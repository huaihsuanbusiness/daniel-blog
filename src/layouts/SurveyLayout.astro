---
export interface Props {
  title?: string;
  description?: string;
  /** Set to 'elder' for larger text suitable for senior users */
  size?: 'normal' | 'elder';
}
const {
  title = '市場調查',
  description = 'AI 陪伴夥伴市場調查',
  size = 'normal',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="zh" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <script is:inline>
    // Apply theme before render to avoid flash
    const stored = localStorage.getItem('theme');
    document.documentElement.dataset.theme = stored || 'dark';
  </script>
  <style>
    :root {
      --bg-page: #f9f7f4;
      --bg-card: #fff;
      --text-primary: #1a1a1a;
      --text-secondary: #666;
      --text-muted: #888;
      --border-color: #e0ddd8;
      --hover-bg: #f0ede8;
      --accent: #4a7c59;
      --accent-hover: #3d6649;
      --shadow: rgba(0,0,0,0.06);
      --error-bg: #fff0f0;
      --error-border: #fcc;
      --error-text: #c44;
      --header-bg: #fff;
    }
    html[data-theme='dark'] {
      --bg-page: #111214;
      --bg-card: #1c1e21;
      --text-primary: #e8e6e3;
      --text-secondary: #a0a0a0;
      --text-muted: #707070;
      --border-color: #2e3033;
      --hover-bg: #262829;
      --shadow: rgba(0,0,0,0.3);
      --error-bg: #2a1a1a;
      --error-border: #5c2020;
      --error-text: #f07070;
      --header-bg: #1c1e21;
    }
    * {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang TC', 'Microsoft JhengHei', sans-serif;
      background: var(--bg-page);
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 100vh;
      transition: background 0.2s, color 0.2s;
    }
    .survey-topbar {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 12px 16px;
      background: var(--header-bg);
      border-bottom: 1px solid var(--border-color);
      transition: background 0.2s;
    }
    .theme-toggle {
      position: relative;
      width: 36px;
      height: 32px;
      padding: 0;
      background: transparent;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      color: var(--text-muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s, color 0.15s;
    }
    .theme-toggle:hover {
      border-color: var(--accent);
      color: var(--text-primary);
    }
    .theme-icon {
      position: absolute;
      transition: opacity 0.15s, transform 0.15s;
    }
    :global(html[data-theme='dark']) .theme-icon-moon,
    :global(html[data-theme='light']) .theme-icon-sun {
      opacity: 0;
      transform: scale(0.8) rotate(-12deg);
    }
    :global(html[data-theme='dark']) .theme-icon-sun,
    :global(html[data-theme='light']) .theme-icon-moon {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
    .survey-container {
      max-width: 640px;
      margin: 0 auto;
      padding: 24px 16px 80px;
    }
    .survey-header {
      text-align: center;
      padding: 32px 0 24px;
    }
    .survey-header h1 {
      font-size: 1.5rem;
      font-weight: 600;
      margin: 0 0 8px;
      color: var(--text-primary);
    }
    .survey-header p {
      font-size: 1rem;
      color: var(--text-secondary);
      margin: 0;
    }
    .question-block {
      position: relative;
      background: var(--bg-card);
      border: 1px solid color-mix(in srgb, var(--border-color) 92%, transparent);
      border-radius: 12px;
      padding: 20px 20px 30px;
      margin-bottom: 24px;
      box-shadow: 0 1px 4px var(--shadow);
      transition: background 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .question-block::after {
      content: '';
      position: absolute;
      left: 20px;
      right: 20px;
      bottom: 0;
      height: 2px;
      background: color-mix(in srgb, var(--border-color) 96%, transparent);
    }
    .question-code {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 6px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }
    .question-text {
      font-size: 1.1rem;
      font-weight: 500;
      margin-bottom: 14px;
      color: var(--text-primary);
    }
    .options-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .options-list li {
      margin-bottom: 10px;
    }
    .options-list li:last-child {
      margin-bottom: 0;
    }
    .option-label {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.15s;
      font-size: 1rem;
      color: var(--text-primary);
    }
    .option-label:hover {
      background: var(--hover-bg);
    }
    .option-label input[type="radio"],
    .option-label input[type="checkbox"] {
      margin-top: 3px;
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      accent-color: var(--accent);
    }
    .submit-btn {
      appearance: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: min(100%, 340px);
      min-height: 56px;
      padding: 16px 28px;
      background: linear-gradient(135deg, var(--accent) 0%, color-mix(in srgb, var(--accent) 82%, #111 18%) 100%);
      color: #fff;
      border: 1px solid color-mix(in srgb, var(--accent) 78%, #000 22%);
      border-radius: 999px;
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: 0.01em;
      cursor: pointer;
      text-align: center;
      margin: 24px auto 0;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.08);
      transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease, filter 0.15s ease;
    }
    .submit-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 28px rgba(0, 0, 0, 0.14), 0 4px 10px rgba(0, 0, 0, 0.08);
      filter: brightness(1.03);
    }
    .submit-btn:active {
      transform: translateY(0);
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.08);
    }
    .submit-btn:disabled {
      opacity: 0.62;
      cursor: not-allowed;
      transform: none;
      filter: saturate(0.8);
      box-shadow: none;
    }
    .error-msg {
      background: var(--error-bg);
      border: 1px solid var(--error-border);
      border-radius: 8px;
      padding: 12px 16px;
      color: var(--error-text);
      font-size: 0.95rem;
      margin-bottom: 16px;
    }
    @keyframes missing-pulse {
      0%   { box-shadow: 0 0 0 0 rgba(200, 60, 60, 0.5); border-color: var(--error-border); }
      40%  { box-shadow: 0 0 0 6px rgba(200, 60, 60, 0); border-color: #e05555; }
      70%  { box-shadow: 0 0 0 3px rgba(200, 60, 60, 0.3); border-color: #e05555; }
      100% { box-shadow: 0 0 0 0 rgba(200, 60, 60, 0); border-color: var(--error-border); }
    }
    .question-block.question-missing {
      animation: missing-pulse 1.2s ease-out 2;
      border: 2px solid var(--error-border);
      background: var(--error-bg);
    }
    .text-input {
      width: 100%;
      padding: 12px;
      border: 1.5px solid var(--border-color);
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      resize: vertical;
      min-height: 100px;
      background: var(--bg-page);
      color: var(--text-primary);
      transition: border-color 0.15s, background 0.2s, color 0.2s;
    }
    textarea.text-input {
      min-height: 168px;
      padding: 14px 16px;
      line-height: 1.6;
    }
    .text-input:focus {
      outline: none;
      border-color: var(--accent);
    }
    .scale-input {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .scale-input label {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.95rem;
      color: var(--text-primary);
    }
    .scale-input input[type="radio"] {
      accent-color: var(--accent);
    }
    .scale-wrapper {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .link-box {
      background: var(--bg-page);
      border: 1.5px solid var(--accent);
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 0.95rem;
      color: var(--accent);
      word-break: break-all;
      cursor: pointer;
      margin-bottom: 8px;
      transition: background 0.15s;
    }
    .link-box:hover {
      background: var(--hover-bg);
    }
    .share-block {
      margin-top: 32px;
      background: var(--bg-card);
      border-radius: 12px;
      padding: 24px 20px;
    }
    .share-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 12px;
    }
    .share-hint {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin: 0;
    }
    .thankyou-block {
      text-align: center;
      padding: 40px 0;
    }
    .big-check {
      font-size: 4rem;
      color: var(--accent);
      margin-bottom: 16px;
    }
    .thankyou-block h2 {
      font-size: 1.6rem;
      font-weight: 600;
      margin: 0 0 16px;
      color: var(--text-primary);
    }
    .thankyou-block p {
      font-size: 1.05rem;
      color: var(--text-secondary);
      line-height: 1.7;
      margin: 0 0 12px;
    }

    #contact-conditional {
      display: none;
    }
    #contact-conditional.revealed {
      display: block;
      animation: fadeSlideIn 0.3s ease-out;
    }
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .section-divider {
      border: none;
      border-top: 2px dashed var(--border-color);
      margin: 32px 0;
    }
    .contact-thanks {
      font-size: 1rem;
      color: var(--text-secondary);
      line-height: 1.7;
      margin: 0 0 20px;
    }
    .contact-list {
      list-style: none;
      padding: 0;
      margin: 0 0 16px 0;
    }
    .contact-list li {
      padding: 4px 0;
      color: var(--text-primary);
      font-size: 1rem;
    }
    .contact-list li::before {
      content: '✓ ';
      color: var(--accent);
      margin-right: 6px;
    }
    .contact-note {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 16px;
      line-height: 1.6;
    }
    .contact-section-label {
      font-size: 0.8rem;
      color: #4a7c59;
      font-weight: 600;
      margin-bottom: 8px;
      letter-spacing: 0.5px;
    }

    /* Elder mode — larger text for senior users */
    [data-survey-size='elder'] {
      font-size: 24px;
    }
    [data-survey-size='elder'] .survey-header h1 {
      font-size: 2.1rem;
    }
    [data-survey-size='elder'] .question-text {
      font-size: 1.5rem;
    }
    [data-survey-size='elder'] .option-label {
      font-size: 1.3rem;
      padding: 14px 16px;
    }
    [data-survey-size='elder'] .option-label input[type='radio'],
    [data-survey-size='elder'] .option-label input[type='checkbox'] {
      width: 24px;
      height: 24px;
    }
    [data-survey-size='elder'] .question-block {
      padding: 28px 24px 38px;
      margin-bottom: 28px;
    }
    [data-survey-size='elder'] .question-block::after {
      left: 24px;
      right: 24px;
      height: 2px;
    }
    [data-survey-size='elder'] .submit-btn {
      font-size: 1.28rem;
      min-height: 64px;
      width: min(100%, 380px);
      padding: 18px 32px;
      margin: 4px auto 0;
    }
    [data-survey-size='elder'] .contact-row .text-input {
      margin-bottom: 0;
    }
    [data-survey-size='elder'] textarea.text-input {
      min-height: 196px;
      font-size: 1.08rem;
    }
    [data-survey-size='elder'] .scale-input label {
      font-size: 1.15rem;
    }
  </style>
</head>
<body data-survey-size={size}>
  <div class="survey-topbar">
    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
      <svg class="theme-icon theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
      </svg>
      <svg class="theme-icon theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/>
      </svg>
    </button>
  </div>
  <div class="survey-container">
    <div class="survey-header">
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
    <slot />
  </div>
  <script is:inline>
    const toggle = document.getElementById('theme-toggle');
    toggle.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
      const next = current === 'light' ? 'dark' : 'light';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  </script>
</body>
</html>
