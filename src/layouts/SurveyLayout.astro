---
export interface Props {
  title?: string;
  description?: string;
}
const { title = '市場調查', description = 'AI 陪伴夥伴市場調查' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <style>
    * {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang TC', 'Microsoft JhengHei', sans-serif;
      background: #f9f7f4;
      color: #2a2a2a;
      line-height: 1.6;
      min-height: 100vh;
    }
    .survey-container {
      max-width: 640px;
      margin: 0 auto;
      padding: 24px 16px 80px;
    }
    .survey-header {
      text-align: center;
      padding: 32px 0 24px;
    }
    .survey-header h1 {
      font-size: 1.5rem;
      font-weight: 600;
      margin: 0 0 8px;
      color: #1a1a1a;
    }
    .survey-header p {
      font-size: 1rem;
      color: #666;
      margin: 0;
    }
    .question-block {
      background: #fff;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 16px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .question-code {
      font-size: 0.8rem;
      color: #888;
      margin-bottom: 6px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }
    .question-text {
      font-size: 1.1rem;
      font-weight: 500;
      margin-bottom: 14px;
      color: #1a1a1a;
    }
    .options-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .options-list li {
      margin-bottom: 10px;
    }
    .options-list li:last-child {
      margin-bottom: 0;
    }
    .option-label {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.15s;
      font-size: 1rem;
    }
    .option-label:hover {
      background: #f0ede8;
    }
    .option-label input[type="radio"],
    .option-label input[type="checkbox"] {
      margin-top: 3px;
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      accent-color: #4a7c59;
    }
    .submit-btn {
      display: block;
      width: 100%;
      padding: 16px;
      background: #4a7c59;
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
      margin-top: 24px;
      transition: background 0.15s, opacity 0.15s;
    }
    .submit-btn:hover {
      background: #3d6649;
    }
    .submit-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .error-msg {
      background: #fff0f0;
      border: 1px solid #fcc;
      border-radius: 8px;
      padding: 12px 16px;
      color: #c44;
      font-size: 0.95rem;
      margin-bottom: 16px;
    }
    .text-input {
      width: 100%;
      padding: 12px;
      border: 1.5px solid #ddd;
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      resize: vertical;
      min-height: 100px;
    }
    .text-input:focus {
      outline: none;
      border-color: #4a7c59;
    }
    .scale-input {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .scale-input label {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.95rem;
    }
    .scale-input input[type="radio"] {
      accent-color: #4a7c59;
    }
    .scale-wrapper {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.85rem;
      color: #888;
    }
  </style>
</head>
<body>
  <div class="survey-container">
    <div class="survey-header">
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
    <slot />
  </div>
</body>
</html>
