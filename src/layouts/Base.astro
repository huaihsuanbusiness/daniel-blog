---
import SearchModal from '../components/SearchModal.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: 'en' | 'zh';
}

const {
  title,
  description = 'Personal blog by Daniel.',
  ogImage,
  lang = 'en',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      // Replace Cloudflare Image Resizing _image?f=svg URLs with direct SVG href
      // f=svg is not supported by Cloudflare Images (returns 400)
      // This must run before any <img> tags are parsed to avoid failed requests
      document.addEventListener('DOMNodeInserted', function handler(e) {
        var el = e.target;
        if (!el || !(el instanceof HTMLElement)) return;
        if (el.tagName === 'IMG') {
          fixImg(el);
        }
        var imgs = el.querySelectorAll && el.querySelectorAll('img');
        if (imgs) imgs.forEach(fixImg);
      });
      function fixImg(img) {
        try {
          var src = img.getAttribute('src');
          if (!src) return;
          var url;
          try { url = new URL(src, window.location.origin); } catch { return; }
          if (url.pathname !== '/_image') return;
          var href = url.searchParams.get('href');
          if (!href || !/\.svg(?:[?#].*)?$/i.test(href)) return;
          img.src = href;
          img.removeAttribute('srcset');
          img.removeAttribute('sizes');
        } catch {}
      }
      // Fix any already-parsed imgs immediately
      if (typeof document !== 'undefined') {
        document.querySelectorAll && document.querySelectorAll('img').forEach(fixImg);
      }
    </script>
    <script is:inline>
      if (
        typeof window !== 'undefined' &&
        window.location.protocol === 'http:' &&
        !['localhost', '127.0.0.1'].includes(window.location.hostname)
      ) {
        window.location.replace(`https://${window.location.host}${window.location.pathname}${window.location.search}${window.location.hash}`);
      }
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- KaTeX CSS for math rendering -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />

    <!-- Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        const theme = stored || (prefersLight ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <style is:global>
      @import '/src/styles/global.css';
    </style>
  </head>
  <body>
    <slot />
    <SearchModal lang={lang} />
  </body>
</html>
