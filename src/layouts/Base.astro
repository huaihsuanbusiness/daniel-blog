---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Personal blog by Daniel.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Detect language from URL: path segment first, then query param
const currentPath = Astro.url.pathname;
const searchParams = Astro.url.searchParams;
const queryLang = searchParams.get('lang');
const isZh = currentPath.includes('/zh/') || queryLang === 'zh';
const isEn = currentPath.includes('/en/') || queryLang === 'en';
const pageLang = isZh ? 'zh' : isEn ? 'en' : 'en';
---

<!doctype html>
<html lang={pageLang} data-lang={pageLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <style is:global>
      @import '/src/styles/global.css';
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
