---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/zh') ? 'zh' : 'en';

const content = {
  en: {
    title: '404 — Page not found',
    description: 'The page you are looking for does not exist.',
    eyebrow: '404 / Lost route',
    heading: 'This page does not exist.',
    body: 'The link may be outdated, the URL may be wrong, or the page may have moved. Let’s get you back to something useful.',
    primaryCta: 'Go home',
    secondaryCta: 'Browse blog',
    note: 'If you came here from an internal link, it is worth fixing.',
  },
  zh: {
    title: '404 — 找不到頁面',
    description: '你要找的頁面不存在。',
    eyebrow: '404 / 路徑遺失',
    heading: '這個頁面不存在。',
    body: '可能是連結過期、網址打錯，或頁面已經移動。先把你帶回可用的地方。',
    primaryCta: '回首頁',
    secondaryCta: '逛部落格',
    note: '如果這是站內連結帶你進來的，代表它值得被修掉。',
  },
} as const;

const copy = content[lang as 'en' | 'zh'];
const homeHref = lang === 'zh' ? '/zh/' : '/en/';
const blogHref = lang === 'zh' ? '/zh/blog?category=all' : '/en/blog?category=all';
---

<Base title={`danielcanfly — ${copy.title}`} description={copy.description} lang={lang}>
  <Header currentLang={lang} />

  <main class="not-found-page">
    <section class="not-found-hero">
      <div class="container not-found-shell">
        <div class="not-found-copy">
          <p class="not-found-eyebrow animate-in">{copy.eyebrow}</p>
          <h1 class="not-found-title animate-in animate-delay-1">{copy.heading}</h1>
          <p class="not-found-body muted animate-in animate-delay-2">{copy.body}</p>

          <div class="not-found-actions animate-in animate-delay-3">
            <a href={homeHref} class="not-found-btn not-found-btn-primary">{copy.primaryCta}</a>
            <a href={blogHref} class="not-found-btn not-found-btn-secondary">{copy.secondaryCta}</a>
          </div>

          <p class="not-found-note animate-in animate-delay-4">{copy.note}</p>
        </div>

        <div class="not-found-visual animate-in animate-delay-2">
          <div id="not-found-lottie" class="not-found-lottie" aria-label="404 animation"></div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script is:inline type="module">
  const container = document.getElementById('not-found-lottie');

  if (container) {
    import('https://cdn.jsdelivr.net/npm/lottie-web@5.12.2/+esm')
      .then(({ default: lottie }) => {
        lottie.loadAnimation({
          container,
          renderer: 'svg',
          loop: true,
          autoplay: true,
          path: '/animations/404-lottie.json',
          rendererSettings: {
            preserveAspectRatio: 'xMidYMid meet',
            progressiveLoad: true,
          },
        });

        container.dataset.ready = 'true';
      })
      .catch(() => {
        container.dataset.ready = 'fallback';
      });
  }
</script>

<style>
  .not-found-page {
    --not-found-accent: #66dcff;
    --not-found-accent-hover: #a8efff;
    --not-found-accent-soft: rgba(102, 220, 255, 0.16);
    --not-found-text: #f3f8ff;
    --not-found-text-soft: #c8d6e5;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
  }

  .not-found-hero {
    width: 100%;
    padding: var(--space-8) 0;
  }

  .not-found-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 520px);
    align-items: center;
    gap: var(--space-6);
  }

  .not-found-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--not-found-accent);
    margin-bottom: var(--space-2);
  }

  .not-found-title {
    max-width: 10ch;
    margin-bottom: var(--space-3);
    line-height: 1.02;
    color: var(--not-found-text);
  }

  .not-found-body {
    max-width: 56ch;
    font-size: 1rem;
    margin-bottom: var(--space-4);
    color: var(--not-found-text-soft);
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: var(--space-3);
  }

  .not-found-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 148px;
    padding: 0.92rem 1.25rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 600;
    transition: transform var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
  }

  .not-found-btn:hover {
    transform: translateY(-2px);
  }

  .not-found-btn-primary {
    color: #041522;
    background: var(--not-found-accent);
    border-color: var(--not-found-accent);
  }

  .not-found-btn-primary:hover {
    color: #041522;
    background: var(--not-found-accent-hover);
    border-color: var(--not-found-accent-hover);
    box-shadow: 0 14px 30px var(--not-found-accent-soft);
  }

  .not-found-btn-secondary {
    color: var(--not-found-text);
    background: transparent;
    border-color: color-mix(in srgb, var(--not-found-accent) 34%, var(--color-border));
  }

  .not-found-btn-secondary:hover {
    color: var(--not-found-accent);
    border-color: var(--not-found-accent);
    box-shadow: 0 14px 30px rgba(102, 220, 255, 0.1);
  }

  .not-found-note {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--not-found-text-soft) 82%, var(--color-muted));
    max-width: 56ch;
  }

  .not-found-visual {
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .not-found-lottie {
    width: min(100%, 460px);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 14px 36px rgba(102, 220, 255, 0.12));
  }

  .not-found-lottie :global(svg) {
    width: 100%;
    height: auto;
  }

  .not-found-lottie[data-ready='fallback']::before {
    content: '404';
    color: var(--not-found-accent);
    font-family: var(--font-display);
    font-size: 4.25rem;
    font-weight: 700;
    letter-spacing: -0.05em;
  }

  @media (max-width: 960px) {
    .not-found-shell {
      grid-template-columns: 1fr;
    }

    .not-found-title {
      max-width: 14ch;
    }

    .not-found-visual {
      min-height: 420px;
      order: -1;
    }

    .not-found-lottie {
      width: min(100%, 360px);
    }
  }

  @media (max-width: 640px) {
    .not-found-hero {
      padding: var(--space-5) 0 var(--space-6);
    }

    .not-found-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .not-found-btn {
      width: 100%;
    }

    .not-found-visual {
      min-height: 340px;
      border-radius: 24px;
    }

    .not-found-lottie {
      width: min(100%, 300px);
    }
  }
</style>
