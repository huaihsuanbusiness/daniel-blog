---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/PostCard.astro';
import CategoryFilter from '../../../components/CategoryFilter.astro';
import { getCollection } from 'astro:content';
import { getOrderedCategories, normalizeCategory } from '../../../utils/categories';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;
const selectedCategory = Astro.url.searchParams.get('category');

const allPosts = await getCollection('blog');
let posts = allPosts
  .filter(post => post.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const slug = post.id.replace(/^[^/]+\//, '');
    return { ...post, slug };
  });

if (selectedCategory) {
  posts = posts.filter(post =>
    post.data.categories.some(cat => normalizeCategory(cat) === selectedCategory)
  );
}

const labels = {
  en: { title: 'Blog', count: (n: number) => `${n} ${n === 1 ? 'article' : 'articles'} across AI, product, business, Web3, travel, and more.` },
  zh: { title: '部落格', count: (n: number) => `共 ${n} 篇文章，涵蓋 AI、產品、創業、商業、Web3 與旅行。` },
};

const label = labels[lang as 'en' | 'zh'];
const allCategories = getOrderedCategories(
  allPosts
    .filter(p => p.id.startsWith(`${lang}/`))
    .flatMap(p => p.data.categories)
);
---

<Base title="Blog — danielcanfly" description="Thoughts on AI, product, entrepreneurship, business, Web3, and travel." lang={lang!}>
  <Header currentLang={lang} />

  <main class="blog-main">
    <div class="container">
      <header class="blog-header animate-in">
        <h1 class="blog-title">{label.title}</h1>
        <p class="blog-subtitle muted">{label.count(posts.length)}</p>
      </header>

      <CategoryFilter categories={allCategories} lang={lang as 'en' | 'zh'} />

      <div class="posts-grid" id="posts-grid">
        {posts.map((post, i) => (
          <div
            class:list={['animate-in', { 'animate-delay-1': i % 3 === 1, 'animate-delay-2': i % 3 === 2 }]}
            data-category={post.data.categories.map(cat => normalizeCategory(cat)).filter(Boolean).join(' ')}
          >
            <PostCard
              slug={`${lang}/${post.slug}`}
              title={post.data.title}
              description={post.data.description}
              categories={post.data.categories}
              date={post.data.date}
              lang={lang as 'en' | 'zh'}
              featured={post.data.featured}
            />
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  .blog-main {
    padding: var(--space-10) 0;
    min-height: 60vh;
  }

  .blog-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-1);
  }

  .blog-subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
