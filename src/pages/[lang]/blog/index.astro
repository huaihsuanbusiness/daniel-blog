---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/PostCard.astro';
import CategoryFilter from '../../../components/CategoryFilter.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS, getOrderedCategories, normalizeCategory } from '../../../utils/categories';
import { getSeriesMeta } from '../../../utils/seriesMeta';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;
const selectedCategory = Astro.url.searchParams.get('category');

const allPosts = await getCollection('blog');
const languagePosts = allPosts
  .filter(post => post.id.endsWith(`/${lang}`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const slug = post.id.split('/')[0];
    return { ...post, slug };
  });

const posts = selectedCategory
  ? languagePosts.filter(post =>
      post.data.categories.some(cat => normalizeCategory(cat) === selectedCategory)
    )
  : languagePosts;

const totalPosts = languagePosts.length;
const labels = {
  en: {
    title: 'Blog',
    total: 'total',
    summary: (visible: number, total: number, categoryLabel?: string) =>
      categoryLabel
        ? `${visible} ${visible === 1 ? 'article' : 'articles'} in ${categoryLabel}. ${total} total on the site.`
        : `${visible} ${visible === 1 ? 'article' : 'articles'} across AI, product, startup, business, Web3, and travel.`,
    emptyTitle: 'Nothing here yet',
    emptyDesc: (categoryLabel?: string) =>
      categoryLabel
        ? `No published articles in ${categoryLabel} yet. Try another category or come back soon.`
        : 'No published articles yet. Check back soon.',
    clearFilter: 'Show all articles',
  },
  zh: {
    title: '部落格',
    total: '全部',
    summary: (visible: number, total: number, categoryLabel?: string) =>
      categoryLabel
        ? `${categoryLabel} 目前有 ${visible} 篇文章；全站共 ${total} 篇。`
        : `目前共 ${visible} 篇文章，涵蓋 AI、產品、創業、商業、Web3 與旅行。`,
    emptyTitle: '這個分類還沒有文章',
    emptyDesc: (categoryLabel?: string) =>
      categoryLabel
        ? `${categoryLabel} 目前尚未發佈文章，可以先看看其他分類，或之後再回來。`
        : '目前尚未發佈文章，敬請期待。',
    clearFilter: '查看全部文章',
  },
};

const label = labels[lang as 'en' | 'zh'];
const allCategories = getOrderedCategories(languagePosts.flatMap(p => p.data.categories));
const selectedCategoryLabel = selectedCategory && selectedCategory in CATEGORY_LABELS
  ? CATEGORY_LABELS[selectedCategory as keyof typeof CATEGORY_LABELS][lang as 'en' | 'zh']
  : undefined;

---

<Base title="Blog — danielcanfly" description="Thoughts on AI, product, startup, business, Web3, and travel." lang={lang!}>
  <Header currentLang={lang} />

  <main class="blog-main">
    <div class="container">
      <header class="blog-header animate-in">
        <div class="blog-header-top">
          <h1 class="blog-title">{label.title}</h1>
          <div class="blog-stats">
            <span id="blog-count-pill" class:list={['stat-pill', { 'stat-pill-active': !!selectedCategoryLabel }]} data-total-label={label.total} data-total-count={totalPosts}>{posts.length} {label.total}</span>
            {selectedCategoryLabel && <span class="stat-pill stat-pill-active">{selectedCategoryLabel}</span>}
          </div>
        </div>
        <p class="blog-subtitle muted">{label.summary(posts.length, totalPosts, selectedCategoryLabel)}</p>
      </header>

      <CategoryFilter categories={allCategories} lang={lang as 'en' | 'zh'} />

      {posts.length === 0 ? (
        <section class="empty-category animate-in">
          <div class="empty-category-icon">◌</div>
          <h2>{label.emptyTitle}</h2>
          <p class="muted">{label.emptyDesc(selectedCategoryLabel)}</p>
          <a href={`/${lang}/blog`} class="empty-category-link">{label.clearFilter}</a>
        </section>
      ) : (
        <div class="posts-grid" id="posts-grid">
          {posts.map((post, i) => (
            <div
              class:list={['animate-in', { 'animate-delay-1': i % 3 === 1, 'animate-delay-2': i % 3 === 2 }]}
              data-post-card
              data-sort-key={post.data.date.toISOString().slice(0,16)}
              data-category={post.data.categories.map(cat => normalizeCategory(cat)).filter(Boolean).join(' ')}
              data-categories={JSON.stringify(post.data.categories.map(cat => normalizeCategory(cat)).filter(Boolean))}
              data-series-key={getSeriesMeta(post.slug, lang as 'en' | 'zh', post.data.series)?.key || ''}
              data-series-label={getSeriesMeta(post.slug, lang as 'en' | 'zh', post.data.series)?.label || ''}
              data-series-order={String(getSeriesMeta(post.slug, lang as 'en' | 'zh', post.data.series)?.order || '')}
            >
              <PostCard
                slug={post.slug}
                title={post.data.title}
                description={post.data.description}
                categories={post.data.categories}
                date={post.data.date}
                lang={lang as 'en' | 'zh'}
                featured={post.data.featured}
                search={selectedCategory ? `?category=${selectedCategory}${Astro.url.searchParams.get('sort') ? `&sort=${Astro.url.searchParams.get('sort')}` : ''}` : Astro.url.searchParams.get('sort') ? `?sort=${Astro.url.searchParams.get('sort')}` : ''}
              />
            </div>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>

<style>
  .blog-main {
    padding: var(--space-6) 0;
    min-height: 60vh;
  }

  .blog-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .blog-title {
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .blog-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .stat-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
  }

  .stat-pill-active {
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface));
  }

  .blog-subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    max-width: 72ch;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    align-items: start;
  }

  /* Each card is a full-height flex container */
  .posts-grid :global(.post-card) {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .posts-grid :global(.card-link) {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .posts-grid :global(.card-inner) {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 260px;
  }

  .posts-grid :global(.card-title) {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.35;
  }

  .posts-grid :global(.card-desc) {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .posts-grid :global(.card-footer) {
    margin-top: auto;
  }

  /* List view: 1 column */
  .posts-grid.view-list {
    grid-template-columns: 1fr;
  }

  .posts-grid.view-list :global(.card-inner) {
    min-height: unset;
  }

  .posts-grid.view-list :global(.card-title),
  .posts-grid.view-list :global(.card-desc) {
    -webkit-line-clamp: 1;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .posts-grid.view-list :global(.card-footer) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .empty-category {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-2);
    min-height: 320px;
    padding: var(--space-8) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    background:
      radial-gradient(circle at top, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 55%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 94%, transparent), var(--color-surface));
  }

  .empty-category-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
    color: var(--color-accent);
    font-size: 2rem;
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
  }

  .empty-category h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .empty-category p {
    max-width: 48ch;
  }

  .empty-category-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.875rem;
    transition: all var(--transition-fast);
  }

  .empty-category-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .blog-main {
      padding: var(--space-3) 0;
    }

    .blog-header-top {
      flex-direction: column;
    }

    .blog-stats {
      justify-content: flex-start;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function syncPostCardLinks() {
    // Read category from sessionStorage first (set by this session's interactions),
    // then fall back to URL params for direct-link visitors.
    const savedCategory = sessionStorage.getItem('blog-category') || '';
    const savedSort = sessionStorage.getItem('blog-sort') || '';
    const urlParams = new URL(window.location.href).searchParams;
    const urlCategory = urlParams.get('category') || '';
    const urlSort = urlParams.get('sort') || '';

    // URL wins (for shareable links); sessionStorage only as fallback for tab persistence
    const activeCat = urlCategory || savedCategory || 'all';
    const activeSort = urlSort || savedSort || 'new';

    const params = new URLSearchParams();
    if (activeCat && activeCat !== 'all') params.set('category', activeCat);
    if (activeSort) params.set('sort', activeSort);
    const searchStr = params.toString() ? `?${params.toString()}` : '';

    // Update every article card link to carry current category + sort
    document.querySelectorAll('[data-post-link]').forEach(link => {
      if (!(link instanceof HTMLAnchorElement)) return;
      const href = link.getAttribute('href');
      if (!href) return;
      const url = new URL(href, window.location.origin);
      url.search = searchStr.replace('?', '');
      link.href = `${url.pathname}${url.search ? '?' + url.search : ''}`;
    });

    // Clear-link removes category but keeps sort
    const clearLink = document.querySelector('.empty-category-link');
    if (clearLink instanceof HTMLAnchorElement) {
      const clearParams = new URLSearchParams();
      if (activeSort && activeSort !== 'new') clearParams.set('sort', activeSort);
      const clearSearch = clearParams.toString() ? `?${clearParams.toString()}` : '';
      clearLink.href = `/${lang}/blog${clearSearch}`;
    }
  }

  function applyCategoryFilter() {
    // URL wins; sessionStorage is only for this session's tab-click persistence
    const urlParams = new URL(window.location.href).searchParams;
    const urlCat = urlParams.get('category') || '';
    const sessionCat = sessionStorage.getItem('blog-category') || '';
    const activeCat = urlCat || sessionCat || 'all';
    const cards = document.querySelectorAll('[data-post-card]');
    let visible = 0;

    cards.forEach(card => {
      const cats = JSON.parse((card as HTMLElement).dataset.categories || '[]');
      const show = activeCat === 'all' || cats.includes(activeCat);
      (card as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });

    const empty = document.querySelector('.posts-grid-empty-state');
    if (empty) (empty as HTMLElement).style.display = visible === 0 ? '' : 'none';
  }

  function syncListRuntimeState() {
    applyCategoryFilter();
    syncPostCardLinks();
  }

  // Persist category + sort to sessionStorage so article pages can pick them up
  function persistFilterState() {
    const params = new URL(window.location.href).searchParams;
    sessionStorage.setItem('blog-category', params.get('category') || '');
    sessionStorage.setItem('blog-sort', params.get('sort') || '');
    document.dispatchEvent(new CustomEvent('blog:urlchange'));
  }

  // Run on load and whenever controls change
  syncListRuntimeState();

  // Also run when category tabs are clicked
  document.querySelectorAll('[data-filter-category]').forEach((tab) => {
    tab.addEventListener('click', () => {
      setTimeout(() => { syncListRuntimeState(); persistFilterState(); }, 0);
    });
  });

  // Re-apply when sort changes (it updates URL)
  const sortSelect = document.getElementById('sort-select');
  sortSelect?.addEventListener('change', () => {
    setTimeout(() => { syncListRuntimeState(); persistFilterState(); }, 0);
  });

  window.addEventListener('popstate', () => {
    syncListRuntimeState();
    persistFilterState();
  });
</script>
