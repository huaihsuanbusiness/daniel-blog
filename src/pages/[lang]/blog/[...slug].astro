---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { calculateReadTime } from '../../../utils/readTime';
import { getCategoryLabel, normalizeCategory } from '../../../utils/categories';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map(post => {
    const lastSlash = post.id.lastIndexOf('/');
    const slug = post.id.substring(0, lastSlash);
    const lang = post.id.substring(lastSlash + 1);

    return {
      params: { lang, slug },
      props: { post },
    };
  });
}

const { lang, slug } = Astro.params;
const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');
const otherLang = lang === 'zh' ? 'en' : 'zh';
const currentCategory = Astro.url.searchParams.get('category');
const currentSort = Astro.url.searchParams.get('sort');
const sharedQuery = new URLSearchParams();
if (currentCategory) sharedQuery.set('category', currentCategory);
if (currentSort) sharedQuery.set('sort', currentSort);
const sharedQueryString = sharedQuery.toString() ? `?${sharedQuery.toString()}` : '';
const otherPost = allPosts.find(p => p.id === `${slug}/${otherLang}`);
const otherVersionHref = otherPost ? `/${otherLang}/blog/${otherPost.id.split('/')[0]}${sharedQueryString}` : null;

const sameLangPosts = allPosts
  .filter(p => p.id.endsWith(`/${lang}`))
  .map(p => ({ ...p, slug: p.id.split('/')[0] }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const runtimeNavPosts = sameLangPosts.map(p => ({
  slug: p.slug,
  date: p.data.date.valueOf(),
  categories: p.data.categories.map(cat => normalizeCategory(cat)).filter(Boolean),
}));
const otherPostSlug = otherPost ? otherPost.id.split('/')[0] : null;
const currentIndex = sameLangPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sameLangPosts.length - 1 ? sameLangPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sameLangPosts[currentIndex - 1] : null;

const readTime = calculateReadTime(post.body);

const formattedDate = new Intl.DateTimeFormat(lang === 'zh' ? 'zh-TW' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.date);

const otherLangLabel = lang === 'zh' ? 'English' : '中文';
const primaryCategory = normalizeCategory(post.data.categories[0] || '') ?? null;

function getSeriesMeta(slug: string, lang: string) {
  if (/^openclaw-getting-started-\d+$/.test(slug)) {
    return { key: 'openclaw-getting-started', label: lang === 'zh' ? 'OpenClaw 快速上手系列' : 'OpenClaw Getting Started' };
  }
  if (/^openclaw-deployment-and-configuration-part-\d+$/.test(slug)) {
    return { key: 'openclaw-deployment-and-configuration', label: lang === 'zh' ? 'OpenClaw 部署與配置系列' : 'OpenClaw Deployment and Configuration' };
  }
  if (/^comfyui-series-\d+$/.test(slug)) {
    return { key: 'comfyui-series', label: lang === 'zh' ? 'ComfyUI 系列' : 'ComfyUI Series' };
  }
  if (/^rag-engineering-in-practice-\d+$/.test(slug)) {
    return { key: 'rag-engineering-in-practice', label: lang === 'zh' ? 'RAG 工程實戰系列' : 'RAG Engineering in Practice' };
  }
  if (/^pm-llm-application-engineering-\d+$/.test(slug)) {
    return { key: 'pm-llm-application-engineering', label: lang === 'zh' ? 'PM LLM 應用工程與治理系列' : 'LLM Application Engineering and Governance for PMs Series' };
  }
  if (/^ai-agentic-workflow-series-\d+$/.test(slug)) {
    return { key: 'ai-agentic-workflow', label: lang === 'zh' ? 'AI 代理工作流系列' : 'AI Agentic Workflow Series' };
  }
  if (/^build-mcp-server-part-\d+$/.test(slug)) {
    return { key: 'build-mcp-server', label: lang === 'zh' ? '自主建造 MCP Server 系列' : 'Build Your Own MCP Server' };
  }
  if (/^building-ai-skills-series-part-\d+$/.test(slug)) {
    return { key: 'building-ai-skills', label: lang === 'zh' ? '打造 AI Skill 系列' : 'Building AI Skills Series' };
  }
  if (/^mcp-engineering-deep-dive-\d+$/.test(slug)) {
    return { key: 'mcp-engineering-deep-dive', label: lang === 'zh' ? 'MCP 工程深化系列' : 'MCP Engineering Deep Dive' };
  }
  if (/^pm-product-data-and-experimentation-\d+$/.test(slug)) {
    return { key: 'pm-product-data-and-experimentation', label: lang === 'zh' ? 'PM 產品數據與實驗系列' : 'PM Product Data and Experimentation Series' };
  }
  if (/^pm-growth-levers-monetisation-\d+$/.test(slug)) {
    return { key: 'pm-growth-levers-monetisation', label: lang === 'zh' ? 'PM 成長槓桿與變現系列' : 'PM Growth Levers and Monetisation Series' };
  }
  if (/^pm-user-research-fieldwork-\d+$/.test(slug)) {
    return { key: 'pm-user-research-fieldwork', label: lang === 'zh' ? 'PM 用戶研究與田野訪查系列' : 'PM User Research and Fieldwork Series' };
  }
  if (/^after-the-pause-\d+$/.test(slug)) {
    return { key: 'after-the-pause', label: lang === 'zh' ? '暫停之後系列' : 'After the Pause Series' };
  }
  if (/^what-reality-corrected-\d+$/.test(slug)) {
    return { key: 'what-reality-corrected', label: lang === 'zh' ? '被現實修正之後系列' : 'What Reality Corrected Series' };
  }
  if (/^local-llm-fine-tuning-\d+$/.test(slug)) {
    return { key: 'local-llm-fine-tuning', label: lang === 'zh' ? '本地 LLM 微調拆解系列' : 'Local LLM Fine-Tuning Breakdown Series' };
  }
  if (/^category-design-for-founders-\d+$/.test(slug)) {
    return { key: 'category-design-for-founders', label: lang === 'zh' ? '創業家的類別創造系列' : 'Category Design for Founders Series' };
  }
  return null;
}

const seriesMeta = getSeriesMeta(slug!, lang!);
const seriesPosts = seriesMeta
  ? sameLangPosts
      .filter(p => getSeriesMeta(p.slug, lang!)?.key === seriesMeta.key)
      .sort((a, b) =>
        ((a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0)) ||
        (a.data.date.valueOf() - b.data.date.valueOf())
      )
  : [];
const currentSeriesIndex = seriesPosts.findIndex(p => p.id === post.id);
---

<Base title={`${post.data.title} — danielcanfly`} description={post.data.description} lang={lang!}>
  <Header currentLang={lang} />

  <article class="post-article">
    <div class="container">
      <header class="post-header animate-in">
        <a id="back-to-blog-link" href={`/${lang}/blog${sharedQueryString}`} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          {lang === 'zh' ? '返回部落格' : 'Back to Blog'}
        </a>

        <div class="post-meta">
          <span class:list={['tag', primaryCategory ? `tag-${primaryCategory}` : undefined]}>
            {getCategoryLabel(post.data.categories[0] || '', lang as 'en' | 'zh')}
          </span>
          <span class="post-date muted">{formattedDate}</span>
          <span class="post-readtime muted">{readTime} min read</span>
        </div>

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>

        {otherVersionHref && (
          <div class="lang-switch">
            <span class="muted">{lang === 'zh' ? '閱讀版本：' : 'Read in:'}</span>
            <a id="other-version-link" href={otherVersionHref} class="lang-btn">{otherLangLabel}</a>
          </div>
        )}
      </header>

      <a id="prev-post-link" href={prevPost ? `/${lang}/blog/${prevPost.slug}${sharedQueryString}` : '#'} class="side-nav side-nav-left" aria-label={lang === 'zh' ? '上一篇' : 'Previous post'} hidden={!prevPost}>
        <span class="side-nav-chip">
          <span class="side-nav-arrow">←</span>
          <span class="side-nav-label">{lang === 'zh' ? '上一篇' : 'Previous'}</span>
        </span>
      </a>
      <a id="next-post-link" href={nextPost ? `/${lang}/blog/${nextPost.slug}${sharedQueryString}` : '#'} class="side-nav side-nav-right" aria-label={lang === 'zh' ? '下一篇' : 'Next post'} hidden={!nextPost}>
        <span class="side-nav-chip">
          <span class="side-nav-label">{lang === 'zh' ? '下一篇' : 'Next'}</span>
          <span class="side-nav-arrow">→</span>
        </span>
      </a>

      <div class="post-content animate-in animate-delay-1">
        <Content />
      </div>

      {seriesMeta && seriesPosts.length > 1 && (
        <div class="post-series-footer animate-in animate-delay-2">
          <div class="series-nav">
            <div class="series-nav-trigger">
              <span class="series-nav-kicker">{lang === 'zh' ? '系列導覽' : 'Series guide'}</span>
              <span class="series-nav-title">{seriesMeta.label}</span>
              <span class="series-nav-count">{currentSeriesIndex + 1}/{seriesPosts.length}</span>
            </div>
            <div class="series-nav-panel">
              {seriesPosts.map((item, index) => (
                <a href={`/${lang}/blog/${item.slug}${sharedQueryString}`} data-series-nav-link class:list={['series-nav-item', { active: item.id === post.id }] }>
                  <span class="series-nav-index">{index + 1}</span>
                  <span class="series-nav-item-title">
                    <span class="series-nav-item-title-link">{item.data.title}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        </div>
      )}

      <footer class="post-footer animate-in animate-delay-2">
        <div class="post-tags">
          {post.data.categories.map(cat => {
            const normalized = normalizeCategory(cat);
            return (
              <span class:list={['tag', normalized ? `tag-${normalized}` : undefined]}>
                {getCategoryLabel(cat, lang as 'en' | 'zh')}
              </span>
            );
          })}
        </div>
        <div class="post-share">
          <a
            href={`https://x.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
          >
            {lang === 'zh' ? '分享到 X' : 'Share on X'}
          </a>
        </div>
      </footer>
    </div>
  </article>

  <Footer />
</Base>

<script define:vars={{ lang, slug, otherLang, otherPostSlug, runtimeNavPosts }}>
  // sessionStorage wins (set by blog list in this session); URL is fallback for direct links
  const sessionCategory = sessionStorage.getItem('blog-category') || '';
  const sessionSort = sessionStorage.getItem('blog-sort') || '';
  const urlParams = new URL(window.location.href).searchParams;
  const urlCategory = urlParams.get('category') || '';
  const urlSort = urlParams.get('sort') || '';

  const runtimeCategory = sessionCategory || urlCategory || null;
  const runtimeSort = sessionSort || urlSort || 'new';

  const sharedParams = new URLSearchParams();
  if (runtimeCategory && runtimeCategory !== 'all') sharedParams.set('category', runtimeCategory);
  if (runtimeSort && runtimeSort !== 'new') sharedParams.set('sort', runtimeSort);

  const sharedQuery = sharedParams.toString() ? `?${sharedParams.toString()}` : '';
  const withQuery = (path) => `${path}${sharedQuery}`;

  const backToBlogLink = document.getElementById('back-to-blog-link');
  if (backToBlogLink instanceof HTMLAnchorElement) {
    backToBlogLink.href = withQuery(`/${lang}/blog`);
  }

  const otherVersionLink = document.getElementById('other-version-link');
  if (otherVersionLink instanceof HTMLAnchorElement && otherPostSlug) {
    otherVersionLink.href = withQuery(`/${otherLang}/blog/${otherPostSlug}`);
  }

  document.querySelectorAll('[data-series-nav-link]').forEach((link) => {
    if (!(link instanceof HTMLAnchorElement)) return;
    const url = new URL(link.href, window.location.origin);
    link.href = withQuery(url.pathname);
  });

  const orderedPosts = [...runtimeNavPosts].sort((a, b) => (
    runtimeSort === 'old' ? a.date - b.date : b.date - a.date
  ));
  const scopedPosts = runtimeCategory && runtimeCategory !== 'all'
    ? orderedPosts.filter((item) => item.categories.includes(runtimeCategory))
    : orderedPosts;
  const currentIndex = scopedPosts.findIndex((item) => item.slug === slug);
  const prevPostRuntime = currentIndex >= 0 && currentIndex < scopedPosts.length - 1 ? scopedPosts[currentIndex + 1] : null;
  const nextPostRuntime = currentIndex > 0 ? scopedPosts[currentIndex - 1] : null;

  const prevLink = document.getElementById('prev-post-link');
  if (prevLink instanceof HTMLAnchorElement) {
    if (prevPostRuntime) {
      prevLink.href = withQuery(`/${lang}/blog/${prevPostRuntime.slug}`);
      prevLink.hidden = false;
    } else {
      prevLink.hidden = true;
    }
  }

  const nextLink = document.getElementById('next-post-link');
  if (nextLink instanceof HTMLAnchorElement) {
    if (nextPostRuntime) {
      nextLink.href = withQuery(`/${lang}/blog/${nextPostRuntime.slug}`);
      nextLink.hidden = false;
    } else {
      nextLink.hidden = true;
    }
  }
</script>


<style>
  .post-article {
    padding: var(--space-8) 0 var(--space-10);
  }

  .post-header {
    max-width: 800px;
    margin: 0 auto var(--space-8);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .post-date,
  .post-readtime {
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-3);
    letter-spacing: -0.02em;
  }

  .post-subtitle {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--space-3);
    max-width: 100%;
    font-style: italic;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    max-width: 100%;
  }

  .series-nav {
    margin-bottom: var(--space-4);
  }

  .series-nav-trigger {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4px 12px;
    align-items: center;
    padding: 10px 14px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 22%, var(--color-border));
    border-radius: 18px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 8%, var(--color-surface)), color-mix(in srgb, var(--color-surface) 94%, transparent));
    cursor: pointer;
    box-shadow: 0 10px 28px color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .series-nav-trigger::-webkit-details-marker {
    display: none;
  }

  .series-nav-kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .series-nav-title {
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .series-nav-count {
    grid-row: span 2;
    align-self: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .series-nav-panel {
    margin-top: 8px;
    max-height: 320px;
    overflow: auto;
    padding: 8px;
    border: 1px solid var(--color-border);
    border-radius: 18px;
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    display: grid;
    gap: 8px;
  }

  .series-nav-item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: start;
    padding: 10px 12px;
    border-radius: 14px;
    color: var(--color-muted);
    text-decoration: none;
    border: 1px solid transparent;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
  }

  .series-nav-item:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
    transform: translateY(-1px);
  }

  .series-nav-item.active {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 25%, var(--color-border));
  }

  .series-nav-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .series-nav-item-title {
    line-height: 1.45;
  }

  .series-nav-item-title-link {
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  .series-nav-item:hover .series-nav-item-title-link {
    text-decoration-color: var(--color-accent);
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
  }

  .lang-btn {
    padding: 4px 10px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    transition: all var(--transition-fast);
  }

  .lang-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .post-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .post-series-footer {
    max-width: 680px;
    margin: var(--space-8) auto 0;
  }

  .side-nav {
    position: fixed;
    top: 0;
    bottom: 0;
    width: 72px;
    z-index: 30;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .side-nav-left {
    left: 0;
    justify-content: flex-start;
  }

  .side-nav-right {
    right: 0;
    justify-content: flex-end;
  }

  .side-nav-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 12px;
    border-radius: 999px;
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    backdrop-filter: blur(10px);
    border: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    opacity: 0;
    transform: translateX(0) scale(0.96);
    transition: opacity var(--transition-fast), transform var(--transition-fast), color var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast);
    pointer-events: none;
  }

  .side-nav-left .side-nav-chip {
    margin-left: 10px;
    transform: translateX(-8px) scale(0.96);
  }

  .side-nav-right .side-nav-chip {
    margin-right: 10px;
    transform: translateX(8px) scale(0.96);
  }

  .side-nav:hover .side-nav-chip {
    opacity: 1;
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
    transform: translateX(0) scale(1);
  }

  .side-nav-arrow {
    font-size: 1rem;
    line-height: 1;
  }

  .side-nav-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
    margin: var(--space-6) 0 var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .post-content :global(h3) {
    font-size: 1.375rem;
    margin: var(--space-4) 0 var(--space-2);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-3);
    max-width: 100%;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: var(--space-3) 0;
    padding-left: var(--space-4);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-1);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-3);
    margin: var(--space-4) 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: var(--space-5) 0;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    display: block;
    overflow-x: auto;
    overflow-y: auto;
    max-height: 520px;
  }

  .post-content :global(thead) {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
  }

  .post-content :global(th),
  .post-content :global(td) {
    min-width: 160px;
    padding: 14px 18px;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--color-border);
    line-height: 1.7;
  }

  .post-content :global(th + th),
  .post-content :global(td + td) {
    border-left: 1px solid var(--color-border);
  }

  .post-content :global(th) {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }

  .post-content :global(td) {
    color: var(--color-text);
  }

  .post-content :global(tbody tr:nth-child(even)) {
    background: color-mix(in srgb, var(--color-surface) 92%, black);
  }

  .post-content :global(tbody tr:hover) {
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-surface));
  }

  .post-content :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .post-content :global(img) {
    display: block;
    width: 100%;
    max-width: 100%;
