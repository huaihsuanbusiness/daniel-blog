---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { calculateReadTime } from '../../../utils/readTime';
import { getCategoryLabel, normalizeCategory } from '../../../utils/categories';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map(post => {
    const lastSlash = post.id.lastIndexOf('/');
    const slug = post.id.substring(0, lastSlash);
    const lang = post.id.substring(lastSlash + 1);

    return {
      params: { lang, slug },
      props: { post },
    };
  });
}

const { lang, slug } = Astro.params;
const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');
const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherPost = allPosts.find(p => p.id === `${slug}/${otherLang}`);
const otherVersionHref = otherPost ? `/${otherLang}/blog/${otherPost.id.split('/')[0]}` : null;

const sameLangPosts = allPosts
  .filter(p => p.id.endsWith(`/${lang}`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(p => ({ ...p, slug: p.id.split('/')[0] }));
const currentIndex = sameLangPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sameLangPosts.length - 1 ? sameLangPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sameLangPosts[currentIndex - 1] : null;

const readTime = calculateReadTime(post.body);

const formattedDate = new Intl.DateTimeFormat(lang === 'zh' ? 'zh-TW' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.date);

const otherLangLabel = lang === 'zh' ? 'English' : '中文';
const primaryCategory = normalizeCategory(post.data.categories[0] || '') ?? null;

function getSeriesMeta(slug: string, lang: string) {
  if (/^ai-agentic-workflow-series-\d+$/.test(slug)) {
    return { key: 'ai-agentic-workflow', label: lang === 'zh' ? 'AI 代理工作流系列' : 'AI Agentic Workflow Series' };
  }
  if (/^build-mcp-server-part-\d+$/.test(slug)) {
    return { key: 'build-mcp-server', label: lang === 'zh' ? '自主建造 MCP Server 系列' : 'Build Your Own MCP Server' };
  }
  if (/^building-ai-skills-series-part-\d+$/.test(slug)) {
    return { key: 'building-ai-skills', label: lang === 'zh' ? '打造 AI Skill 系列' : 'Building AI Skills Series' };
  }
  if (/^mcp-engineering-deep-dive-\d+$/.test(slug)) {
    return { key: 'mcp-engineering-deep-dive', label: lang === 'zh' ? 'MCP 工程深化系列' : 'MCP Engineering Deep Dive' };
  }
  return null;
}

const seriesMeta = getSeriesMeta(slug!, lang!);
const seriesPosts = seriesMeta
  ? sameLangPosts.filter(p => getSeriesMeta(p.slug, lang!)?.key === seriesMeta.key)
  : [];
const currentSeriesIndex = seriesPosts.findIndex(p => p.id === post.id);
---

<Base title={`${post.data.title} — danielcanfly`} description={post.data.description} lang={lang!}>
  <Header currentLang={lang} />

  <article class="post-article">
    <div class="container">
      <header class="post-header animate-in">
        <a href={`/${lang}/blog`} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          {lang === 'zh' ? '返回部落格' : 'Back to Blog'}
        </a>

        <div class="post-meta">
          <span class:list={['tag', primaryCategory ? `tag-${primaryCategory}` : undefined]}>
            {getCategoryLabel(post.data.categories[0] || '', lang as 'en' | 'zh')}
          </span>
          <span class="post-date muted">{formattedDate}</span>
          <span class="post-readtime muted">{readTime} min read</span>
        </div>

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>

        {seriesMeta && seriesPosts.length > 1 && (
          <details class="series-nav">
            <summary class="series-nav-trigger">
              <span class="series-nav-kicker">{lang === 'zh' ? '系列導覽' : 'Series guide'}</span>
              <span class="series-nav-title">{seriesMeta.label}</span>
              <span class="series-nav-count">{currentSeriesIndex + 1}/{seriesPosts.length}</span>
            </summary>
            <div class="series-nav-panel">
              {seriesPosts.map((item, index) => (
                <a href={`/${lang}/blog/${item.slug}`} class:list={['series-nav-item', { active: item.id === post.id }] }>
                  <span class="series-nav-index">{index + 1}</span>
                  <span class="series-nav-item-title">{item.data.title}</span>
                </a>
              ))}
            </div>
          </details>
        )}

        {otherVersionHref && (
          <div class="lang-switch">
            <span class="muted">{lang === 'zh' ? '閱讀版本：' : 'Read in:'}</span>
            <a href={otherVersionHref} class="lang-btn">{otherLangLabel}</a>
          </div>
        )}
      </header>

      {prevPost && (
        <a href={`/${lang}/blog/${prevPost.slug}`} class="side-nav side-nav-left" aria-label={lang === 'zh' ? '上一篇' : 'Previous post'}>
          <span class="side-nav-chip">
            <span class="side-nav-arrow">←</span>
            <span class="side-nav-label">{lang === 'zh' ? '上一篇' : 'Previous'}</span>
          </span>
        </a>
      )}
      {nextPost && (
        <a href={`/${lang}/blog/${nextPost.slug}`} class="side-nav side-nav-right" aria-label={lang === 'zh' ? '下一篇' : 'Next post'}>
          <span class="side-nav-chip">
            <span class="side-nav-label">{lang === 'zh' ? '下一篇' : 'Next'}</span>
            <span class="side-nav-arrow">→</span>
          </span>
        </a>
      )}

      <div class="post-content animate-in animate-delay-1">
        <Content />
      </div>

      <footer class="post-footer animate-in animate-delay-2">
        <div class="post-tags">
          {post.data.categories.map(cat => {
            const normalized = normalizeCategory(cat);
            return (
              <span class:list={['tag', normalized ? `tag-${normalized}` : undefined]}>
                {getCategoryLabel(cat, lang as 'en' | 'zh')}
              </span>
            );
          })}
        </div>
        <div class="post-share">
          <a
            href={`https://x.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
          >
            {lang === 'zh' ? '分享到 X' : 'Share on X'}
          </a>
        </div>
      </footer>
    </div>
  </article>

  <Footer />
</Base>

<style>
  .post-article {
    padding: var(--space-8) 0 var(--space-10);
  }

  .post-header {
    max-width: 800px;
    margin: 0 auto var(--space-8);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .post-date,
  .post-readtime {
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-3);
    letter-spacing: -0.02em;
  }

  .post-subtitle {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--space-3);
    max-width: 100%;
    font-style: italic;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    max-width: 100%;
  }

  .series-nav {
    margin-bottom: var(--space-4);
  }

  .series-nav-trigger {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4px 12px;
    align-items: center;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: 18px;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    cursor: pointer;
  }

  .series-nav-trigger::-webkit-details-marker {
    display: none;
  }

  .series-nav-kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .series-nav-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text);
  }

  .series-nav-count {
    grid-row: span 2;
    align-self: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .series-nav-panel {
    margin-top: 10px;
    max-height: 320px;
    overflow: auto;
    padding: 8px;
    border: 1px solid var(--color-border);
    border-radius: 18px;
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    display: grid;
    gap: 8px;
  }

  .series-nav-item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: start;
    padding: 10px 12px;
    border-radius: 14px;
    color: var(--color-muted);
    text-decoration: none;
    border: 1px solid transparent;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
  }

  .series-nav-item:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
    transform: translateY(-1px);
  }

  .series-nav-item.active {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 25%, var(--color-border));
  }

  .series-nav-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .series-nav-item-title {
    line-height: 1.45;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
  }

  .lang-btn {
    padding: 4px 10px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    transition: all var(--transition-fast);
  }

  .lang-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .post-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .side-nav {
    position: fixed;
    top: 0;
    bottom: 0;
    width: 72px;
    z-index: 30;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .side-nav-left {
    left: 0;
    justify-content: flex-start;
  }

  .side-nav-right {
    right: 0;
    justify-content: flex-end;
  }

  .side-nav-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 12px;
    border-radius: 999px;
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    backdrop-filter: blur(10px);
    border: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    opacity: 0;
    transform: translateX(0) scale(0.96);
    transition: opacity var(--transition-fast), transform var(--transition-fast), color var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast);
    pointer-events: none;
  }

  .side-nav-left .side-nav-chip {
    margin-left: 10px;
    transform: translateX(-8px) scale(0.96);
  }

  .side-nav-right .side-nav-chip {
    margin-right: 10px;
    transform: translateX(8px) scale(0.96);
  }

  .side-nav:hover .side-nav-chip {
    opacity: 1;
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
    transform: translateX(0) scale(1);
  }

  .side-nav-arrow {
    font-size: 1rem;
    line-height: 1;
  }

  .side-nav-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
    margin: var(--space-6) 0 var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .post-content :global(h3) {
    font-size: 1.375rem;
    margin: var(--space-4) 0 var(--space-2);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-3);
    max-width: 100%;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: var(--space-3) 0;
    padding-left: var(--space-4);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-1);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-3);
    margin: var(--space-4) 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: var(--space-5) 0;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    display: block;
    overflow-x: auto;
    overflow-y: auto;
    max-height: 520px;
  }

  .post-content :global(thead) {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
  }

  .post-content :global(th),
  .post-content :global(td) {
    min-width: 160px;
    padding: 14px 18px;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--color-border);
    line-height: 1.7;
  }

  .post-content :global(th + th),
  .post-content :global(td + td) {
    border-left: 1px solid var(--color-border);
  }

  .post-content :global(th) {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }

  .post-content :global(td) {
    color: var(--color-text);
  }

  .post-content :global(tbody tr:nth-child(even)) {
    background: color-mix(in srgb, var(--color-surface) 92%, black);
  }

  .post-content :global(tbody tr:hover) {
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-surface));
  }

  .post-content :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .post-content :global(img) {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    margin: var(--space-2) 0 var(--space-3);
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-footer {
    max-width: 680px;
    margin: var(--space-8) auto 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .share-btn {
    padding: 8px 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text);
    transition: all var(--transition-fast);
  }

  .share-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .post-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .side-nav {
      display: none;
    }
  }
</style>
