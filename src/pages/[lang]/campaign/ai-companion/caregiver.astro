---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}
const { lang } = Astro.params;
import SurveyLayout from '../../../../layouts/SurveyLayout.astro';

// B1-B34 questions data
const questions = [
  // B-1 基本情況
  {
    code: 'B1', section: 'B-1 基本情況',
    text: '您和這位長輩的關係是？',
    type: 'radio',
    options: ['子女', '孫子女', '兄弟姊妹', '其他親屬', '朋友／其他照顧者']
  },
  {
    code: 'B2', text: '您和這位長輩目前的居住關係是？',
    type: 'radio',
    options: ['同住', '不同住但同一棟／同一社區', '不同住但同一城市', '不同城市', '不同國家']
  },
  {
    code: 'B3', text: '這位長輩目前主要和誰一起住？',
    type: 'radio',
    options: ['自己一個人住', '和配偶住', '和子女住', '和看護／照顧者住', '其他']
  },
  {
    code: 'B4', text: '您平常覺得這位長輩使用手機的能力比較接近哪一種？',
    type: 'radio',
    options: ['幾乎不用智慧型手機', '主要接電話', '會看 LINE 或訊息', '會語音／視訊', '會自己操作 app']
  },
  // B-2 痛點強度與照顧壓力
  {
    code: 'B5', section: 'B-2 痛點強度與照顧壓力',
    text: '您平均多久會主動確認一次這位長輩的狀況？',
    type: 'radio',
    options: ['幾乎每天', '一週好幾次', '一週一次', '一個月幾次', '很少']
  },
  {
    code: 'B6', text: '您目前最常用哪種方式確認這位長輩的狀況？',
    type: 'checkbox',
    options: ['打電話', 'LINE 文字', 'LINE 語音／視訊', '問其他家人', '看護／照服員回報', '長輩主動聯絡我', '其實沒有固定方式', '其他']
  },
  {
    code: 'B7', text: '以下哪些情況最讓您擔心？',
    type: 'checkbox',
    options: ['長輩太孤單／沒有人說話', '心情變差但沒人知道', '忘東忘西變嚴重', '跌倒／身體異常', '沒接電話不知道怎麼了', '作息突然變亂', '我沒有時間常常關心', '其他']
  },
  {
    code: 'B8', text: '您目前對這位長輩的擔心程度大概是？',
    type: 'slider',
    options: Array.from({ length: 11 }, (_, i) => String(i)),
    scaleLabels: ['幾乎不擔心', '非常擔心']
  },
  {
    code: 'B9', text: '這份擔心多久會影響您的情緒、注意力或生活安排？',
    type: 'radio',
    options: ['幾乎每天', '一週好幾次', '一週一兩次', '很少', '幾乎沒有']
  },
  // B-3 現有替代方案
  {
    code: 'B10', section: 'B-3 現有替代方案',
    text: '您目前有沒有用過以下工具或管道來幫助自己關心長輩？（每列請選一項）',
    type: 'matrix',
    rows: ['固定電話問安', '家庭群組回報', '視訊', '智慧手錶／緊急求助裝置', '遠距監測／感測設備', '請親友鄰居幫忙看', '看護／照服員', '其他 app／工具'],
    cols: ['有在用', '用過但停了', '沒用過']
  },
  {
    code: 'B11', text: '除了上面這些工具或管道，您現在是否有固定的關心流程或分工方式？',
    type: 'checkbox',
    options: ['有固定時段主動聯絡', '和其他家人輪流關心', '會和長輩約定主動報平安', '如果一段時間聯絡不上，會找其他人協助確認', '會請住得近的親友／鄰居協助留意', '會依長輩最近身體或情緒狀況調整關心頻率', '沒有特別固定流程', '其他']
  },
  {
    code: 'B12', text: '您對現有方式最不滿意的地方是？',
    type: 'checkbox',
    options: ['太花時間', '資訊不連續', '太像監視', '只能事後才知道，無法提前發現', '家人之間不好協調', '成本太高', '沒有真正減少我的焦慮', '其他']
  },
  // B-4 對 AI 夥伴概念的反應
  {
    code: 'B13', section: '產品說明',
    text: '想像一下：如果有一個語音 AI 夥伴，會每天主動致電問候長輩、陪長輩聊幾句、主動記得長輩說過的事並在適當時拿出來聊，也會貼心提醒長輩該吃藥、該運動。身為家屬，您每天會收到長輩的情緒分數與互動摘要；當長輩說出「感覺生活好沒意義」等可能代表情緒低落的關鍵句時，系統會立即發出警報通知您。您第一反應比較接近哪一個？',
    type: 'radio',
    options: ['很有興趣', '有點興趣', '普通', '不太有興趣', '完全沒興趣']
  },
  {
    code: 'B14', section: 'B-4 對 AI 夥伴概念的反應',
    text: '如果只能選一個，您最在意這個服務帶來的哪個價值？',
    type: 'radio',
    options: ['長輩比較不孤單', '我每天比較放心', '我能更早知道異常', '我不用一直自己打電話', '家人之間更容易分工']
  },
  {
    code: 'B15', text: '如果只能選兩個，您最希望這個服務做到哪兩件事？',
    type: 'checkbox',
    maxSelect: 2,
    options: ['每天幫忙問安', '長輩能有人聊幾句', '提供心情／狀態趨勢', '異常早知道', '沒有 check-in 時提醒我', '幫助家人協作', '其他']
  },
  // B-5 家屬想要的輸出格式
  {
    code: 'B16', section: 'B-5 家屬想要的輸出格式',
    text: '如果只能選一種，您最想收到哪一種資訊？',
    type: 'radio',
    options: ['今天是否完成 check-in + 綠黃紅狀態', '情緒／互動趨勢儀表板', '2-3 句短摘要', '狀態+趨勢+異常提醒', '更完整的內容摘要']
  },
  {
    code: 'B17', text: '哪種提醒方式對您最有價值？',
    type: 'checkbox',
    options: ['今天完全沒有 check-in', '情緒明顯比平常低', '作息突然異常', '提到身體不舒服', '提到孤單／很低落', '互動內容看起來怪怪的', '不需要提醒我自己有空看就好']
  },
  {
    code: 'B18', text: '對您來說，以下哪一種最不能接受？',
    type: 'radio',
    options: ['完全沒有提醒', '提醒太多', '提醒太模糊不知道要不要處理', '看不到趨勢', '摘要太少', '摘要太多']
  },
  {
    code: 'B19', text: '您比較偏好哪種方式？',
    type: 'radio',
    options: ['平常只看簡單狀態異常時才多給一些資訊', '平常每天看短摘要就好', '平常看趨勢有異常再看摘要', '想看得越完整越好', '不確定']
  },
  // B-6 分享邊界與長輩控制權
  {
    code: 'B20', section: 'B-6 分享邊界與長輩控制權',
    text: '哪些內容您覺得「不一定需要知道」？',
    type: 'checkbox',
    options: ['長輩所有情緒細節', '長輩對家人的抱怨', '金錢話題', '私人生活', '與其他人的私下談話', '其實我都想知道', '其他']
  },
  {
    code: 'B21', text: '如果長輩可以自己決定要分享到什麼程度，您是否可以接受？',
    type: 'radio',
    options: ['很能接受', '能接受', '普通', '不太能接受', '不能接受']
  },
  {
    code: 'B22', text: '您覺得最合理的做法是？',
    type: 'radio',
    options: ['平常只給我大致狀態異常才多一點資訊', '平常就給我短摘要', '平常給我趨勢必要時再看摘要', '我希望看得更完整', '不確定']
  },
  // B-7 採用、付費與價格
  {
    code: 'B23', section: 'B-7 採用、付費與價格',
    text: '如果這個服務能讓您更早知道異常、平常也能比較放心，您願意試用嗎？',
    type: 'radio',
    options: ['很願意', '願意', '看情況', '不太願意', '完全不願意']
  },
  {
    code: 'B24', text: '若試用後覺得有幫助，您最可能願意為哪個價值付費？',
    type: 'checkbox',
    options: ['每天有人幫忙 check-in', '異常早知道', '心情／狀態趨勢', '長輩比較不孤單', '我比較不用一直自己打電話', '家人之間更好分工', '其他']
  },
  {
    code: 'B25', text: '對您來說，以下哪個月費最有可能考慮？',
    type: 'radio',
    options: ['NT$149 以下', 'NT$150-299', 'NT$300-499', 'NT$500-799', 'NT$800 以上', '完全不會考慮付費']
  },
  {
    code: 'B26', text: '哪個價格會讓您覺得「太便宜，反而有點不放心」？',
    type: 'radio',
    options: ['NT$149 以下', 'NT$150-299', 'NT$300-499', 'NT$500-799', 'NT$800 以上', '沒有這種感覺']
  },
  {
    code: 'B27', text: '哪個價格會讓您覺得「開始有點貴，但還可能考慮」？',
    type: 'radio',
    options: ['NT$149 以下', 'NT$150-299', 'NT$300-499', 'NT$500-799', 'NT$800 以上']
  },
  {
    code: 'B28', text: '哪個價格會讓您覺得「太貴，不會考慮」？',
    type: 'radio',
    options: ['NT$149 以下', 'NT$150-299', 'NT$300-499', 'NT$500-799', 'NT$800 以上']
  },
  {
    code: 'B29', text: '如果價格一樣，您更願意為哪一種買單？',
    type: 'radio',
    options: ['陪伴聊天為主', '問安+短摘要', '問安+異常提醒', '問安+短摘要+異常提醒', '我不會買']
  },
  // B-8 多照顧者協作與權限
  {
    code: 'B30', section: 'B-8 多照顧者協作與權限',
    text: '平常是否只有您一個人主要在關心這位長輩？',
    type: 'radio',
    options: ['幾乎是我一個人', '主要是我但也有其他人', '有兩三個人一起', '很多人都會管', '不一定']
  },
  {
    code: 'B31', text: '如果有這個服務，您覺得最合理的權限方式是？',
    type: 'radio',
    options: ['只給一位主要家屬看', '一位主要家屬+其他人只看簡單狀態', '所有家人都看一樣內容', '由長輩自己設定', '不確定']
  },
  {
    code: 'B32', text: '如果系統偵測到異常，第一個應該通知誰？',
    type: 'radio',
    options: ['主要家屬', '最近住得近的人', '所有家人', '先提醒長輩本人', '視情況而定']
  },
  // B-9 開放題
  {
    code: 'B33', section: 'B-9 開放題',
    text: '如果這個 AI 夥伴真的要讓您願意持續使用，最重要的一件事是什麼？（非必填）',
    type: 'textarea'
  },
  {
    code: 'B34', text: '您最怕這個 AI 夥伴做不好的地方是什麼？（非必填）',
    type: 'textarea'
  },
];

function renderQuestion(q: typeof questions[0], qIndex: number) {
  const isRequired = q.type !== 'textarea';
  const reqAttr = isRequired ? 'required' : '';
  const name = q.code;

  if (q.type === 'radio') {
    const otherIdx = q.options!.indexOf('其他');
    const revealId = `other-reveal-${q.code}`;
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <ul class="options-list">
      ${q.options!.map((opt) => `
      <li>
        <label class="option-label">
          <input type="radio" name="${name}" value="${opt}" ${reqAttr} />
          <span>${opt}</span>
        </label>
        ${opt === '其他' ? `<div class="other-reveal" id="${revealId}"><input type="text" class="other-text-input" name="${name}_other" placeholder="請說明（選填）" autocomplete="off" /></div>` : ''}
      </li>`).join('')}
    </ul>
  </div>`;
  }

  if (q.type === 'checkbox') {
    const revealId = `other-reveal-${q.code}`;
    return `
  <div class="question-block" ${q.maxSelect ? `data-max-select="${q.maxSelect}"` : ''}>
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <ul class="options-list">
      ${q.options!.map((opt) => `
      <li>
        <label class="option-label">
          <input type="checkbox" name="${name}" value="${opt}" />
          <span>${opt}</span>
        </label>
        ${opt === '其他' ? `<div class="other-reveal" id="${revealId}"><input type="text" class="other-text-input" name="${name}_other" placeholder="請說明（選填）" autocomplete="off" /></div>` : ''}
      </li>`).join('')}
    </ul>
  </div>`;
  }

  if (q.type === 'scale') {
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <div class="scale-input">
      <div class="scale-wrapper">${q.scaleLabels![0]}</div>
      ${q.options!.map((opt) => `
      <label>
        <input type="radio" name="${name}" value="${opt}" ${reqAttr} />
        ${opt}
      </label>`).join('')}
      <div class="scale-wrapper">${q.scaleLabels![1]}</div>
    </div>
  </div>`;
  }

  if (q.type === 'slider') {
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <div class="slider-block">
      <div class="slider-value" id="${name}-value">5</div>
      <div class="slider-track-shell">
        <div class="slider-ticks" aria-hidden="true">${q.options!.map(() => '<span></span>').join('')}</div>
        <input type="range" name="${name}" min="0" max="10" step="1" value="5" class="range-input" data-range-output="${name}-value" ${reqAttr} />
      </div>
      <div class="slider-labels">
        <span>${q.scaleLabels![0]}</span>
        <span>${q.scaleLabels![1]}</span>
      </div>
    </div>
  </div>`;
  }

  if (q.type === 'textarea') {
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <textarea class="text-input" name="${name}" rows="4" placeholder="請填寫（選填）"></textarea>
  </div>`;
  }

  if (q.type === 'matrix') {
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <div class="matrix-table-wrap">
      <table class="matrix-table">
        <colgroup>
          <col class="matrix-col-label" />
          ${q.cols!.map(() => `<col class="matrix-col-option" />`).join('')}
        </colgroup>
        <thead>
          <tr>
            <th class="matrix-corner"></th>
            ${q.cols!.map(c => `<th>${c}</th>`).join('')}
          </tr>
        </thead>
        <tbody>
          ${q.rows!.map((row, rowIndex) => `
          <tr>
            <td class="row-label">${row}</td>
            ${q.cols!.map(col => `
            <td data-col-label="${col}">
              <label class="matrix-choice">
                <input type="radio" name="${name}__${rowIndex}" value="${row}|${col}" />
                <span class="matrix-choice-label">${col}</span>
              </label>
            </td>`).join('')}
          </tr>`).join('')}
        </tbody>
      </table>
    </div>
  </div>`;
  }

  return '';
}
---

<SurveyLayout title="市場調查｜家屬版" description="請根據您的實際情況填寫">
  <form id="survey-form">
    {questions.map((q, i) => (
      <Fragment set:html={renderQuestion(q, i)} />
    ))}

    <hr class="section-divider" />

    <div class="question-block">
      <div class="section-label">聯絡與後續參與意願</div>
      <div class="question-text">感謝您完成問卷。<br />如果您願意留下聯絡方式，後續有機會：</div>
      <ul class="contact-list">
        <li>優先參與 3 個月免費試用（價值 $900 元）</li>
        <li>接受 15–30 分鐘深度訪談邀請</li>
        <li>參與後續產品測試或研究回訪</li>
      </ul>
      <div class="contact-note">
        這一部分完全自願。即使不留下聯絡資訊，也不影響本次問卷完成。<br />
        我們只會將您提供的聯絡資訊用於本研究，不會任意對外公開。
      </div>
      <div class="question-text">我是否願意留下聯絡方式？</div>
      <ul class="options-list">
        <li><label class="option-label"><input type="radio" name="contact_willing" value="願意" /> <span>願意（已閱讀並同意 <a href={`/${lang}/privacy/`} target="_blank" onclick="event.stopPropagation()" style="color:var(--accent);text-decoration:underline">隱私權聲明</a>）</span></label></li>
        <li><label class="option-label"><input type="radio" name="contact_willing" value="暫時不願意" /> <span>暫時不願意</span></label></li>
      </ul>
    </div>

    <div id="contact-conditional" class="contact-conditional" style="display:none">
      <div class="question-code">選填</div>
      <div class="question-text">聯絡方式（至少填寫一格）</div>
      <div class="contact-row"><span class="contact-row-label">電子郵件</span><input type="email" name="contact_email" class="text-input" placeholder="電子郵件，例如：example@email.com" /></div>
      <div class="contact-row"><span class="contact-row-label">LINE</span><input type="text" name="contact_line" class="text-input" placeholder="LINE ID" /></div>
      <ul class="options-list">
        <li><label class="option-label"><input type="checkbox" name="consent_followup" value="我願意接受與本研究相關的後續聯絡，包括免費試用邀請與產品優先測試通知" /> <span>我願意接受與本研究相關的後續聯絡，包括免費試用邀請與產品優先測試通知</span></label></li>
        <li><label class="option-label"><input type="checkbox" name="consent_interview" value="我願意接受後續深度訪談邀請（約 15–30 分鐘）" /> <span>我願意接受後續深度訪談邀請（約 15–30 分鐘）</span></label></li>
      </ul>
    </div>

    <button type="submit" class="submit-btn" id="submit-btn">送出</button>
  </form>
  <div id="error-container"></div>
</SurveyLayout>

<style>
  .section-label {
    font-size: 0.75rem;
    color: #4a7c59;
    font-weight: 600;
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }
  :global(.slider-block) {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 14px;
    margin-top: 10px;
    width: 100%;
    max-width: 100%;
  }
  :global(.slider-value) {
    justify-self: center;
    min-width: 52px;
    padding: 8px 14px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 14%, var(--bg-page));
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.05rem;
    text-align: center;
  }
  :global(.slider-track-shell) {
    position: relative;
    width: 100%;
    padding: 8px 0;
  }
  :global(.slider-track-shell::before) {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    top: 50%;
    height: 8px;
    transform: translateY(-50%);
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 28%, var(--bg-page));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 24%, transparent);
  }
  :global(.slider-ticks) {
    position: absolute;
    left: 12px;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    align-items: center;
    pointer-events: none;
    z-index: 1;
  }
  :global(.slider-ticks span) {
    width: 2px;
    height: 10px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 56%, transparent);
  }
  :global(.range-input) {
    position: relative;
    z-index: 2;
    display: block;
    width: 100%;
    min-width: 100%;
    margin: 0;
    background: transparent;
    accent-color: var(--accent);
    -webkit-appearance: none;
    appearance: none;
  }
  :global(.range-input::-webkit-slider-thumb) {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 88%, #fff 12%);
    border: 2px solid #fff;
    box-shadow: 0 4px 12px rgba(100, 76, 255, 0.35);
    margin-top: -8px;
    cursor: grab;
  }
  :global(.range-input::-webkit-slider-thumb:active) {
    cursor: grabbing;
  }
  :global(.range-input::-webkit-slider-runnable-track) {
    height: 8px;
    border-radius: 999px;
    background: transparent;
  }
  :global(.range-input::-moz-range-track) {
    height: 8px;
    border-radius: 999px;
    background: transparent;
  }
  :global(.range-input::-moz-range-thumb) {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 88%, #fff 12%);
    border: 2px solid #fff;
    box-shadow: 0 4px 12px rgba(100, 76, 255, 0.35);
    cursor: grab;
  }
  :global(.range-input::-moz-range-thumb:active) {
    cursor: grabbing;
  }
  :global(.slider-labels) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    font-size: 0.92rem;
    color: var(--text-secondary);
  }
  :global(.slider-labels span:last-child) {
    text-align: right;
  }
  :global(.matrix-table-wrap) {
    overflow-x: visible;
    width: 100%;
    margin-top: 12px;
    border: 1px solid color-mix(in srgb, var(--border-color) 88%, transparent);
    border-radius: 16px;
    background: color-mix(in srgb, var(--bg-page) 60%, transparent);
    padding: 4px;
  }
  :global(.matrix-table) {
    width: 100%;
    min-width: 0;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.98rem;
    table-layout: fixed;
  }
  :global(.matrix-table th), :global(.matrix-table td) {
    padding: 16px 14px;
    text-align: center;
    vertical-align: middle;
    border-bottom: 1px solid color-mix(in srgb, var(--border-color) 84%, transparent);
    background: transparent;
  }
  :global(.matrix-table th) {
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-weight: 700;
    white-space: nowrap;
    background: color-mix(in srgb, var(--bg-card) 74%, var(--bg-page));
  }
  :global(.matrix-table .matrix-col-label) {
    width: 46%;
  }
  :global(.matrix-table .matrix-col-option) {
    width: 18%;
  }
  :global(.matrix-table .matrix-corner) {
    text-align: left;
  }
  :global(.matrix-table .row-label) {
    text-align: left;
    font-weight: 500;
    padding: 18px 18px 18px 20px;
    color: var(--text-primary);
    line-height: 1.7;
    white-space: normal;
    word-break: break-word;
    background: color-mix(in srgb, var(--bg-card) 58%, var(--bg-page));
  }
  :global(.matrix-table tbody td[data-col-label]) {
    padding: 0;
  }
  :global(.matrix-table tr:last-child td) {
    border-bottom: none;
  }
  :global(.matrix-choice) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    width: 100%;
    min-height: 44px;
    padding: 10px 0;
    box-sizing: border-box;
    cursor: pointer;
  }
  :global(.matrix-choice-label) {
    display: none;
  }
  :global(.matrix-table input[type="checkbox"]),
  :global(.matrix-table input[type="radio"]) {
    accent-color: var(--accent);
    width: 20px;
    height: 20px;
  }
  :global(.matrix-table td:has(input:checked)) {
    background: color-mix(in srgb, var(--accent) 14%, var(--bg-page));
  }
  :global(.matrix-table tbody td) {
    cursor: pointer;
  }
  :global(.matrix-table tbody td:hover) {
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-page));
  }
  @media (max-width: 860px) {
    :global(.matrix-table-wrap) {
      overflow-x: visible;
      border: none;
      background: transparent;
      padding: 0;
    }
    :global(.matrix-table),
    :global(.matrix-table thead),
    :global(.matrix-table tbody),
    :global(.matrix-table tr),
    :global(.matrix-table th),
    :global(.matrix-table td) {
      display: block;
      width: 100%;
    }
    :global(.matrix-table) {
      min-width: 0;
      border-spacing: 0;
    }
    :global(.matrix-table thead) {
      display: none;
    }
    :global(.matrix-table tr) {
      margin-bottom: 14px;
      border: 1px solid color-mix(in srgb, var(--border-color) 88%, transparent);
      border-radius: 14px;
      background: color-mix(in srgb, var(--bg-card) 72%, var(--bg-page));
      overflow: hidden;
    }
    :global(.matrix-table tr:last-child) {
      margin-bottom: 0;
    }
    :global(.matrix-table .row-label) {
      width: 100%;
      min-width: 0;
      padding: 16px 16px 10px;
      border-bottom: 1px solid color-mix(in srgb, var(--border-color) 84%, transparent);
      background: transparent;
      font-size: 1rem;
      line-height: 1.6;
    }
    :global(.matrix-table td) {
      padding: 0;
      border-bottom: none;
      background: transparent;
    }
    :global(.matrix-table td:has(input:checked)) {
      background: transparent;
    }
    :global(.matrix-choice) {
      justify-content: flex-start;
      gap: 12px;
      min-height: 0;
      padding: 14px 16px;
      border-bottom: 1px solid color-mix(in srgb, var(--border-color) 76%, transparent);
    }
    :global(.matrix-table tr td:last-child .matrix-choice) {
      border-bottom: none;
    }
    :global(.matrix-choice-label) {
      display: block;
      font-size: 0.98rem;
      color: var(--text-primary);
      line-height: 1.5;
    }
    :global(.matrix-choice input[type="radio"]) {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
    }
    :global(.matrix-choice:has(input:checked)) {
      background: color-mix(in srgb, var(--accent) 12%, var(--bg-page));
    }
  }
  .contact-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .contact-row:last-of-type {
    margin-bottom: 18px;
  }
  .contact-row-label {
    min-width: 78px;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    flex-shrink: 0;
  }
  .contact-row .text-input {
    flex: 1;
    margin-bottom: 0 !important;
    min-height: 46px;
    height: 46px;
    padding: 10px 14px;
    font-size: 0.98rem;
    line-height: 1.3;
    border-radius: 14px;
    resize: none;
  }
  .contact-row .text-input::placeholder {
    font-size: 0.98rem;
    color: var(--text-muted);
  }
  :global(.option-label.option-disabled) {
    opacity: 0.48;
    cursor: not-allowed;
  }
  :global(.other-reveal) {
    display: none;
    margin: 8px 0 4px 32px;
  }
  :global(.other-reveal.visible) {
    display: block;
  }
  :global(.other-text-input) {
    width: 100%;
    max-width: 100%;
    padding: 10px 14px;
    font-size: 0.95rem;
    border: 1.5px solid color-mix(in srgb, var(--border-color) 70%, transparent);
    border-radius: 12px;
    background: color-mix(in srgb, var(--bg-card) 50%, var(--bg-page));
    color: var(--text-primary);
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  @media (max-width: 480px) {
    :global(.other-reveal) {
      margin-left: 0;
    }
  }
  :global(.other-text-input::placeholder) {
    color: var(--text-muted);
  }
  :global(.other-text-input:focus) {
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 14%, transparent);
  }
</style>

<script>
  const form = document.getElementById('survey-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorContainer = document.getElementById('error-container') as HTMLDivElement;
  const SESSION_KEY = 'caregiver_survey_draft';
  const safeSession = {
    get(key: string) {
      try {
        return sessionStorage.getItem(key);
      } catch {
        return null;
      }
    },
    set(key: string, value: string) {
      try {
        sessionStorage.setItem(key, value);
      } catch {
        // ignore storage failures in mobile/in-app/private browsing
      }
    },
    remove(key: string) {
      try {
        sessionStorage.removeItem(key);
      } catch {
        // ignore storage failures in mobile/in-app/private browsing
      }
    },
  };

  // ── URL ref param for invite-link tracking ──────────────────
  const urlParams = new URLSearchParams(window.location.search);
  const refParam = urlParams.get('ref') || '';

  // ── Draft persistence ────────────────────────────────────────
  function saveDraft() {
    const data: Record<string, string | string[]> = {};
    for (const [key, value] of new FormData(form)) {
      if (data[key] === undefined) {
        data[key] = String(value);
      } else if (Array.isArray(data[key])) {
        (data[key] as string[]).push(String(value));
      } else {
        data[key] = [data[key] as string, String(value)];
      }
    }
    safeSession.set(SESSION_KEY, JSON.stringify(data));
  }

  function restoreDraft() {
    const raw = safeSession.get(SESSION_KEY);
    if (!raw) return;
    try {
      const data: Record<string, string | string[]> = JSON.parse(raw);
      Object.entries(data).forEach(([key, value]) => {
        // text / textarea / email: use name-only selector
        const textField = form.querySelector(`[name="${key}"]:not([type="radio"]):not([type="checkbox"])`) as HTMLInputElement | null;
        if (textField) {
          textField.value = String(value);
          return;
        }
        // radio / checkbox
        if (Array.isArray(value)) {
          value.forEach((v) => {
            const field = form.querySelector(`[name="${key}"][value="${v}"]`) as HTMLInputElement | null;
            if (field) field.checked = true;
          });
        } else {
          const field = form.querySelector(`[name="${key}"][value="${value}"]`) as HTMLInputElement | null;
          if (field) field.checked = true;
        }
      });
      document.querySelectorAll('[data-range-output]').forEach((input) => {
        const out = document.getElementById(input.getAttribute('data-range-output') || '');
        if (out) out.textContent = (input as HTMLInputElement).value;
      });
      const willing = document.querySelector('input[name="contact_willing"]:checked')?.value;
      const contactConditional = document.getElementById('contact-conditional');
      if (contactConditional) {
        contactConditional.style.display = willing === '願意' ? 'block' : 'none';
      }
    } catch { /* ignore parse errors */ }
  }

  function clearDraft() {
    safeSession.remove(SESSION_KEY);
  }

  restoreDraft();

  // ── Other-reveal logic ──────────────────────────────────────
  function setupOtherReveal() {
    document.querySelectorAll('.question-block').forEach((block) => {
      const radios = block.querySelectorAll('input[type="radio"]');
      const checkboxes = block.querySelectorAll('input[type="checkbox"]');

      if (radios.length > 0) {
        // Find the reveal div inside this block
        const reveal = block.querySelector('.other-reveal');
        if (!reveal) return;
        const sync = () => {
          const checked = block.querySelector('input[type="radio"]:checked');
          reveal.classList.toggle('visible', checked?.value === '其他');
        };
        radios.forEach((r) => r.addEventListener('change', sync));
        sync(); // initial state
      } else if (checkboxes.length > 0) {
        const reveal = block.querySelector('.other-reveal');
        if (!reveal) return;
        const sync = () => {
          const otherCb = block.querySelector('input[value="其他"]');
          reveal.classList.toggle('visible', otherCb?.checked ?? false);
        };
        checkboxes.forEach((c) => c.addEventListener('change', sync));
        sync();
      }
    });
  }
  setupOtherReveal();

  let saveTimer: ReturnType<typeof setTimeout>;
  form.addEventListener('input', () => {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveDraft, 300);
  });


  function setupMaxSelectLimits() {
    const limitedBlocks = document.querySelectorAll('.question-block[data-max-select]');

    limitedBlocks.forEach((block) => {
      const max = Number(block.getAttribute('data-max-select') || '0');
      const boxes = Array.from(block.querySelectorAll('input[type="checkbox"]')) as HTMLInputElement[];
      if (!max || boxes.length === 0) return;

      const sync = () => {
        const checkedCount = boxes.filter((box) => box.checked).length;
        const reached = checkedCount >= max;

        boxes.forEach((box) => {
          const shouldDisable = reached && !box.checked;
          box.disabled = shouldDisable;
          box.closest('.option-label')?.classList.toggle('option-disabled', shouldDisable);
        });
      };

      boxes.forEach((box) => box.addEventListener('change', sync));
      sync();
    });
  }

  function validateMaxSelectLimits() {
    const limitedBlocks = Array.from(document.querySelectorAll('.question-block[data-max-select]'));

    for (const block of limitedBlocks) {
      const max = Number(block.getAttribute('data-max-select') || '0');
      const checkedCount = block.querySelectorAll('input[type="checkbox"]:checked').length;
      if (max && checkedCount > max) {
        block.classList.add('question-missing');
        block.scrollIntoView({ behavior: 'smooth', block: 'center' });
        errorContainer.innerHTML = `<div class="error-msg">這題最多只能選 ${max} 項</div>`;
        return false;
      }
    }

    return true;
  }

  setupMaxSelectLimits();

  function findQuestionBlock(questionCode: string) {
    const byName = document.querySelector(`.question-block input[name="${questionCode}"]`)?.closest('.question-block');
    if (byName) return byName;

    const byCode = Array.from(document.querySelectorAll('.question-block')).find((block) => {
      const codeEl = block.querySelector('.question-code');
      return codeEl?.textContent?.trim() === questionCode;
    });
    return byCode || null;
  }

  function focusMissingBlock(target: Element | null) {
    if (!target) return;
    target.classList.add('question-missing');
    const rect = target.getBoundingClientRect();
    const absoluteTop = window.scrollY + rect.top - 96;
    window.scrollTo({ top: Math.max(absoluteTop, 0), behavior: 'smooth' });
  }

  document.querySelectorAll('[data-range-output]').forEach((input) => {
    const outputId = input.getAttribute('data-range-output');
    const output = outputId ? document.getElementById(outputId) : null;
    if (!output) return;

    const sync = () => {
      output.textContent = input.value;
    };

    input.addEventListener('input', sync);
    sync();
  });

  // Contact conditional reveal
  const contactConditional = document.getElementById('contact-conditional');
  const contactWillingRadios = document.querySelectorAll('input[name="contact_willing"]');
  contactWillingRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      const willing = document.querySelector('input[name="contact_willing"]:checked')?.value;
      if (willing === '願意') {
        contactConditional.style.display = 'block';
        contactConditional.classList.add('revealed');
      } else {
        contactConditional.style.display = 'none';
        contactConditional.classList.remove('revealed');
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorContainer.innerHTML = '';
    document.querySelectorAll('.question-missing').forEach(el => el.classList.remove('question-missing'));

    if (!validateMaxSelectLimits()) {
      return;
    }

    const formData = new FormData(form);
    const answers: Record<string, string | string[]> = {};

    // Gather answers
    for (const [key, value] of formData.entries()) {
      const groupedKey = key.match(/^([A-Z]\d+)__\d+$/)?.[1] || key;
      if (answers[groupedKey] === undefined) {
        answers[groupedKey] = value;
      } else if (Array.isArray(answers[groupedKey])) {
        (answers[groupedKey] as string[]).push(value);
      } else {
        answers[groupedKey] = [answers[groupedKey] as string, value];
      }
    }

    // Validate required fields
    const requiredQuestions = [
      'B1','B2','B3','B4','B5','B6','B7','B8','B9',
      'B13','B14','B15','B16','B17','B18','B19',
      'B21','B22','B23','B25','B26','B27','B28','B29',
      'B30','B31','B32','contact_willing'
    ];
    const missing = requiredQuestions.filter(q => !answers[q]);
    if (missing.length > 0) {
      // Remove previous highlights
      document.querySelectorAll('.question-missing').forEach(el => el.classList.remove('question-missing'));

      // Scroll to first missing question
      const firstMissing = missing[0];
      const target = findQuestionBlock(firstMissing);
      focusMissingBlock(target);

      errorContainer.innerHTML = `<div class="error-msg">還有 ${missing.length} 題未填（請滑到紫色標記的題目）</div>`;
      return;
    }

    // Conditional validation: if contact_willing = 願意, need contact fields AND at least one consent checkbox
    const contactWilling = document.querySelector('input[name="contact_willing"]:checked')?.value;
    if (contactWilling === '願意') {
      const email = (document.querySelector('input[name="contact_email"]') as HTMLInputElement)?.value.trim();
      const line = (document.querySelector('input[name="contact_line"]') as HTMLInputElement)?.value.trim();
      const hasContact = !!(email || line);
      const consentFollowup = !!(document.querySelector('input[name="consent_followup"]:checked'));
      const consentInterview = !!(document.querySelector('input[name="consent_interview"]:checked'));
      const hasConsent = consentFollowup || consentInterview;

      if (!hasContact || !hasConsent) {
        const contactBlock = document.getElementById('contact-conditional');
        focusMissingBlock(contactBlock);
        if (!hasContact && !hasConsent) {
          errorContainer.innerHTML = `<div class="error-msg">請填寫聯絡方式（至少一項）並選擇後續聯絡意願（至少一項）</div>`;
        } else if (!hasContact) {
          errorContainer.innerHTML = `<div class="error-msg">請填寫電子郵件或 LINE（至少一項）</div>`;
        } else {
          errorContainer.innerHTML = `<div class="error-msg">請選擇後續聯絡意願（至少一項）</div>`;
        }
        return;
      }
    }

    submitBtn.disabled = true;
    submitBtn.textContent = '送出中…';

    try {
      const res = await fetch('/api/campaign/ai-companion-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          role: 'caregiver',
          familyId: refParam || undefined,
          answers,
          locale: 'zh',
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        throw new Error(data.error || '送出失敗');
      }
      // Store familyId and inviteLink
      safeSession.set('survey_familyId', data.familyId);
      safeSession.set('survey_inviteLink', data.inviteLink || '');
      safeSession.set('survey_role', 'caregiver');
      clearDraft();
      const lang = window.location.pathname.split('/').filter(Boolean)[0] || 'zh';
      const fullInvite = (data.inviteLink || '').startsWith('http')
        ? data.inviteLink
        : window.location.origin + (data.inviteLink || '');
      const contactParam = data.contactSubmitted ? '&contact=1' : '';
      window.location.href = `/${lang}/campaign/ai-companion/thank-you?role=caregiver&invite=${encodeURIComponent(fullInvite)}${contactParam}`;
    } catch (err: any) {
      errorContainer.innerHTML = `<div class="error-msg">送出失敗：${err.message}</div>`;
      submitBtn.disabled = false;
      submitBtn.textContent = '送出';
    }
  });
</script>
