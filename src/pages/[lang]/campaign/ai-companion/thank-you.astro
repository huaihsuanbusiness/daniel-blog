---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}
import SurveyLayout from '../../../../layouts/SurveyLayout.astro';
---

<SurveyLayout title="感謝填寫" description="">
  <div class="thankyou-block">

    <div class="big-check">✓</div>
    <h2>謝謝您的填寫！</h2>

    <!-- 填寫後的感謝語 -->
    <p id="caregiver-msg" class="thank-msg" style="display:none">
      感謝您分享這麼寶貴的意見。<br />
      您的回覆將幫助我們打造更適合長輩與家屬的 AI 陪伴服務。
    </p>
    <p id="elder-msg" class="thank-msg" style="display:none">
      感謝您撥冗填寫！<br />
      您的回覆對我們非常寶貴。
    </p>

    <!-- 單一分享容器：Prompt + 連結 + 按鈕 -->
    <div id="share-panel" class="share-panel" style="display:none">

      <!-- 邀請提示語（置換後的正確版本） -->
      <p id="elder-prompt" class="prompt-line" style="display:none">
        邀請您分享給家人或照顧者填寫
      </p>
      <p id="caregiver-prompt" class="prompt-line" style="display:none">
        邀請您分享給長輩填寫
      </p>

      <!-- 連結滿寬 -->
      <div class="link-block">
        <div class="share-link" id="share-link"></div>
      </div>

      <!-- 按鈕組：上下排列 -->
      <div class="btn-group">
        <button class="btn-copy" id="btn-copy">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          <span id="copy-label">複製</span>
        </button>
        <a class="btn-line" id="btn-line" href="#" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><g fill="none" fill-rule="evenodd"><path d="M12 0C5.373 0 0 4.974 0 11.116c0 3.497 1.748 6.614 4.467 8.436V24l4.088-2.242c1.092.304 2.246.467 3.445.467 6.627 0 12-4.975 12-11.116S18.627 0 12 0z" fill="#00B900"/><path d="M7.08 10.65c-.39 0-.7.34-.7.75v.35h1.27v1.04c0 .42-.31.75-.7.75-.38 0-.69-.33-.69-.75v-2.14zm1.41 2.57c-.23.27-.65.37-1.03.37-.27 0-.47-.08-.62-.21a.69.69 0 0 1-.23-.53c0-.23.09-.43.25-.58a.86.86 0 0 1 .6-.24c.38 0 .68.13.9.38.14.15.24.36.24.58 0 .13-.04.25-.11.33zm.57 1.19c-.08.12-.2.18-.36.18-.12 0-.2-.05-.28-.13-.11-.12-.18-.31-.18-.53 0-.36.21-.58.51-.58.15 0 .27.04.33.12.06.07.09.18.09.32v.15c0 .15 0 .26-.11.47zm.97.35c-.06.19-.17.29-.36.29-.1 0-.17-.02-.24-.07-.11-.09-.19-.25-.22-.45l.38-.07c.02.11.07.18.15.22.07.03.13.05.18.05.13 0 .2-.08.2-.23v-.13c-.05 0-.1 0-.15.01-.24.02-.37.09-.44.22a.56.56 0 0 0 .03.54c.08.11.22.17.42.17.17 0 .3-.05.39-.18.07-.1.1-.24.1-.39 0-.13-.03-.25-.1-.36zm1.15.38c-.08.12-.2.18-.36.18-.12 0-.2-.05-.28-.13-.11-.12-.18-.31-.18-.53 0-.36.21-.58.51-.58.15 0 .27.04.33.12.06.07.09.18.09.32v.15c0 .15 0 .26-.11.47z" fill="#FFF" fill-rule="nonzero"/><path d="M14.4 9.2c-.37 0-.68.1-.92.29-.24.19-.36.43-.36.72 0 .27.1.49.29.65.19.17.44.25.75.25.12 0 .23-.02.34-.05v-.4a1.35 1.35 0 0 1-.33.08c-.13.02-.23.03-.31.03-.25 0-.45-.07-.59-.2a.66.66 0 0 1-.2-.5c0-.21.08-.39.24-.52.16-.13.37-.2.65-.2.12 0 .23.01.34.04l-.05.44c-.1-.02-.19-.04-.28-.04-.12 0-.22.03-.3.1a.33.33 0 0 0-.12.26c0 .12.04.21.13.28.08.07.2.1.36.1.12 0 .24-.02.35-.07v.42c-.11.03-.22.05-.34.05-.3 0-.54-.08-.72-.23a.75.75 0 0 1-.27-.57c0-.3.12-.55.35-.74.23-.2.54-.29.91-.29.33 0 .59.07.78.21l-.28.37c-.08-.06-.19-.09-.31-.09-.17 0-.29.05-.38.16zm1.95 1.8c0 .35-.09.64-.26.86-.17.22-.4.34-.69.34-.3 0-.53-.12-.7-.35-.17-.23-.26-.52-.26-.86v-.67c0-.35.09-.63.26-.85.17-.22.4-.33.69-.33s.52.11.69.33c.17.22.26.5.26.85v.67zm-.46-.67c0-.24-.05-.42-.15-.55-.1-.13-.25-.19-.45-.19-.21 0-.36.06-.47.19a.76.76 0 0 0-.15.55v.67c0 .23.05.41.15.54.1.13.26.19.47.19.2 0 .35-.06.46-.19.1-.13.15-.31.15-.54v-.67z" fill="#FFF" fill-rule="nonzero"/><path d="M17.8 9.2c-.36 0-.66.1-.9.28a.93.93 0 0 0-.35.72c0 .27.1.49.3.65.19.17.44.25.74.25.22 0 .42-.04.59-.13l.08.4a1.5 1.5 0 0 1-.42.09c-.32 0-.58-.1-.77-.29a.91.91 0 0 1-.28-.67c0-.3.1-.55.3-.74.2-.2.46-.29.8-.29.29 0 .52.06.7.19l-.21.38a1.2 1.2 0 0 0-.52-.16c-.23 0-.4.05-.52.16-.12.11-.18.25-.18.43 0 .2.07.36.21.48.14.12.32.18.54.18.2 0 .37-.05.52-.14l.06.4c-.12.08-.27.13-.45.13-.3 0-.54-.09-.72-.26a.87.87 0 0 1-.26-.65c0-.28.1-.52.31-.71.21-.19.48-.29.83-.29.36 0 .64.09.84.26l-.25.36c-.08-.07-.2-.1-.34-.1-.18 0-.31.05-.4.16z" fill="#FFF" fill-rule="nonzero"/></g></svg>
          分享到LINE
        </a>
      </div>

      <!-- 提示文字 -->
      <p id="elder-hint" class="share-hint" style="display:none"></p>
      <p id="caregiver-hint" class="share-hint" style="display:none"></p>
    </div>

    <div class="back-row">
      <a href="https://www.danielcanfly.com/zh/blog/ai-companion-survey?category=business" class="btn-back">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        返回文章
      </a>
    </div>

  </div>
</SurveyLayout>

<style>
  .thankyou-block {
    text-align: center;
    padding: 48px 24px 40px;
    max-width: 520px;
    margin: 0 auto;
  }

  .big-check {
    font-size: 60px;
    line-height: 1;
    margin-bottom: 14px;
  }

  h2 {
    font-size: 1.45rem;
    margin-bottom: 10px;
    color: #fff;
    font-weight: 700;
  }

  .thank-msg {
    font-size: 0.92rem;
    color: #e8e8f0;
    line-height: 1.75;
    margin: 0 0 4px;
  }

  /* 單一分享容器 */
  .share-panel {
    margin-top: 28px;
    background: #f7f8ff;
    border: 1.5px solid #dde3ff;
    border-radius: 14px;
    padding: 18px 20px 14px;
    text-align: left;
  }

  .prompt-line {
    font-size: 0.88rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 12px;
    line-height: 1.5;
  }

  .link-block {
    flex: none;
    width: 100%;
  }
  .share-link {
    width: 100%;
    background: #fff;
    border: 1.5px solid #c5cae9;
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 0.78rem;
    font-family: 'SF Mono', 'Cascadia Code', monospace;
    color: #4f46e5;
    word-break: break-all;
    cursor: pointer;
    user-select: all;
    min-height: 40px;
    display: flex;
    align-items: center;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }
  .share-link:hover { border-color: #4f46e5; }

  .btn-group {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    margin-top: 8px;
  }

  .btn-copy {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 14px;
    height: 40px;
    background: #4f46e5;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    flex: 1;
    transition: background 0.15s;
  }
  .btn-copy:hover { background: #4338ca; }
  .btn-copy.copied { background: #16a34a; }

  .btn-line {
    display: flex;
    align-items: center;
    gap: 4px;
    height: 40px;
    padding: 0 14px;
    background: #00B900;
    color: #fff;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex: 1;
    transition: background 0.15s;
  }
  .btn-line:hover { background: #009100; }

  .share-hint {
    font-size: 0.78rem;
    color: #b0b0c8;
    margin: 8px 0 0;
    line-height: 1.5;
  }

  .back-row {
    margin-top: 28px;
    text-align: center;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 10px 22px;
    color: #fff;
    text-decoration: none;
    font-size: 0.88rem;
    border: 1.5px solid rgba(255,255,255,0.3);
    border-radius: 8px;
    transition: all 0.15s;
  }
  .btn-back:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.5);
  }
</style>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const role = urlParams.get('role') || sessionStorage.getItem('survey_role') || '';
  const inviteUrl = urlParams.get('invite') || '';

  const panel = document.getElementById('share-panel');
  const linkEl = document.getElementById('share-link');
  const btnCopy = document.getElementById('btn-copy');
  const copyLabel = document.getElementById('copy-label');
  const btnLine = document.getElementById('btn-line');

  if (role === 'caregiver') {
    document.getElementById('caregiver-msg').style.display = 'block';
    document.getElementById('caregiver-prompt').style.display = 'block';
    document.getElementById('caregiver-hint').style.display = 'block';
    if (inviteUrl) {
      panel.style.display = 'block';
      linkEl.textContent = inviteUrl;
    }
  } else if (role === 'elder') {
    document.getElementById('elder-msg').style.display = 'block';
    document.getElementById('elder-prompt').style.display = 'block';
    document.getElementById('elder-hint').style.display = 'block';
    if (inviteUrl) {
      panel.style.display = 'block';
      linkEl.textContent = inviteUrl;
    }
  }

  // 複製按鈕：停在「已複製 ✓」
  if (btnCopy && inviteUrl) {
    btnCopy.addEventListener('click', () => {
      navigator.clipboard.writeText(inviteUrl).then(() => {
        copyLabel.textContent = '已複製 ✓';
        btnCopy.classList.add('copied');
      });
    });
  }

  // LINE 分享
  if (btnLine && inviteUrl) {
    btnLine.href = 'https://social-plugins.line.me/lineit/share?url=' + encodeURIComponent(inviteUrl);
  }

  // 清理 sessionStorage
  sessionStorage.removeItem('survey_familyId');
  sessionStorage.removeItem('survey_inviteLink');
  sessionStorage.removeItem('survey_role');
</script>
