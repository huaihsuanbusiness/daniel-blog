---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}
import SurveyLayout from '../../../../layouts/SurveyLayout.astro';
---

<SurveyLayout title="感謝填寫" description="">
  <div class="thankyou-block">

    <div class="big-check">✓</div>
    <h2>謝謝您的填寫！</h2>

    <!-- 填寫後的感謝語 -->
    <p id="caregiver-msg" class="thank-msg" style="display:none">
      感謝您分享這麼寶貴的意見。<br />
      您的回覆將幫助我們打造更適合長輩與家屬的 AI 陪伴服務。
    </p>
    <p id="elder-msg" class="thank-msg" style="display:none">
      感謝您撥冗填寫！<br />
      您的回覆對我們非常寶貴。
    </p>

    <!-- 單一分享容器：Prompt + 連結 + 按鈕 -->
    <div id="share-panel" class="share-panel" style="display:none">

      <!-- 邀請提示語（置換後的正確版本） -->
      <p id="elder-prompt" class="prompt-line" style="display:none">
        邀請您分享給家人或照顧者填寫
      </p>
      <p id="caregiver-prompt" class="prompt-line" style="display:none">
        邀請您分享給長輩填寫
      </p>

      <!-- 連結＋按鈕 -->
      <div class="share-row">
        <div class="share-link" id="share-link"></div>
        <button class="btn-copy" id="btn-copy">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          <span id="copy-label">複製</span>
        </button>
        <a class="btn-line" id="btn-line" href="#" target="_blank" rel="noopener">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.924c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.198 0 .376.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0v-2.162c0-.344.282-.629.63-.629.346 0 .63.285.63.629v2.162H10.77V8.108c0-.345.282-.63.63-.63.346 0 .63.285.63.63v4.771H10.77zm-4.877 0H1.624c-.346 0-.63-.285-.63-.629V8.108c0-.345.284-.63.63-.63.345 0 .63.285.63.63v4.141h5.302V8.108c0-.345.284-.63.63-.63.345 0 .63.285.63.63v4.771zM8.437 9.68l-.382 2.924 2.665-2.924H8.437zm7.073 4.196H3.748l-.104-.629 4.197-4.141.104.63 4.465-.001v4.141z"/></svg>
          LINE
        </a>
      </div>

      <!-- 提示文字 -->
      <p id="elder-hint" class="share-hint" style="display:none">
        他們可以點擊連結填寫家屬版問卷
      </p>
      <p id="caregiver-hint" class="share-hint" style="display:none">
        長輩可點擊連結填寫長輩版問卷
      </p>
    </div>

    <div class="back-row">
      <a href="https://www.danielcanfly.com/zh/blog/ai-companion-survey?category=business" class="btn-back">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        返回文章
      </a>
    </div>

  </div>
</SurveyLayout>

<style>
  .thankyou-block {
    text-align: center;
    padding: 48px 24px 40px;
    max-width: 520px;
    margin: 0 auto;
  }

  .big-check {
    font-size: 60px;
    line-height: 1;
    margin-bottom: 14px;
  }

  h2 {
    font-size: 1.45rem;
    margin-bottom: 10px;
    color: #111;
    font-weight: 700;
  }

  .thank-msg {
    font-size: 0.92rem;
    color: #444;
    line-height: 1.75;
    margin: 0 0 4px;
  }

  /* 單一分享容器 */
  .share-panel {
    margin-top: 28px;
    background: #f7f8ff;
    border: 1.5px solid #dde3ff;
    border-radius: 14px;
    padding: 18px 20px 14px;
    text-align: left;
  }

  .prompt-line {
    font-size: 0.88rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 12px;
    line-height: 1.5;
  }

  .share-row {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .share-link {
    flex: 1;
    background: #fff;
    border: 1.5px solid #c5cae9;
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 0.78rem;
    font-family: 'SF Mono', 'Cascadia Code', monospace;
    color: #4f46e5;
    word-break: break-all;
    cursor: pointer;
    user-select: all;
    min-height: 40px;
    display: flex;
    align-items: center;
    transition: border-color 0.15s;
  }
  .share-link:hover { border-color: #4f46e5; }

  .btn-copy {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 11px;
    height: 40px;
    background: #4f46e5;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  .btn-copy:hover { background: #4338ca; }
  .btn-copy.copied { background: #16a34a; }

  .btn-line {
    display: flex;
    align-items: center;
    gap: 4px;
    height: 40px;
    padding: 0 11px;
    background: #00B900;
    color: #fff;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  .btn-line:hover { background: #009100; }

  .share-hint {
    font-size: 0.78rem;
    color: #777;
    margin: 8px 0 0;
    line-height: 1.5;
  }

  .back-row {
    margin-top: 28px;
    text-align: center;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 10px 22px;
    color: #555;
    text-decoration: none;
    font-size: 0.88rem;
    border: 1.5px solid #ddd;
    border-radius: 8px;
    transition: all 0.15s;
  }
  .btn-back:hover {
    color: #4f46e5;
    border-color: #4f46e5;
  }
</style>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const role = urlParams.get('role') || sessionStorage.getItem('survey_role') || '';
  const inviteUrl = urlParams.get('invite') || '';

  const panel = document.getElementById('share-panel');
  const linkEl = document.getElementById('share-link');
  const btnCopy = document.getElementById('btn-copy');
  const copyLabel = document.getElementById('copy-label');
  const btnLine = document.getElementById('btn-line');

  if (role === 'caregiver') {
    document.getElementById('caregiver-msg').style.display = 'block';
    document.getElementById('caregiver-prompt').style.display = 'block';
    document.getElementById('caregiver-hint').style.display = 'block';
    if (inviteUrl) {
      panel.style.display = 'block';
      linkEl.textContent = inviteUrl;
    }
  } else if (role === 'elder') {
    document.getElementById('elder-msg').style.display = 'block';
    document.getElementById('elder-prompt').style.display = 'block';
    document.getElementById('elder-hint').style.display = 'block';
    if (inviteUrl) {
      panel.style.display = 'block';
      linkEl.textContent = inviteUrl;
    }
  }

  // 複製按鈕：停在「已複製 ✓」
  if (btnCopy && inviteUrl) {
    btnCopy.addEventListener('click', () => {
      navigator.clipboard.writeText(inviteUrl).then(() => {
        copyLabel.textContent = '已複製 ✓';
        btnCopy.classList.add('copied');
      });
    });
  }

  // LINE 分享
  if (btnLine && inviteUrl) {
    btnLine.href = 'https://social-plugins.line.me/lineit/share?url=' + encodeURIComponent(inviteUrl);
  }

  // 清理 sessionStorage
  sessionStorage.removeItem('survey_familyId');
  sessionStorage.removeItem('survey_inviteLink');
  sessionStorage.removeItem('survey_role');
</script>
