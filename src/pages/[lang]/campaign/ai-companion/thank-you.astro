---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}
import SurveyLayout from '../../../../layouts/SurveyLayout.astro';
---

<SurveyLayout
  title="感謝填寫"
  description="AI 陪伴服務上線問卷填寫中！邀請您一起填寫 填寫問卷，服務上線後有機會獲得至少一個月免費試用！"
  ogTitle="AI 陪伴服務上線問卷填寫中！邀請您一起填寫 填寫問卷，服務上線後有機會獲得至少一個月免費試用！"
>
  <div class="thankyou-block">

    <!-- 第一區：個人邀請連結 -->
    <div id="share-panel" class="share-panel" style="display:none">

      <p class="panel-label">個人邀請連結</p>
      <p class="prompt-line" id="elder-prompt" style="display:none">
        邀請您分享給您的家人或照顧者填寫
      </p>
      <p class="prompt-line" id="caregiver-prompt" style="display:none">
        邀請您分享給長輩填寫
      </p>

      <div class="link-block">
        <div class="share-link" id="share-link"></div>
      </div>

      <div class="btn-group">
        <button class="btn-copy" id="btn-copy">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          <span id="copy-label">複製連結</span>
        </button>
        <div class="share-subrow">
          <a class="btn-line" id="btn-line" href="#" target="_blank" rel="noopener">
            <img src="/images/line-icon.png" alt="LINE" width="18" height="18" />
            分享到LINE
          </a>
          <a class="btn-fb" id="btn-fb" href="#" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span class="fb-spinner" aria-hidden="true"></span>
            <span class="fb-label">複製文案並分享到Facebook</span>
          </a>
        </div>
      </div>
    </div>

    <!-- 第二區：分享給其他人 -->
    <div class="share-panel share-panel-second">
      <p class="panel-label">分享給其他長輩或照顧者</p>
      <p class="prompt-line">將問卷連結分享給更多有需要的人</p>

      <div class="link-block">
        <div class="share-link" id="article-link"></div>
      </div>

      <div class="btn-group">
        <button class="btn-copy" id="btn-copy-article">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          <span id="copy-article-label">複製連結</span>
        </button>
        <div class="share-subrow">
          <a class="btn-line" id="btn-line-article" href="#" target="_blank" rel="noopener">
            <img src="/images/line-icon.png" alt="LINE" width="18" height="18" />
            分享到LINE
          </a>
          <a class="btn-fb" id="btn-fb-article" href="#" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span class="fb-spinner" aria-hidden="true"></span>
            <span class="fb-label">複製文案並分享到Facebook</span>
          </a>
        </div>
      </div>
    </div>

    <div class="back-row">
      <a href="https://www.danielcanfly.com/zh/blog/ai-companion-survey?category=business" class="btn-back">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        返回文章
      </a>
    </div>

    <div class="toast" id="share-toast" aria-live="polite"></div>

  </div>
</SurveyLayout>

<style>
  .thankyou-block {
    text-align: center;
    padding: 24px 24px 40px;
    max-width: 520px;
    margin: 0 auto;
  }
  .share-panel {
    margin-top: 28px;
    background: #f7f8ff;
    border: 1.5px solid #dde3ff;
    border-radius: 14px;
    padding: 18px 20px 14px;
    text-align: left;
  }
  .share-panel-second {
    margin-top: 14px;
  }
  .panel-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #8b8ba0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 8px;
  }
  .prompt-line {
    font-size: 0.88rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 12px;
    line-height: 1.5;
  }
  .link-block {
    flex: none;
    width: 100%;
  }
  .share-link {
    width: 100%;
    background: #fff;
    border: 1.5px solid #c5cae9;
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 0.78rem;
    font-family: 'SF Mono', 'Cascadia Code', monospace;
    color: #4f46e5;
    word-break: break-all;
    cursor: pointer;
    user-select: all;
    min-height: 40px;
    display: flex;
    align-items: center;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }
  .share-link:hover { border-color: #4f46e5; }
  .btn-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-shrink: 0;
    margin-top: 8px;
  }
  .share-subrow {
    display: flex;
    gap: 8px;
  }

  @media (max-width: 480px) {
    .share-panel {
      padding: 16px 16px 14px;
    }
    .btn-group {
      gap: 6px;
      margin-top: 6px;
    }
    .share-subrow {
      flex-direction: column;
      gap: 6px;
    }
    .btn-copy,
    .btn-line,
    .btn-fb {
      flex: none !important;
      width: 100%;
      justify-content: center;
      padding: 0 12px;
      box-sizing: border-box;
    }
  }
  .btn-copy {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 0 14px;
    height: 48px;
    min-height: 48px;
    width: 100%;
    box-sizing: border-box;
    background: #4f46e5;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    white-space: nowrap;
    flex: 1;
    appearance: none;
    -webkit-appearance: none;
    transition: background 0.15s;
  }
  .btn-copy:hover { background: #4338ca; }
  .btn-copy.copied { background: #16a34a; }
  .btn-line {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    height: 48px;
    min-height: 48px;
    padding: 0 14px;
    background: #00B900;
    color: #fff;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    flex: 1;
    transition: background 0.15s;
  }
  .btn-line:hover { background: #009100; }

  .btn-fb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    height: 48px;
    min-height: 48px;
    padding: 0 14px;
    background: #1877F2;
    color: #fff;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    flex: 1;
    transition: background 0.15s;
  }
  .btn-fb:hover { background: #166fe5; }
  .fb-spinner {
    display: none;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255,255,255,0.35);
    border-top-color: #fff;
    border-radius: 50%;
    animation: fb-spin 0.75s linear infinite;
    flex: 0 0 auto;
  }
  .btn-fb.loading {
    background: #145bd1;
    box-shadow: 0 0 0 3px rgba(24, 119, 242, 0.16);
    pointer-events: none;
  }
  .btn-fb.loading .fb-spinner {
    display: inline-block;
  }
  @keyframes fb-spin {
    to { transform: rotate(360deg); }
  }
  .toast {
    position: fixed;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%) translateY(12px);
    background: rgba(17, 24, 39, 0.94);
    color: #fff;
    padding: 11px 14px;
    border-radius: 12px;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.4;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
    z-index: 60;
    max-width: min(92vw, 420px);
    text-align: center;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .back-row {
    margin-top: 28px;
    text-align: center;
  }
  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 10px 22px;
    color: #fff;
    text-decoration: none;
    font-size: 0.88rem;
    border: 1.5px solid rgba(255,255,255,0.3);
    border-radius: 8px;
    transition: all 0.15s;
  }
  .btn-back:hover {
    color: #fff;
    border-color: #fff;
  }
</style>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const role = urlParams.get('role') || sessionStorage.getItem('survey_role') || '';
  const inviteUrl = urlParams.get('invite') || '';
  const articleUrl = 'https://www.danielcanfly.com/zh/blog/ai-companion-survey';
  const isMobileBrowser = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

  const panel = document.getElementById('share-panel');
  const linkEl = document.getElementById('share-link');
  const articleLinkEl = document.getElementById('article-link');
  const btnCopy = document.getElementById('btn-copy');
  const copyLabel = document.getElementById('copy-label');
  const btnLine = document.getElementById('btn-line');
  const btnCopyArticle = document.getElementById('btn-copy-article');
  const copyArticleLabel = document.getElementById('copy-article-label');
  const btnLineArticle = document.getElementById('btn-line-article');
  const btnFb = document.getElementById('btn-fb');
  const btnFbArticle = document.getElementById('btn-fb-article');
  const shareToast = document.getElementById('share-toast');

  // 個人邀請連結
  if (role === 'caregiver') {
    document.getElementById('caregiver-prompt').style.display = 'block';
    if (inviteUrl) {
      panel.style.display = 'block';
      linkEl.textContent = 'AI 陪伴服務上線問卷填寫中！邀請您一起填寫\n填寫問卷，服務上線後有機會獲得至少一個月免費試用！ ' + inviteUrl;
    }
  } else if (role === 'elder') {
    document.getElementById('elder-prompt').style.display = 'block';
    if (inviteUrl) {
      panel.style.display = 'block';
      linkEl.textContent = 'AI 陪伴服務上線問卷填寫中！邀請您一起填寫\n填寫問卷，服務上線後有機會獲得至少一個月免費試用！ ' + inviteUrl;
    }
  }

  // 文章連結（固定，永遠顯示）
  if (articleLinkEl) {
    articleLinkEl.textContent = 'AI 陪伴服務上線問卷填寫中！邀請您一起填寫\n填寫問卷，服務上線後有機會獲得至少一個月免費試用！ ' + articleUrl;
  }

  // ─── 分享區域 ───
  var TRIGGER = 'AI 陪伴服務上線問卷填寫中！邀請您一起填寫\n填寫問卷，服務上線後有機會獲得至少一個月免費試用！';

  // LINE 個人連結
  if (btnLine && inviteUrl) {
    var isMac = /Mac/i.test(navigator.userAgent) && !/iPhone|iPad/i.test(navigator.userAgent);
    if (isMac) {
      btnLine.href = 'https://line.me/R/msg/text?url=' + encodeURIComponent(inviteUrl) + '&text=' + encodeURIComponent(TRIGGER + ' ' + inviteUrl);
    } else {
      btnLine.href = 'line://msg/text/' + encodeURIComponent(TRIGGER + ' ' + inviteUrl);
    }
  }

  // LINE 文章連結
  if (btnLineArticle) {
    var isMac2 = /Mac/i.test(navigator.userAgent) && !/iPhone|iPad/i.test(navigator.userAgent);
    if (isMac2) {
      btnLineArticle.href = 'https://line.me/R/msg/text?url=' + encodeURIComponent(articleUrl) + '&text=' + encodeURIComponent(TRIGGER + ' ' + articleUrl);
    } else {
      btnLineArticle.href = 'line://msg/text/' + encodeURIComponent(TRIGGER + ' ' + articleUrl);
    }
  }







  function composeShareText(url) {
    return `${TRIGGER}\n${url}`;
  }

  function showToast(message) {
    if (!shareToast) return;
    shareToast.textContent = message;
    shareToast.classList.add('show');
    clearTimeout(shareToast._hideTimer);
    shareToast._hideTimer = setTimeout(() => {
      shareToast.classList.remove('show');
    }, 2400);
  }

  function showFbLoadingState(btn) {
    const label = btn?.querySelector('.fb-label');
    if (label) label.textContent = '已複製，重新導向中...';
    btn?.classList.add('loading');
    showToast('文案已複製，可直接貼上');
  }

  function resetFbState(btn) {
    const label = btn?.querySelector('.fb-label');
    if (label) label.textContent = '複製文案並分享到Facebook';
    btn?.classList.remove('loading');
  }

  // 複製個人連結
  if (btnCopy && inviteUrl) {
    if (role === 'caregiver') copyLabel.textContent = '複製長輩專屬連結';
    else if (role === 'elder') copyLabel.textContent = '複製家人/照顧者專屬連結';
    btnCopy.addEventListener('click', () => {
      navigator.clipboard.writeText(composeShareText(inviteUrl)).then(() => {
        copyLabel.textContent = '已複製 ✓';
        btnCopy.classList.add('copied');
      });
    });
  }

  // FB 分享個人連結：先複製貼文文案，再開 Facebook 分享頁
  if (btnFb && inviteUrl) {
    btnFb.addEventListener('click', (e) => {
      if (!isMobileBrowser) e.preventDefault();
      const webUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(inviteUrl);
      if (isMobileBrowser) {
        window.location.href = 'fb://composer';
      } else {
        window.open(webUrl, '_blank', 'noopener');
      }
    });
  }

  // FB 分享文章連結：先複製貼文文案，再開 Facebook 分享頁
  if (btnFbArticle) {
    btnFbArticle.addEventListener('click', (e) => {
      if (!isMobileBrowser) e.preventDefault();
      const webUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(articleUrl);
      if (isMobileBrowser) {
        window.location.href = 'fb://composer';
      } else {
        window.open(webUrl, '_blank', 'noopener');
      }
    });
  }

  // 複製文章連結
  if (btnCopyArticle) {
    btnCopyArticle.addEventListener('click', () => {
      navigator.clipboard.writeText(composeShareText(articleUrl)).then(() => {
        copyArticleLabel.textContent = '已複製 ✓';
        btnCopyArticle.classList.add('copied');
      });
    });
  }

  sessionStorage.removeItem('survey_familyId');
  sessionStorage.removeItem('survey_inviteLink');
  sessionStorage.removeItem('survey_role');
</script>
