---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}
import SurveyLayout from '../../../../layouts/SurveyLayout.astro';
---

<SurveyLayout title="感謝填寫" description="">
  <div class="thankyou-block">
    <div class="big-check">✓</div>
    <h2>謝謝您的填寫！</h2>
    <p id="caregiver-msg" style="display:none">
      感謝您分享這麼寶貴的意見。<br />
      您的回覆將幫助我們打造更適合長輩與家屬的 AI 陪伴服務。
    </p>
    <p id="elder-msg" style="display:none">
      感謝您撥冗填寫！<br />
      您的回覆對我們非常寶貴。
    </p>

    <div id="share-section" style="display:none" class="share-block">
      <p class="share-title" id="share-title"></p>
      <div class="link-box" id="invite-link-box"></div>
      <p class="share-hint" id="share-hint"></p>
    </div>
  </div>
</SurveyLayout>

<script>
  const role = sessionStorage.getItem('survey_role');
  const inviteLink = sessionStorage.getItem('survey_inviteLink') || '';

  const shareSection = document.getElementById('share-section');
  const shareTitle = document.getElementById('share-title');
  const shareHint = document.getElementById('share-hint');
  const linkBox = document.getElementById('invite-link-box');

  if (role === 'caregiver') {
    document.getElementById('caregiver-msg').style.display = 'block';
    if (inviteLink) {
      shareSection.style.display = 'block';
      shareTitle.textContent = '請將以下連結分享給長輩：';
      shareHint.textContent = '長輩可點擊連結填寫長輩版問卷';
      linkBox.textContent = inviteLink;
      linkBox.addEventListener('click', () => {
        navigator.clipboard.writeText(inviteLink).then(() => {
          linkBox.textContent = '已複製！';
          setTimeout(() => { linkBox.textContent = inviteLink; }, 2000);
        });
      });
    }
  } else {
    document.getElementById('elder-msg').style.display = 'block';
    if (inviteLink) {
      shareSection.style.display = 'block';
      shareTitle.textContent = '請將以下連結分享給家人或照顧者：';
      shareHint.textContent = '他們可以點擊連結填寫家屬版問卷';
      linkBox.textContent = inviteLink;
      linkBox.addEventListener('click', () => {
        navigator.clipboard.writeText(inviteLink).then(() => {
          linkBox.textContent = '已複製！';
          setTimeout(() => { linkBox.textContent = inviteLink; }, 2000);
        });
      });
    }
  }

  // Clean up sessionStorage after reading
  sessionStorage.removeItem('survey_familyId');
  sessionStorage.removeItem('survey_inviteLink');
  sessionStorage.removeItem('survey_role');
</script>
