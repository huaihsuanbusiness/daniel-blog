function renderQuestion(q: typeof questions[0], qIndex: number) {
  const isRequired = q.type !== 'textarea';
  const reqAttr = isRequired ? 'required' : '';
  const name = q.code;

  if (q.type === 'radio') {
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <ul class="options-list">
      ${q.options!.map((opt) => `
      <li>
        <label class="option-label">
          <input type="radio" name="${name}" value="${opt}" ${reqAttr} />
          <span>${opt}</span>
        </label>
      </li>`).join('')}
    </ul>
  </div>`;
  }

  if (q.type === 'checkbox') {
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <ul class="options-list">
      ${q.options!.map((opt) => `
      <li>
        <label class="option-label">
          <input type="checkbox" name="${name}" value="${opt}" />
          <span>${opt}</span>
        </label>
      </li>`).join('')}
    </ul>
  </div>`;
  }

  if (q.type === 'textarea') {
    return `
  <div class="question-block">
    ${q.section ? `<div class="section-label">${q.section}</div>` : ''}
    <div class="question-code">${q.code}</div>
    <div class="question-text">${q.text}</div>
    <textarea class="text-input" name="${name}" rows="4" placeholder="請填寫（選填）"></textarea>
  </div>`;
  }

  return '';
}

// Read ref param from URL on client side only
const refParam = '';
---

<SurveyLayout title="市場調查｜長輩版" description="請根據您的實際情況填寫">
  <div id="link-invalid" style="display:none" class="question-block">
    <div class="question-text">此連結已失效，請向家人重新取得。</div>
  </div>
  <form id="survey-form" style="display:none">
    {questions.map((q, i) => (
      <Fragment set:html={renderQuestion(q, i)} />
    ))}
    <button type="submit" class="submit-btn" id="submit-btn">送出</button>
  </form>
  <div id="error-container"></div>
</SurveyLayout>

<style>
  .section-label {
    font-size: 0.75rem;
    color: #4a7c59;
    font-weight: 600;
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }
</style>

<script define:vars={{ refParam }}>
  const urlParams = new URLSearchParams(window.location.search);
  const ref = urlParams.get('ref');

  if (!ref || !ref.startsWith('fam_')) {
    document.getElementById('link-invalid').style.display = 'block';
  } else {
    document.getElementById('survey-form').style.display = 'block';
  }

  const form = document.getElementById('survey-form');
  const submitBtn = document.getElementById('submit-btn');
  const errorContainer = document.getElementById('error-container');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorContainer.innerHTML = '';

    const formData = new FormData(form);
    const answers = {};

    for (const [key, value] of formData.entries()) {
      if (answers[key] === undefined) {
        answers[key] = value;
      } else if (Array.isArray(answers[key])) {
        answers[key].push(value);
      } else {
        answers[key] = [answers[key], value];
      }
    }

    const requiredQuestions = [
      'A1','A2','A3','A4','A5-1','A5-2','A5-3','A6','A7',
      'A8','A9','A10','A11','A12','A13','A14','A15',
      'A16','A17','A18','A19','A20','A21','A22','A23',
      'A24','A25'
    ];
    const missing = requiredQuestions.filter(q => !answers[q]);
    if (missing.length > 0) {
      errorContainer.innerHTML = `<div class="error-msg">請填完所有必填題目（還有 ${missing.length} 題未填）</div>`;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = '送出中…';

    try {
      const res = await fetch('/api/campaign/ai-companion-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          role: 'elder',
          familyId: ref,
          answers,
          locale: 'zh',
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        throw new Error(data.error || '送出失敗');
      }
      sessionStorage.setItem('survey_role', 'elder');
      const lang = window.location.pathname.split('/').filter(Boolean)[0] || 'zh';
      window.location.href = `/${lang}/campaign/ai-companion/thank-you`;
    } catch (err) {
      errorContainer.innerHTML = `<div class="error-msg">送出失敗：${err.message}</div>`;
      submitBtn.disabled = false;
      submitBtn.textContent = '送出';
    }
  });
</script>
