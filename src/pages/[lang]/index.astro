---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS, CATEGORY_ORDER, normalizeCategory } from '../../utils/categories';
import CategoryIcon from '../../components/CategoryIcon.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.id.endsWith(`/${lang}`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const slug = post.id.split('/')[0];
    return { ...post, slug };
  });

const heroContent = {
  en: {
    eyebrow: 'Welcome',
    title: 'Not here to sound smart.\nHere to make things work.',
    subtitle: 'AI・Tech・Business・Web3・Travel',
    heroCta: 'See all posts',
    latestLabel: 'Latest',
    viewAll: 'View all',
    comingSoon: 'Coming Soon',
    comingSoonDesc: 'Content is being prepared. Check back soon.',
    categoriesEyebrow: 'Explore by topic',
    categoriesTitle: 'Browse the archive by category',
    categoriesDesc: 'A structured path into essays, notes, and observations across the ideas that shape Daniel’s work.',
  },
  zh: {
    eyebrow: '歡迎',
    title: 'Not here to sound smart.\nHere to make things work.',
    subtitle: 'AI・Tech・Business・Web3・Travel',
    heroCta: '查看所有文章',
    latestLabel: '最新文章',
    viewAll: '查看全部',
    comingSoon: '即將上線',
    comingSoonDesc: '內容正在準備中，敬請期待。',
    categoriesEyebrow: '依主題瀏覽',
    categoriesTitle: '按分類進入文章與筆記',
    categoriesDesc: '把 Daniel 的觀察、長文與實作思考，整理成更容易探索的主題入口。',
  },
};

const content = heroContent[lang as 'en' | 'zh'];
const homepageCategories = CATEGORY_ORDER.map(id => ({
  id,
  label: CATEGORY_LABELS[id][lang as 'en' | 'zh'],
}));
---

<Base title="danielcanfly — Not here to sound smart" lang={lang!}>
  <Header currentLang={lang} />

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="hero-eyebrow animate-in">{content.eyebrow}</p>
          <h1 class="hero-title animate-in animate-delay-1">
            {content.title.split('\n').map((line, i) => (
              <>{line}{i < 1 && <br />}</>
            ))}
          </h1>
          <p class="hero-subtitle animate-in animate-delay-2">{content.subtitle}</p>
          <a href={`/${lang}/blog?category=all`} class="hero-cta animate-in animate-delay-2" data-home-see-all-posts>{content.heroCta}</a>
        </div>

        <div class="hero-visual animate-in animate-delay-2">
          <div class="hero-lottie" data-home-hero-lottie aria-hidden="true"></div>
        </div>
        <a href="#latest-posts" class="scroll-hint" aria-label={lang === 'zh' ? '往下閱讀' : 'Scroll down'}>
          <span class="scroll-hint-mouse" aria-hidden="true">
            <span class="scroll-hint-wheel"></span>
          </span>
          <span class="scroll-hint-text">{lang === 'zh' ? '往下滑' : 'Scroll'}</span>
        </a>
      </div>
    </section>

    <section id="latest-posts" class="posts-section">
      <div class="container">
        <div class="section-header animate-in">
          <h2 class="section-title">{content.latestLabel}</h2>
          <a href={`/${lang}/blog?category=all`} class="view-all" data-home-see-all-posts>
            {content.viewAll}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {posts.length === 0 ? (
          <div class="empty-state animate-in">
            <div class="empty-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>{content.comingSoon}</h3>
            <p class="muted">{content.comingSoonDesc}</p>
          </div>
        ) : (
          <>
            <div class="posts-grid">
              {posts.slice(0, 6).map((post, i) => (
                <div
                  class:list={['animate-in', { 'animate-delay-1': i % 3 === 1, 'animate-delay-2': i % 3 === 2 }]}
                  data-category={post.data.categories.map(cat => normalizeCategory(cat)).filter(Boolean).join(' ')}
                >
                  <PostCard
                    slug={post.slug}
                    title={post.data.title}
                    description={post.data.description}
                    categories={post.data.categories}
                    date={post.data.date}
                    lang={lang as 'en' | 'zh'}
                    featured={post.data.featured}
                  />
                </div>
              ))}
            </div>
            <div class="posts-cta-wrap animate-in animate-delay-2">
              <a href={`/${lang}/blog?category=all`} class="hero-cta posts-cta" data-home-see-all-posts>{content.heroCta}</a>
            </div>
          </>
        )}
      </div>
    </section>

    <section class="categories-section">
      <div class="container categories-shell">
        <div class="categories-intro animate-in">
          <p class="categories-eyebrow">{content.categoriesEyebrow}</p>
          <div class="categories-copy">
            <h2 class="categories-title">{content.categoriesTitle}</h2>
            <p class="categories-desc muted">{content.categoriesDesc}</p>
          </div>
        </div>

        <div class="categories-grid categories-grid-7">
          {homepageCategories.map((cat, index) => (
            <a href={`/${lang}/blog?category=${cat.id}`} class={`category-card tag-${cat.id} animate-in`} style={`animation-delay:${120 + index * 40}ms`}>
              <span class="cat-orbit"></span>
              <span class="cat-icon"><CategoryIcon id={cat.id} class="cat-icon-svg" size={28} /></span>
              <span class="cat-label">{cat.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script is:inline type="module">
  document.querySelectorAll('[data-home-see-all-posts]').forEach((link) => {
    link.addEventListener('click', () => {
      try {
        sessionStorage.removeItem('blog-category');
      } catch {}
    });
  });

  const heroLottieEls = document.querySelectorAll('[data-home-hero-lottie]');

  if (heroLottieEls.length) {
    import('https://cdn.jsdelivr.net/npm/lottie-web@5.12.2/+esm')
      .then(({ default: lottie }) => {
        heroLottieEls.forEach((container) => {
          lottie.loadAnimation({
            container,
            renderer: 'svg',
            loop: true,
            autoplay: true,
            path: '/animations/home-hero-lottie.json',
            rendererSettings: {
              preserveAspectRatio: 'xMidYMid meet',
              progressiveLoad: true,
            },
          });
        });
      })
      .catch(() => {
        heroLottieEls.forEach((container) => {
          container.setAttribute('data-ready', 'fallback');
        });
      });
  }
</script>

<style>
  .hero {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding: var(--space-10) 0 96px;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-8);
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .hero-title {
    font-size: clamp(2.2rem, 5.4vw, 4.1rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-3);
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.25rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast);
    width: fit-content;
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: 0 10px 24px color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(46vw, 520px);
    min-width: 320px;
  }

  .hero-lottie {
    width: min(100%, 500px);
    aspect-ratio: 950 / 847;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 18px 42px rgba(245, 158, 11, 0.16));
  }

  .hero-lottie :global(svg) {
    width: 100%;
    height: auto;
  }

  .hero-lottie[data-ready='fallback']::before {
    content: '';
    width: min(72vw, 280px);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-accent) 38%, var(--color-border));
    box-shadow: inset 0 0 0 36px color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  .scroll-hint {
    position: absolute;
    left: 50%;
    bottom: 22px;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--color-muted);
    opacity: 0.92;
    transition: transform var(--transition-fast), color var(--transition-fast), opacity var(--transition-fast);
    z-index: 2;
  }

  .scroll-hint:hover {
    color: var(--color-accent);
    opacity: 1;
    transform: translateX(-50%) translateY(-2px);
  }

  .scroll-hint-mouse {
    width: 26px;
    height: 42px;
    border-radius: 999px;
    border: 1.5px solid color-mix(in srgb, currentColor 75%, transparent);
    display: inline-flex;
    justify-content: center;
    padding-top: 7px;
    box-shadow: 0 0 0 1px color-mix(in srgb, currentColor 8%, transparent), 0 10px 24px color-mix(in srgb, currentColor 12%, transparent);
  }

  .scroll-hint-wheel {
    width: 4px;
    height: 9px;
    border-radius: 999px;
    background: currentColor;
    animation: scrollWheel 1.4s ease-in-out infinite;
  }

  .scroll-hint-text {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @keyframes scrollWheel {
    0% { transform: translateY(0); opacity: 1; }
    45% { transform: translateY(9px); opacity: 0.25; }
    46% { transform: translateY(0); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  .posts-section {
    padding: var(--space-10) 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .view-all {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .view-all:hover {
    color: var(--color-accent);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-4);
  }

  .posts-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: var(--space-6);
  }

  .posts-cta {
    min-width: 180px;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-10) 0;
  }

  .empty-icon {
    color: var(--color-border);
    margin-bottom: var(--space-3);
  }

  .empty-state h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-1);
  }

  .categories-section {
    padding: var(--space-6) 0 var(--space-10);
  }

  .categories-shell {
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: var(--space-5);
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 8%, transparent), transparent 38%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 96%, transparent), var(--color-surface));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
  }

  .categories-intro {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-4);
    align-items: start;
    margin-bottom: var(--space-5);
  }

  .categories-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .categories-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-1);
  }

  .categories-desc {
    max-width: 60ch;
  }

  .categories-grid {
    display: grid;
    gap: var(--space-3);
  }

  .categories-grid-7 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .category-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    gap: var(--space-2);
    padding: var(--space-4);
    min-height: 180px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 84%, transparent), var(--color-surface));
    border: 1px solid var(--color-border);
    border-radius: 18px;
    text-decoration: none;
    transition: transform var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .category-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--tag-color, var(--color-accent)) 65%, var(--color-border));
    box-shadow: 0 18px 40px color-mix(in srgb, var(--tag-color, var(--color-accent)) 14%, transparent);
  }

  .cat-orbit {
    position: absolute;
    top: -18px;
    right: -18px;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--tag-color, var(--color-accent)) 28%, transparent);
    opacity: 0.65;
  }

  .cat-orbit::after {
    content: '';
    position: absolute;
    inset: 14px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--tag-color, var(--color-accent)) 18%, transparent);
  }

  .cat-icon {
    font-size: 2rem;
    color: var(--tag-color, var(--color-accent));
    position: relative;
    z-index: 1;
  }

  .cat-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.35;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1200px) {
    .categories-grid-7 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 900px) {
    .categories-intro {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      width: min(100%, 360px);
      min-width: 0;
      margin: 0 auto;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .categories-shell {
      padding: var(--space-4);
    }

    .categories-grid-7 {
      grid-template-columns: repeat(2, 1fr);
    }

    .category-card {
      min-height: 150px;
    }
  }
</style>
