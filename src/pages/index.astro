---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_ICONS, CATEGORY_LABELS, CATEGORY_ORDER, normalizeCategory } from '../utils/categories';

const lang = 'en';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const slug = post.id.replace(/^[^/]+\//, '');
    return { ...post, slug };
  });

const heroContent = {
  eyebrow: 'Welcome',
  title: 'Ideas\nWorth\nSpreading.',
  subtitle: 'Web3 · AI · Business · Travel',
  latestLabel: 'Latest',
  viewAll: 'View all',
  comingSoon: 'Coming Soon',
  comingSoonDesc: 'Content is being prepared. Check back soon.',
};

const homepageCategories = CATEGORY_ORDER.map(id => ({
  id,
  icon: CATEGORY_ICONS[id],
  label: CATEGORY_LABELS[id][lang],
}));
---

<Base title="danielcanfly — Ideas Worth Spreading" lang={lang}>
  <Header currentLang={lang} />

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="hero-eyebrow animate-in">{heroContent.eyebrow}</p>
          <h1 class="hero-title animate-in animate-delay-1">
            {heroContent.title.split('\n').map((line, i) => (
              <>{line}{i < 2 && <br />}</>
            ))}
          </h1>
          <p class="hero-subtitle animate-in animate-delay-2">{heroContent.subtitle}</p>
        </div>

        <div class="hero-decoration">
          <div class="deco-circle"></div>
          <div class="deco-line"></div>
        </div>
      </div>
    </section>

    <section class="posts-section">
      <div class="container">
        <div class="section-header animate-in">
          <h2 class="section-title">{heroContent.latestLabel}</h2>
          <a href={`/${lang}/blog`} class="view-all">
            {heroContent.viewAll}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {posts.length === 0 ? (
          <div class="empty-state animate-in">
            <div class="empty-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>{heroContent.comingSoon}</h3>
            <p class="muted">{heroContent.comingSoonDesc}</p>
          </div>
        ) : (
          <div class="posts-grid">
            {posts.slice(0, 6).map((post, i) => (
              <div
                class:list={['animate-in', { 'animate-delay-1': i % 3 === 1, 'animate-delay-2': i % 3 === 2 }]}
                data-category={post.data.categories.map(cat => normalizeCategory(cat)).filter(Boolean).join(' ')}
              >
                <PostCard
                  slug={`${lang}/${post.slug}`}
                  title={post.data.title}
                  description={post.data.description}
                  categories={post.data.categories}
                  date={post.data.date}
                  lang={lang}
                  featured={post.data.featured}
                />
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="categories-section">
      <div class="container">
        <div class="categories-grid categories-grid-7">
          {homepageCategories.map(cat => (
            <a href={`/${lang}/blog?category=${cat.id}`} class={`category-card cat-${cat.id}`}>
              <span class="cat-icon">{cat.icon}</span>
              <span class="cat-label">{cat.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .hero {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding: var(--space-10) 0;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-8);
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-3);
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }

  .hero-decoration {
    position: relative;
    width: 300px;
    height: 300px;
  }

  .deco-circle {
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    animation: pulse 4s ease-in-out infinite;
  }

  .deco-circle::before {
    content: '';
    position: absolute;
    inset: 40px;
    border: 1px solid var(--color-accent);
    border-radius: 50%;
    opacity: 0.3;
  }

  .deco-line {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 2px;
    height: 200px;
    background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    opacity: 0.5;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.7; }
  }

  .posts-section {
    padding: var(--space-10) 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .view-all {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .view-all:hover {
    color: var(--color-accent);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-4);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-10) 0;
  }

  .empty-icon {
    color: var(--color-border);
    margin-bottom: var(--space-3);
  }

  .empty-state h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-1);
  }

  .categories-section {
    padding: var(--space-6) 0 var(--space-10);
  }

  .categories-grid {
    display: grid;
    gap: var(--space-3);
  }

  .categories-grid-7 {
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: all var(--transition-fast);
    min-height: 140px;
  }

  .category-card:hover {
    transform: translateY(-4px);
    border-color: var(--tag-color, var(--color-accent));
  }

  .cat-icon {
    font-size: 2rem;
    color: var(--tag-color, var(--color-accent));
  }

  .cat-label {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    text-align: center;
    line-height: 1.35;
  }

  @media (max-width: 1200px) {
    .categories-grid-7 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-decoration {
      display: none;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .categories-grid-7 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
