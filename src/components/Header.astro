---
export interface Props {
  currentLang?: 'en' | 'zh';
}

const { currentLang = 'en' } = Astro.props;

const navLinks = {
  en: [
    { href: '/en/blog', label: 'Blog' },
    { href: '/en/about', label: 'About' },
    { href: '/en/shop', label: 'Shop' },
  ],
  zh: [
    { href: '/zh/blog', label: '部落格' },
    { href: '/zh/about', label: '關於' },
    { href: '/zh/shop', label: '商店' },
  ],
};

const currentPath = Astro.url.pathname;
const currentSearch = Astro.url.search;
const links = navLinks[currentLang];
const otherLang = currentLang === 'zh' ? 'en' : 'zh';

const switchLangPath = (path: string, targetLang: 'en' | 'zh') => {
  if (path === '/') return targetLang === 'en' ? '/en/' : '/zh/';
  if (/^\/(en|zh)(\/)?$/.test(path)) return `/${targetLang}/`;
  return path.replace(/^\/(en|zh)(?=\/|$)/, `/${targetLang}`);
};

const langToggleHref = `${switchLangPath(currentPath, otherLang)}${currentSearch}`;
const logoHref = currentLang === 'en' ? '/en/' : '/zh/';
---

<header class="site-header" id="site-header">
  <div class="header-inner container">
    <a href={logoHref} class="logo">
      <span class="logo-text">danielcanfly</span>
      <span class="logo-tld">.com</span>
    </a>

    <nav class="nav-desktop">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a href={langToggleHref} class="lang-toggle" aria-label="Toggle language">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        <span>{otherLang === 'en' ? 'EN' : '中'}</span>
      </a>

      <button class="theme-toggle" aria-label="Toggle theme" id="theme-toggle" type="button">
        <svg class="theme-icon theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg class="theme-icon theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/>
        </svg>
      </button>

      <button class="search-btn" aria-label="Search" id="search-trigger">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>

      <button class="mobile-menu-btn" aria-label="Menu" id="mobile-menu-trigger">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav class="nav-mobile" id="mobile-nav">
    {links.map(link => (
      <a href={link.href} class="nav-link-mobile">
        {link.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const mobileNav = document.getElementById('mobile-nav');
  const mobileBtn = document.getElementById('mobile-menu-trigger');
  const langToggle = document.querySelector('.lang-toggle');
  const themeToggle = document.getElementById('theme-toggle');
  const storedTheme = localStorage.getItem('theme');
  if (!document.documentElement.dataset.theme) {
    document.documentElement.dataset.theme = storedTheme || 'dark';
  }

  if (langToggle instanceof HTMLAnchorElement) {
    const url = new URL(langToggle.href, window.location.origin);
    url.search = window.location.search;
    langToggle.href = url.toString();
  }

  // Header tracking: works on BOTH mobile and desktop
  // Page scrolls DOWN -> header hides UP  (offset goes more negative)
  // Page scrolls UP   -> header reveals DOWN (offset returns to 0)
  (function() {
    const headerHeight = header?.offsetHeight || 56;
    let lastY = null;
    let headerOffset = 0; // 0 = visible, negative = hidden above

    function applyTransform() {
      header.style.transform = `translateY(${Math.round(headerOffset)}px)`;
    }

    // Touch events (mobile)
    document.addEventListener('touchstart', (e) => {
      lastY = e.touches[0].clientY;
    }, { passive: true });

    document.addEventListener('touchmove', (e) => {
      if (lastY === null) return;
      const delta = lastY - e.touches[0].clientY; // + = finger pulled DOWN on page
      lastY = e.touches[0].clientY;
      // delta > 0: finger pulled down = page scrolling down -> hide header
      headerOffset = Math.min(Math.max(headerOffset + delta, -headerHeight), 0);
      applyTransform();
    }, { passive: true });

    document.addEventListener('touchend', () => {
      lastY = null;
    }, { passive: true });

    // Wheel events (desktop)
    document.addEventListener('wheel', (e) => {
      if (document.documentElement.scrollHeight <= window.innerHeight) return;
      const delta = -e.deltaY; // + = scrolling down
      headerOffset = Math.min(Math.max(headerOffset + delta * 0.12, -headerHeight), 0);
      applyTransform();
    }, { passive: true });
  })();

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem('theme', theme);
  };

  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
    applyTheme(current === 'light' ? 'dark' : 'light');
  });

  mobileBtn?.addEventListener('click', () => {
    mobileNav?.classList.toggle('open');
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-2) 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header.scrolled {
    background: var(--color-bg);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .logo {
    display: flex;
    align-items: baseline;
    gap: 2px;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover { color: var(--color-text); }
  .logo-tld { color: var(--color-accent); }

  .nav-desktop {
    display: flex;
    gap: var(--space-4);
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav-link:hover,
  .nav-link.active { color: var(--color-text); }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .lang-toggle,
  .theme-toggle,
  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 6px 10px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .lang-toggle:hover,
  .theme-toggle:hover,
  .search-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .theme-toggle {
    position: relative;
    width: 36px;
    height: 32px;
    padding: 0;
  }

  .theme-icon {
    position: absolute;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  :global(html[data-theme='dark']) .theme-icon-moon,
  :global(html[data-theme='light']) .theme-icon-sun {
    opacity: 0;
    transform: scale(0.8) rotate(-12deg);
  }

  :global(html[data-theme='dark']) .theme-icon-sun,
  :global(html[data-theme='light']) .theme-icon-moon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .mobile-menu-btn {
    display: none;
    padding: 6px;
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: var(--space-2) var(--space-3);
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 94%, transparent);
  }

  .nav-mobile.open { display: flex; }

  .nav-link-mobile {
    padding: var(--space-2) 0;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .site-header {
      padding: var(--space-1) 0;
      background: var(--color-bg);
      transition: none;
      backdrop-filter: none;
      border: none;
    }

    .site-header.scrolled {
      background: var(--color-bg);
    }

    .site-header.is-hidden {
      transform: translateY(-100%);
    }

    .site-header.is-visible {
      transform: translateY(0);
    }

    .header-inner {
      flex-wrap: wrap;
      gap: var(--space-2);
      background: var(--color-surface);
      border-radius: 12px;
      padding: var(--space-1) var(--space-2);
      border: 1px solid var(--color-border);
    }

    .logo { font-size: 0.875rem; }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 4px;
      order: 2;
    }

    .lang-toggle,
    .theme-toggle,
    .search-btn {
      padding: 4px 6px;
      font-size: 0.65rem;
    }

    .nav-desktop {
      display: flex;
      gap: var(--space-2);
      order: 3;
      width: 100%;
      justify-content: center;
    }

    .nav-link { font-size: 0.75rem; }

    .mobile-menu-btn { display: none; }
  }
</style>
