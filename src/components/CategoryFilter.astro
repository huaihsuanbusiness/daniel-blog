---
import { CATEGORY_ORDER, CATEGORY_LABELS, type BlogLang } from '../utils/categories';

export interface Props {
  categories?: string[];
  lang: BlogLang;
}

const { lang } = Astro.props;
const { category } = Astro.url.searchParams;

const filters = [
  { id: 'all', label: lang === 'zh' ? '全部' : 'All' },
  ...CATEGORY_ORDER.map(cat => ({ id: cat, label: CATEGORY_LABELS[cat][lang] })),
];
---

<div class="category-filter">
  <div class="filter-scroll">
    {filters.map(filter => (
      <button
        class:list={['tag', `tag-${filter.id}`, { active: (filter.id === 'all' && !category) || filter.id === category }]}
        data-category={filter.id}
      >
        {filter.label}
      </button>
    ))}
  </div>
</div>

<script>
  const buttons = document.querySelectorAll('.tag[data-category]');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');
      const cards = document.querySelectorAll('[data-category]');

      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const url = new URL(window.location.href);
      if (category === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', category!);
      }
      window.history.replaceState(null, '', url.toString());

      cards.forEach(card => {
        const cardCategories = (card.getAttribute('data-category') || '').split(' ').filter(Boolean);
        if (category === 'all' || cardCategories.includes(category || '')) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .category-filter {
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  .filter-scroll {
    display: flex;
    gap: var(--space-1);
    overflow-x: auto;
    padding-bottom: var(--space-1);
    scrollbar-width: none;
  }

  .filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .tag {
    flex-shrink: 0;
    cursor: pointer;
    border: none;
    font-family: var(--font-mono);
  }
</style>
