              ) : <CategoryIcon id={filter.id} class="tag-icon-svg" size={16} />}
            </span>
            <span class="tag-label">{filter.label}</span>
            <span class="tag-underline" aria-hidden="true"></span>
          </a>
        );
      })}
    </div>
  </div>

  <div class="controls-right">
    <div class="sort-wrap">
      <select id="sort-select" class="sort-select" aria-label={lang === 'zh' ? '排序' : 'Sort'}>
        <option value="new">{sortLabel.new}</option>
        <option value="old">{sortLabel.old}</option>
      </select>
      <svg class="sort-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>

    <div class="view-toggle" role="group" aria-label={lang === 'zh' ? '檢視模式' : 'View'}>
      <button class="view-btn active" id="view-grid" data-view="grid" aria-pressed="true" aria-label={lang === 'zh' ? '網格檢視' : 'Grid view'}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
      </button>
      <button class="view-btn" id="view-list" data-view="list" aria-pressed="false" aria-label={lang === 'zh' ? '列表檢視' : 'List view'}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="series-row" id="series-row" hidden>
    <div class="sort-wrap series-wrap" id="series-wrap">
      <select id="series-select" class="sort-select series-select" aria-label={seriesLabel.button}>
        <option value="">{seriesLabel.placeholder}</option>
      </select>
      <svg class="sort-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>
  </div>
</div>

<script>
  const postsGrid = document.getElementById('posts-grid');
  const tempTab = document.getElementById('series-temp-tab');
  const tempLabel = document.getElementById('series-temp-label');
  const tempClose = document.getElementById('series-temp-close');
  const seriesRow = document.getElementById('series-row');
  const seriesWrap = document.getElementById('series-wrap');
  const seriesSelect = document.getElementById('series-select');
  const sortSelect = document.getElementById('sort-select');
  const gridBtn = document.getElementById('view-grid');
  const listBtn = document.getElementById('view-list');
  const blogCountPill = document.getElementById('blog-count-pill');

  let activeCategory = new URL(window.location.href).searchParams.get('category') || sessionStorage.getItem('blog-category') || 'all';
  let activeSeries = '';

  function collectSeries(category) {
    const cards = Array.from(document.querySelectorAll('[data-post-card]'));
    const map = new Map();
    cards.forEach((card) => {
      const el = /** @type {HTMLElement} */ (card);
      const key = el.dataset.seriesKey || '';
      const label = el.dataset.seriesLabel || '';
      const order = Number(el.dataset.seriesOrder || '999');
      const categories = (el.dataset.category || '').split(' ');
      if (!key || !label) return;
      if (category === 'all' || !categories.includes(category)) return;
      if (!map.has(key)) map.set(key, { key, label, order });
    });
    return Array.from(map.values()).sort((a, b) => a.order - b.order);
  }

  function updateCountPill(count) {
    if (!blogCountPill) return;
    const label = blogCountPill.getAttribute('data-total-label') || '';
    blogCountPill.textContent = `${count} ${label}`;
  }

  function applySeriesFilter() {
    const cards = Array.from(document.querySelectorAll('[data-post-card]'));
    const effectiveSeries = (tempTab instanceof HTMLElement && !tempTab.hidden ? tempTab.dataset.seriesKey || activeSeries : activeSeries) || '';
    activeSeries = effectiveSeries;
    let visibleCount = 0;
    cards.forEach((card) => {
      const el = /** @type {HTMLElement} */ (card);
      const categories = (el.dataset.category || '').split(' ');
      const categoryMatch = activeCategory === 'all' || categories.includes(activeCategory);
      const seriesMatch = !effectiveSeries || el.dataset.seriesKey === effectiveSeries;
      const show = categoryMatch && seriesMatch;
      el.hidden = !show;
      if (show) visibleCount += 1;
    });
    updateCountPill(activeCategory === 'all' ? Number(blogCountPill?.getAttribute('data-total-count') || visibleCount) : visibleCount);
  }

  function clearSeriesFilter() {
    activeSeries = '';
    if (seriesSelect) seriesSelect.value = '';
    if (tempLabel) tempLabel.textContent = '';
    if (tempTab instanceof HTMLElement) {
      tempTab.hidden = true;
      delete tempTab.dataset.seriesKey;
    }
    applySeriesFilter();
  }

  function syncSeriesControl() {
    const options = collectSeries(activeCategory);
    if (!seriesWrap || !seriesSelect || !seriesRow) return;

    if (activeCategory === 'all' || options.length === 0) {
      seriesRow.hidden = true;
      clearSeriesFilter();
      return;
    }

    seriesRow.hidden = false;
    seriesSelect.innerHTML = '';

    const placeholder = document.createElement('option');
    placeholder.value = '';
    placeholder.textContent = seriesSelect.getAttribute('aria-label') === '查看系列' ? '查看系列' : 'Browse series';
    seriesSelect.appendChild(placeholder);

    options.forEach((option) => {
      const el = document.createElement('option');
      el.value = option.key;
      el.textContent = option.label;
      seriesSelect.appendChild(el);
    });

    if (!activeSeries) {
      seriesSelect.value = '';
      if (tempTab) tempTab.hidden = true;
    }
  }

  function syncCategoryTabs() {
    activeCategory = new URL(window.location.href).searchParams.get('category') || 'all';
    document.querySelectorAll('[data-filter-category]').forEach((tab) => {
      const cat = tab.getAttribute('data-filter-category') || 'all';
      const isActive = cat === activeCategory;
      tab.classList.toggle('active', isActive);
      if (isActive) tab.setAttribute('aria-current', 'page');
      else tab.removeAttribute('aria-current');
    });
  }

  document.querySelectorAll('[data-filter-category]').forEach((tab) => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      const cat = tab.getAttribute('data-filter-category') || 'all';
      const href = tab.getAttribute('href') || '';
      // Update URL synchronously so downstream syncListRuntimeState reads the new value
      history.pushState({}, '', href);
      activeCategory = cat;
      clearSeriesFilter();
      syncCategoryTabs();
      syncSeriesControl();
    });
  });

  seriesSelect?.addEventListener('change', () => {
    const select = /** @type {HTMLSelectElement} */ (seriesSelect);
    activeSeries = select.value;
    const selectedOption = select.options[select.selectedIndex];

    if (!activeSeries) {
      clearSeriesFilter();
      return;
    }

    if (tempTab instanceof HTMLElement && tempLabel) {
      tempTab.hidden = false;
      tempTab.dataset.seriesKey = activeSeries;
      tempLabel.textContent = selectedOption?.textContent || '';
    }

    applySeriesFilter();
  });

  tempClose?.addEventListener('click', (event) => {
    event.preventDefault();
    event.stopPropagation();
    clearSeriesFilter();
    if (tempTab) tempTab.hidden = true;
    syncSeriesControl();
  });

  function applyView(view) {
    const mobile = window.matchMedia('(max-width: 720px)').matches;
    const resolvedView = mobile ? 'list' : view;
    postsGrid?.classList.toggle('view-list', resolvedView === 'list');
    gridBtn?.classList.toggle('active', resolvedView === 'grid');
    listBtn?.classList.toggle('active', resolvedView === 'list');
    gridBtn?.setAttribute('aria-pressed', resolvedView === 'grid' ? 'true' : 'false');
    listBtn?.setAttribute('aria-pressed', resolvedView === 'list' ? 'true' : 'false');
    if (!mobile) localStorage.setItem('blog-view', resolvedView);
  }

  gridBtn?.addEventListener('click', () => applyView('grid'));
  listBtn?.addEventListener('click', () => applyView('list'));
  applyView(localStorage.getItem('blog-view') || 'grid');
  window.addEventListener('resize', () => applyView(localStorage.getItem('blog-view') || 'grid'));

  function applySort(sort) {
    if (!postsGrid) return;
    const preservedSeries = activeSeries || (tempTab instanceof HTMLElement ? tempTab.dataset.seriesKey || '' : '');
    const preservedLabel = tempLabel?.textContent || '';
    const cards = Array.from(postsGrid.querySelectorAll('[data-post-card]'));
    cards.sort((a, b) => {
      const keyA = /** @type {HTMLElement} */ (a).dataset.sortKey || '';
      const keyB = /** @type {HTMLElement} */ (b).dataset.sortKey || '';
      return sort === 'old' ? keyA.localeCompare(keyB) : keyB.localeCompare(keyA);
    });
    cards.forEach(card => postsGrid.appendChild(card));
    activeSeries = preservedSeries;
    if (preservedSeries && tempTab instanceof HTMLElement && tempLabel) {
      tempTab.hidden = false;
      tempTab.dataset.seriesKey = preservedSeries;
      tempLabel.textContent = preservedLabel;
      if (seriesSelect) seriesSelect.value = preservedSeries;
    }
    applySeriesFilter();
  }

  sortSelect?.addEventListener('change', () => {
    const select = /** @type {HTMLSelectElement} */ (sortSelect);
    const sort = select.value;
    const url = new URL(window.location.href);
    url.searchParams.set('sort', sort);
    history.replaceState({}, '', url.toString());
    applySort(sort);
  });

  const initialSort = new URL(window.location.href).searchParams.get('sort') || 'new';
  if (sortSelect) sortSelect.value = initialSort;
  applySort(initialSort);
  syncCategoryTabs();
  syncSeriesControl();
  applySeriesFilter();
</script>

<style>
  .blog-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: 0;
    flex-wrap: wrap;
  }

  .filter-scroll-wrap {
    flex: 1;
    overflow: hidden;
  }

  .filter-scroll {
    display: flex;
    gap: var(--space-1);
    overflow-x: auto;
    padding-bottom: 2px;
    scrollbar-width: none;
  }

  .filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .controls-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .sort-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .sort-select {
    appearance: none;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 6px 28px 6px 10px;
    cursor: pointer;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .sort-select:hover,
  .sort-select:focus {
    border-color: var(--color-accent);
  }

  .sort-chevron {
    position: absolute;
    right: 8px;
    pointer-events: none;
    color: var(--color-muted);
  }

  .view-toggle {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: transparent;
    border: none;
    color: var(--color-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .view-btn.active {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .tag {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    padding: 8px 14px;
    border-radius: 999px;
    overflow: hidden;
    transform: translateY(0);
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      color var(--transition-fast);
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
  }

  .tag:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--tag-color, var(--color-accent)) 18%, transparent), 0 8px 20px color-mix(in srgb, var(--tag-color, var(--color-accent)) 10%, transparent);
  }

  .tag.active,
  .tag[aria-current='page'],
  .tag-temp {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--tag-color, var(--color-accent)) 28%, transparent),
      0 0 20px color-mix(in srgb, var(--tag-color, var(--color-accent)) 18%, transparent),
      inset 0 0 18px color-mix(in srgb, var(--tag-color, var(--color-accent)) 10%, transparent);
    border-color: color-mix(in srgb, var(--tag-color, var(--color-accent)) 40%, transparent);
  }

  .tag-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--tag-color, var(--color-accent));
    transform: translateY(0) scale(1);
    transition: transform var(--transition-fast), color var(--transition-fast), text-shadow var(--transition-fast);
  }

  .tag.active .tag-icon,
  .tag[aria-current='page'] .tag-icon,
  .tag-temp .tag-icon {
    transform: translateY(-1px) scale(1.08);
    text-shadow: 0 0 12px color-mix(in srgb, var(--tag-color, var(--color-accent)) 40%, transparent);
  }

  .tag-underline {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 6px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--tag-color, var(--color-accent)), transparent);
    opacity: 0;
    transform: scaleX(0.4);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .tag.active .tag-underline,
  .tag[aria-current='page'] .tag-underline,
  .tag-temp .tag-underline {
    opacity: 1;
    transform: scaleX(1);
  }

  #series-temp-tab[hidden],
  [data-post-card][hidden] {
    display: none !important;
  }

  .tag-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: none;
    background: transparent;
    color: inherit;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    margin-left: 2px;
    flex: 0 0 auto;
  }

  .series-row {
    flex-basis: 100%;
    margin: 6px 0 var(--space-4);
  }

  .series-row[hidden] {
    display: block !important;
    visibility: hidden;
    pointer-events: none;
  }

  .series-wrap {
    width: fit-content;
    min-width: 0;
  }

  .series-select {
    width: auto;
    min-width: 0;
    padding-right: 30px;
    max-width: 160px;
  }

  @media (max-width: 720px) {
    .filter-scroll-wrap {
      flex: 1 1 100%;
      width: 100%;
    }

    .view-toggle {
      display: none;
    }

    .series-row {
      flex-basis: auto;
      margin: 0 0 var(--space-3);
      order: 2;
      margin-right: auto;
      align-self: center;
    }

    .controls-right {
      width: auto;
      justify-content: flex-end;
      align-items: center;
      padding-top: 0;
      margin-top: 0;
      margin-bottom: 0;
      order: 3;
      margin-left: auto;
      align-self: center;
    }

    .series-wrap,
    .controls-right .sort-wrap {
      height: 34px;
      min-height: 34px;
      align-items: center;
      margin: 0;
    }

    .series-select,
    .controls-right .sort-select {
      height: 34px;
      min-height: 34px;
      box-sizing: border-box;
      margin: 0;
      line-height: 1.2;
    }

    .series-select {
      max-width: 140px;
    }
  }
</style>
