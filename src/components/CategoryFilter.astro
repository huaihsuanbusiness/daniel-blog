---
import { CATEGORY_ORDER, CATEGORY_LABELS, type BlogLang } from '../utils/categories';
import CategoryIcon from './CategoryIcon.astro';

export interface Props {
  categories?: string[];
  lang: BlogLang;
}

const { lang } = Astro.props;
const category = Astro.url.searchParams.get('category');
const basePath = `/${lang}/blog`;

const filters = [
  { id: 'all', label: lang === 'zh' ? '全部' : 'All', href: basePath },
  ...CATEGORY_ORDER.map(cat => ({
    id: cat,
    label: CATEGORY_LABELS[cat][lang],
    href: `${basePath}?category=${cat}`,
  })),
];

const sortLabels = {
  en: { new: 'Newest first', old: 'Oldest first' },
  zh: { new: '最新優先', old: '最早優先' },
};
const sortLabel = sortLabels[lang];
const seriesUi = {
  en: { button: 'Browse series', close: 'Close series filter' },
  zh: { button: '查看系列', close: '關閉系列篩選' },
}[lang];
---

<div class="blog-controls">
  <div class="filter-scroll-wrap">
    <div class="filter-scroll">
      {filters.map(filter => {
        const isActive = (filter.id === 'all' && !category) || filter.id === category;
        return (
          <a
            href={filter.href}
            class:list={['tag', `tag-${filter.id}`, { active: isActive }]}
            data-filter-category={filter.id}
            aria-current={isActive ? 'page' : undefined}
          >
            <span class="tag-icon" aria-hidden="true">
              {filter.id === 'all' ? '◌' : <CategoryIcon id={filter.id} class="tag-icon-svg" size={16} />}
            </span>
            <span class="tag-label">{filter.label}</span>
            <span class="tag-underline" aria-hidden="true"></span>
          </a>
        );
      })}
    </div>
  </div>

  <div class="controls-right">
    <!-- Sort -->
    <div class="sort-wrap">
      <select id="sort-select" class="sort-select" aria-label={lang === 'zh' ? '排序' : 'Sort'}>
        <option value="new">{sortLabel.new}</option>
        <option value="old">{sortLabel.old}</option>
      </select>
      <svg class="sort-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="m6 15 6-6 6-6"/>
      </svg>
    </div>

    <!-- View toggle -->
    <div class="view-toggle" role="group" aria-label={lang === 'zh' ? '檢視模式' : 'View'}>
      <button class="view-btn active" id="view-grid" data-view="grid" aria-pressed="true" aria-label={lang === 'zh' ? '網格檢視' : 'Grid view'}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
      </button>
      <button class="view-btn" id="view-list" data-view="list" aria-pressed="false" aria-label={lang === 'zh' ? '列表檢視' : 'List view'}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<div class="series-filter-row" id="series-filter-row" hidden>
  <button class="series-filter-button" id="series-filter-button" type="button" hidden>{seriesUi.button}</button>
  <div class="series-filter-dropdown" id="series-filter-dropdown" hidden></div>
  <button class="series-filter-chip" id="series-filter-chip" type="button" hidden>
    <span class="series-filter-chip-icon tag-icon" aria-hidden="true"></span>
    <span class="series-filter-chip-label"></span>
    <span class="series-filter-chip-close" aria-label={seriesUi.close}>×</span>
  </button>
</div>

<script>
  // ── Category tab sync ──────────────────────────────────────
  const seriesRow = document.getElementById('series-filter-row');
  const seriesButton = document.getElementById('series-filter-button');
  const seriesDropdown = document.getElementById('series-filter-dropdown');
  const seriesChip = document.getElementById('series-filter-chip');
  const seriesChipLabel = seriesChip?.querySelector('.series-filter-chip-label');
  const seriesChipIcon = seriesChip?.querySelector('.series-filter-chip-icon');
  let selectedSeriesKey = '';
  let baseCategory = new URL(window.location.href).searchParams.get('category') || 'all';

  function collectSeries(category) {
    const cards = Array.from(document.querySelectorAll('[data-post-card]'));
    const map = new Map();
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const cardCategory = (el.dataset.category || '').split(' ');
      const key = el.dataset.seriesKey || '';
      const label = el.dataset.seriesLabel || '';
      if (!key || !label) return;
      if (category !== 'all' && !cardCategory.includes(category)) return;
      if (!map.has(key)) map.set(key, label);
    });
    return Array.from(map.entries()).map(([key, label]) => ({ key, label }));
  }

  function applySeriesFilter() {
    const cards = Array.from(document.querySelectorAll('[data-post-card]'));
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const match = !selectedSeriesKey || el.dataset.seriesKey === selectedSeriesKey;
      el.style.display = match ? '' : 'none';
    });
  }

  function closeSeriesDropdown() {
    seriesDropdown?.setAttribute('hidden', 'true');
  }

  function clearSeriesFilter() {
    selectedSeriesKey = '';
    if (seriesChip) seriesChip.hidden = true;
    applySeriesFilter();
    closeSeriesDropdown();
  }

  function renderSeriesUi(category) {
    baseCategory = category;
    const isAll = category === 'all';
    const options = collectSeries(category);
    if (!seriesRow || !seriesButton || !seriesDropdown) return;

    if (isAll || options.length === 0) {
      seriesRow.hidden = true;
      clearSeriesFilter();
      return;
    }

    seriesRow.hidden = false;
    seriesButton.hidden = false;
    seriesDropdown.hidden = true;
    seriesDropdown.innerHTML = '';

    options.forEach((option) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'series-filter-option';
      btn.textContent = option.label;
      btn.addEventListener('click', () => {
        selectedSeriesKey = option.key;
        if (seriesChip && seriesChipLabel && seriesChipIcon) {
          seriesChip.hidden = false;
          seriesChipLabel.textContent = option.label;
          seriesChipIcon.textContent = '◌';
        }
        applySeriesFilter();
        closeSeriesDropdown();
      });
      seriesDropdown.appendChild(btn);
    });
  }

  function syncCategoryTabs() {
    const url = window.location.href;
    const activeCategory = new URL(url).searchParams.get('category') || 'all';
    const tabs = document.querySelectorAll('[data-filter-category]');
    tabs.forEach((tab) => {
      const cat = tab.getAttribute('data-filter-category');
      const isActive = cat === activeCategory;
      tab.classList.toggle('active', isActive);
      if (isActive) {
        tab.setAttribute('aria-current', 'page');
      } else {
        tab.removeAttribute('aria-current');
      }
      tab.addEventListener('click', () => {
        clearSeriesFilter();
      });
    });
    renderSeriesUi(activeCategory);
  }

  syncCategoryTabs();

  seriesButton?.addEventListener('click', () => {
    const hidden = seriesDropdown?.hasAttribute('hidden');
    if (hidden) {
      seriesDropdown?.removeAttribute('hidden');
    } else {
      closeSeriesDropdown();
    }
  });

  seriesChip?.addEventListener('click', () => {
    clearSeriesFilter();
    renderSeriesUi(baseCategory);
  });

  // ── View toggle ──────────────────────────────────────────────
  const gridBtn = document.getElementById('view-grid');
  const listBtn = document.getElementById('view-list');
  const postsGrid = document.getElementById('posts-grid');

  function applyView(view) {
    postsGrid?.classList.toggle('view-list', view === 'list');
    gridBtn?.classList.toggle('active', view === 'grid');
    listBtn?.classList.toggle('active', view === 'list');
    gridBtn?.setAttribute('aria-pressed', view === 'grid' ? 'true' : 'false');
    listBtn?.setAttribute('aria-pressed', view === 'list' ? 'true' : 'false');
    localStorage.setItem('blog-view', view);
  }

  gridBtn?.addEventListener('click', () => applyView('grid'));
  listBtn?.addEventListener('click', () => applyView('list'));

  // Restore saved view
  const savedView = localStorage.getItem('blog-view') || 'grid';
  applyView(savedView);

  // ── Sort ─────────────────────────────────────────────────────
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;

  function applySort(sort: string) {
    if (!postsGrid) return;
    const cards = Array.from(postsGrid.querySelectorAll('[data-post-card]'));
    cards.sort((a, b) => {
      const keyA = (a as HTMLElement).dataset.sortKey || '';
      const keyB = (b as HTMLElement).dataset.sortKey || '';
      // key format: "YYYY-MM-DDTHH:MM" (slug removed)
      // Astro collection order = commit order for same-date items
      // For "newest first": newer keys first (reverse Astro default)
      return sort === 'old' ? keyA.localeCompare(keyB) : keyB.localeCompare(keyA);
    });
    cards.forEach(card => postsGrid.appendChild(card));
  }

  sortSelect?.addEventListener('change', () => {
    const sort = sortSelect.value;
    const url = new URL(window.location.href);
    url.searchParams.set('sort', sort);
    history.replaceState({}, '', url.toString());
    applySort(sort);
  });

  // Restore sort from URL on load
  const initialSort = new URL(window.location.href).searchParams.get('sort') || 'new';
  if (sortSelect) sortSelect.value = initialSort;
  applySort(initialSort);
</script>

<style>
  .blog-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .filter-scroll-wrap {
    flex: 1;
    overflow: hidden;
  }

  .filter-scroll {
    display: flex;
    gap: var(--space-1);
    overflow-x: auto;
    padding-bottom: 2px;
    scrollbar-width: none;
  }

  .filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .controls-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    .filter-scroll-wrap {
      flex: 1 1 100%;
      width: 100%;
    }

    .controls-right {
      width: 100%;
      justify-content: flex-end;
      padding-top: 4px;
    }
  }

  /* ── Sort ──────────────────────────────── */
  .sort-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .sort-select {
    appearance: none;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 6px 28px 6px 10px;
    cursor: pointer;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .sort-select:hover,
  .sort-select:focus {
    border-color: var(--color-accent);
  }

  .sort-chevron {
    position: absolute;
    right: 8px;
    pointer-events: none;
    color: var(--color-muted);
  }

  /* ── View toggle ───────────────────────── */
  .view-toggle {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: transparent;
    border: none;
    color: var(--color-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .view-btn:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-text) 6%, transparent);
  }

  .view-btn.active {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  /* ── Category tags (unchanged) ─────────── */
  .tag {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    padding: 8px 14px;
    border-radius: 999px;
    overflow: hidden;
    transform: translateY(0);
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      color var(--transition-fast);
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
  }

  .tag:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--tag-color, var(--color-accent)) 18%, transparent), 0 8px 20px color-mix(in srgb, var(--tag-color, var(--color-accent)) 10%, transparent);
  }

  .tag-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    color: var(--tag-color, var(--color-accent));
    transform: translateY(0) scale(1);
    transition: transform var(--transition-fast), color var(--transition-fast), text-shadow var(--transition-fast);
  }

  .tag-label {
    position: relative;
    z-index: 1;
  }

  .tag-underline {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 6px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--tag-color, var(--color-accent)), transparent);
    opacity: 0;
    transform: scaleX(0.4);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .tag.active,
  .tag[aria-current='page'] {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--tag-color, var(--color-accent)) 28%, transparent),
      0 0 20px color-mix(in srgb, var(--tag-color, var(--color-accent)) 18%, transparent),
      inset 0 0 18px color-mix(in srgb, var(--tag-color, var(--color-accent)) 10%, transparent);
    border-color: color-mix(in srgb, var(--tag-color, var(--color-accent)) 40%, transparent);
  }

  .tag.active .tag-icon,
  .tag[aria-current='page'] .tag-icon {
    transform: translateY(-1px) scale(1.08);
    text-shadow: 0 0 12px color-mix(in srgb, var(--tag-color, var(--color-accent)) 40%, transparent);
    animation: tagIconPulse 1.8s ease-in-out infinite;
  }

  .tag.active .tag-underline,
  .tag[aria-current='page'] .tag-underline {
    opacity: 1;
    transform: scaleX(1);
  }

  @keyframes tagIconPulse {
    0%, 100% { transform: translateY(-1px) scale(1.08); }
    50% { transform: translateY(-3px) scale(1.14); }
  }

  /* ── Responsive ────────────────────────── */
  .series-filter-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: -10px 0 var(--space-5);
    position: relative;
    flex-wrap: wrap;
  }

  .series-filter-button,
  .series-filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
  }

  .series-filter-dropdown {
    width: min(100%, 520px);
    padding: 8px;
    border-radius: 16px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    display: grid;
    gap: 8px;
  }

  .series-filter-option {
    text-align: left;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
  }

  .series-filter-option:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
  }

  .series-filter-chip-close {
    font-size: 1rem;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .blog-controls {
      flex-wrap: wrap;
    }

    .filter-scroll-wrap {
      width: 100%;
      order: 1;
    }

    .controls-right {
      order: 2;
    }

    .series-filter-row {
      margin-top: -4px;
    }

    .series-filter-dropdown {
      width: 100%;
    }
  }
</style>
