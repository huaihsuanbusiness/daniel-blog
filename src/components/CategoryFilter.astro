---
import { CATEGORY_ORDER, CATEGORY_LABELS, type BlogLang } from '../utils/categories';

export interface Props {
  categories?: string[];
  lang: BlogLang;
}

const { lang } = Astro.props;
const { category } = Astro.url.searchParams;
const basePath = `/${lang}/blog`;

const filters = [
  { id: 'all', label: lang === 'zh' ? '全部' : 'All', href: basePath },
  ...CATEGORY_ORDER.map(cat => ({
    id: cat,
    label: CATEGORY_LABELS[cat][lang],
    href: `${basePath}?category=${cat}`,
  })),
];
---

<div class="category-filter">
  <div class="filter-scroll">
    {filters.map(filter => (
      <a
        href={filter.href}
        class:list={['tag', `tag-${filter.id}`, { active: (filter.id === 'all' && !category) || filter.id === category }]}
        data-filter-category={filter.id}
        aria-current={(filter.id === 'all' && !category) || filter.id === category ? 'page' : undefined}
      >
        {filter.label}
      </a>
    ))}
  </div>
</div>

<style>
  .category-filter {
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  .filter-scroll {
    display: flex;
    gap: var(--space-1);
    overflow-x: auto;
    padding-bottom: var(--space-1);
    scrollbar-width: none;
  }

  .filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .tag {
    flex-shrink: 0;
    cursor: pointer;
    font-family: var(--font-mono);
  }
</style>
