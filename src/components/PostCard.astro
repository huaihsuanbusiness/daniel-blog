---
export interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  date: Date;
  lang: 'en' | 'zh';
  featured?: boolean;
}

const { slug, title, description, category, date, lang, featured = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);

const categoryLabels: Record<string, string> = {
  web3: 'Web3',
  ai: 'AI',
  travel: 'Travel',
  openclaw: 'OpenClaw',
  business: 'Business',
  tech: 'Tech',
};
---

<article class:list={['post-card', { featured }]}>
  <a href={`/blog/${slug}`} class="card-link">
    <div class="card-inner">
      <div class="card-meta">
        <span class={`tag tag-${category}`}>
          {categoryLabels[category] || category}
        </span>
        <span class="card-date muted">{formattedDate}</span>
      </div>

      <h3 class="card-title">{title}</h3>
      <p class="card-desc muted">{description}</p>

      <div class="card-footer">
        <span class="read-more">
          Read more
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
        <span class="card-lang muted">{lang === 'zh' ? '中文' : 'EN'}</span>
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: all var(--transition-fast);
  }

  .post-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 0 24px rgba(245, 158, 11, 0.08);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-inner {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    height: 100%;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .card-date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .post-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    transition: gap var(--transition-fast);
  }

  .post-card:hover .read-more {
    gap: 10px;
  }

  .card-lang {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
  }

  /* Featured variant */
  .post-card.featured {
    grid-column: span 2;
  }

  .post-card.featured .card-title {
    font-size: 1.75rem;
  }

  .post-card.featured .card-desc {
    -webkit-line-clamp: 4;
  }

  @media (max-width: 768px) {
    .post-card.featured {
      grid-column: span 1;
    }
  }
</style>
