---
import { getCollection } from 'astro:content';
import { normalizeCategory } from '../utils/categories';

export interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const allPosts = await getCollection('blog');
const languagePosts = allPosts
  .filter(post => post.id.endsWith(`/${lang}`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const slug = post.id.split('/')[0];
    return {
      slug,
      title: post.data.title,
      description: post.data.description || '',
      category: normalizeCategory(post.data.categories[0] || '') ?? '',
      date: post.data.date.toISOString().slice(0, 10),
    };
  });

const labels = {
  en: { placeholder: 'Search articles…', noResults: 'No results found.' },
  zh: { placeholder: '搜尋文章…', noResults: '找不到符合的文章。' },
};
const label = labels[lang];
const searchData = JSON.stringify(languagePosts);
---

<!-- Inject posts data as global BEFORE the inline script runs -->
<script is:inline define:vars={{ searchData, label, lang }}>
  window.BLOG_SEARCH_DATA = JSON.parse(searchData);
  window.BLOG_SEARCH_LANG = lang;
  window.BLOG_SEARCH_LABEL = label;
</script>

<!-- Search Modal -->
<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <div class="search-header">
      <div class="search-input-wrap">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder={label.placeholder}
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <button class="search-close" id="search-close" aria-label="Close search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="search-body">
      <ul id="search-results" class="search-results" role="listbox"></ul>
      <p id="search-empty" class="search-empty">{label.noResults}</p>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var posts = window.BLOG_SEARCH_DATA || [];
    var lang = window.BLOG_SEARCH_LANG || 'en';
    var label = window.BLOG_SEARCH_LABEL || {};

    var modal = document.getElementById('search-modal');
    var backdrop = document.getElementById('search-backdrop');
    var closeBtn = document.getElementById('search-close');
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    var emptyMsg = document.getElementById('search-empty');

    function isOpen() {
      return modal && modal.classList.contains('is-open');
    }

    function openModal() {
      if (!modal) return;
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      if (input) {
        input.value = '';
        input.focus();
      }
      if (results) results.innerHTML = '';
      if (emptyMsg) emptyMsg.style.display = 'none';
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    // Open: header search button
    var trigger = document.getElementById('search-trigger');
    if (trigger) trigger.addEventListener('click', openModal);

    // Close
    if (backdrop) backdrop.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen()) closeModal();
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        isOpen() ? closeModal() : openModal();
      }
    });

    function render(resultsList) {
      if (!results || !emptyMsg) return;
      if (resultsList.length === 0) {
        results.innerHTML = '';
        emptyMsg.style.display = '';
        return;
      }
      emptyMsg.style.display = 'none';
      var html = '';
      for (var i = 0; i < resultsList.length; i++) {
        var p = resultsList[i];
        html += '<li role="option">\
          <a href="/' + lang + '/blog/' + p.slug + '" class="search-result-item">\
            <div class="result-meta">\
              <span class="result-category">' + p.category + '</span>\
              <span class="result-date">' + p.date + '</span>\
            </div>\
            <div class="result-title">' + p.title + '</div>\
            <div class="result-desc">' + (p.description || '') + '</div>\
          </a>\
        </li>';
      }
      results.innerHTML = html;
    }

    if (input) {
      input.addEventListener('input', function () {
        var q = input.value.trim().toLowerCase();
        if (!q) {
          render([]);
          return;
        }
        var filtered = [];
        for (var i = 0; i < posts.length; i++) {
          var p = posts[i];
          if (p.title.toLowerCase().indexOf(q) !== -1 ||
              (p.description && p.description.toLowerCase().indexOf(q) !== -1)) {
            filtered.push(p);
          }
        }
        render(filtered);
      });
    }
  })();
</script>

<style>
  .search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: flex-start;
    justify-content: center;
    padding-top: clamp(48px, 10vh, 120px);
    padding-inline: 16px;
  }

  .search-modal.is-open {
    display: flex;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-panel {
    position: relative;
    width: 100%;
    max-width: 620px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.4);
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .search-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0 12px;
    transition: border-color 0.15s;
  }

  .search-input-wrap:focus-within {
    border-color: var(--color-accent);
  }

  .search-icon {
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text);
    padding: 10px 0;
  }

  .search-input::placeholder {
    color: var(--color-muted);
  }

  .search-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.15s;
  }

  .search-close:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .search-body {
    max-height: 380px;
    overflow-y: auto;
    padding: 8px;
  }

  .search-results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 14px;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }

  .search-result-item:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
  }

  .result-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .result-category {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .result-date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
  }

  .result-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .result-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-empty {
    padding: 28px 16px;
    text-align: center;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin: 0;
  }
</style>
