---
import { getCollection } from 'astro:content';
import { normalizeCategory } from '../utils/categories';

export interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const allPosts = await getCollection('blog');
const languagePosts = allPosts
  .filter(post => post.id.endsWith(`/${lang}`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const slug = post.id.split('/')[0];
    return {
      slug,
      title: post.data.title,
      description: post.data.description,
      category: normalizeCategory(post.data.categories[0] || '') ?? '',
      date: post.data.date.toISOString().slice(0, 10),
    };
  });

const labels = {
  en: { placeholder: 'Search articles…', noResults: 'No results found.', hint: 'Press ESC to close' },
  zh: { placeholder: '搜尋文章…', noResults: '找不到符合的文章。', hint: '按 ESC 關閉' },
};
const label = labels[lang];
---

<!-- Search Modal -->
<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <div class="search-header">
      <div class="search-input-wrap">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder={label.placeholder}
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="search-esc-hint">{label.hint}</kbd>
      </div>
      <button class="search-close" id="search-close" aria-label="Close search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="search-body">
      <ul id="search-results" class="search-results" role="listbox"></ul>
      <p id="search-empty" class="search-empty" hidden>{label.noResults}</p>
    </div>
  </div>
</div>

<script define:vars={{ posts: languagePosts, label }}>
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  const emptyMsg = document.getElementById('search-empty');

  function openModal() {
    modal.hidden = false;
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => input.focus());
  }

  function closeModal() {
    modal.hidden = true;
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
    if (input) input.value = '';
    if (results) results.innerHTML = '';
    if (emptyMsg) emptyMsg.hidden = true;
  }

  document.getElementById('search-trigger')?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal.hidden) openModal();
      else closeModal();
    }
  });

  function render(results_list) {
    if (!results || !emptyMsg) return;
    if (results_list.length === 0) {
      results.innerHTML = '';
      emptyMsg.hidden = false;
      return;
    }
    emptyMsg.hidden = true;
    results.innerHTML = results_list.map(p => `
      <li role="option">
        <a href="/${lang}/blog/${p.slug}" class="search-result-item" onclick="closeModal()">
          <div class="result-meta">
            <span class="result-category">${p.category}</span>
            <span class="result-date">${p.date}</span>
          </div>
          <div class="result-title">${p.title}</div>
          <div class="result-desc">${p.description || ''}</div>
        </a>
      </li>
    `).join('');
  }

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    if (!q) {
      render([]);
      return;
    }
    const filtered = posts.filter(p =>
      p.title.toLowerCase().includes(q) ||
      (p.description && p.description.toLowerCase().includes(q))
    );
    render(filtered);
  });
</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: clamp(48px, 10vh, 120px);
    padding-inline: 16px;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-panel {
    position: relative;
    width: 100%;
    max-width: 620px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.4);
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .search-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0 12px;
    transition: border-color var(--transition-fast);
  }

  .search-input-wrap:focus-within {
    border-color: var(--color-accent);
  }

  .search-icon {
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text);
    padding: 10px 0;
  }

  .search-input::placeholder {
    color: var(--color-muted);
  }

  .search-esc-hint {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2px 6px;
    white-space: nowrap;
  }

  .search-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .search-close:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .search-body {
    max-height: 440px;
    overflow-y: auto;
    padding: 8px;
  }

  .search-results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 14px;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast);
  }

  .search-result-item:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
  }

  .result-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .result-category {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .result-date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
  }

  .result-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .result-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-empty {
    padding: 32px 16px;
    text-align: center;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
</style>
