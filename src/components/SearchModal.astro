---
import { getCollection } from 'astro:content';
import { normalizeCategory, CATEGORY_LABELS, type BlogLang } from '../utils/categories';

export interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

// Category color map (must match CSS --tag-color in global.css)
const CATEGORY_COLORS: Record<string, string> = {
  ai: '#06b6d4',
  openclaw: '#f97316',
  pm: '#6366f1',
  startup: '#ef4444',
  business: '#ec4899',
  web3: '#8b5cf6',
  travel: '#10b981',
  murmurs: '#14b8a6',
};

const allPosts = await getCollection('blog');
const languagePosts = allPosts
  .filter(post => post.id.endsWith(`/${lang}`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const slug = post.id.split('/')[0];
    const catId = normalizeCategory(post.data.categories[0] || '') ?? '';
    const color = CATEGORY_COLORS[catId] ?? '#06b6d4';
    const catLabel = catId ? CATEGORY_LABELS[catId]?.[lang] ?? catId : catId;
    const dateFormatted = new Intl.DateTimeFormat(lang === 'zh' ? 'zh-TW' : 'en-US', {
      year: 'numeric', month: 'short', day: 'numeric',
    }).format(post.data.date);
    return {
      slug,
      title: post.data.title,
      description: post.data.description || '',
      body: (post.body || '').replace(/[#*`\[\]]/g, ' ').slice(0, 2000),
      category: catId,
      catLabel,
      color,
      date: dateFormatted,
    };
  });

const labels = {
  en: { placeholder: 'Search articles…', noResults: 'No results found.' },
  zh: { placeholder: '搜尋文章…', noResults: '找不到符合的文章。' },
};
const label = labels[lang];
const searchPosts = JSON.stringify(languagePosts);
const categoryColors = JSON.stringify(CATEGORY_COLORS);
---

<script is:inline define:vars={{ searchPosts, categoryColors, label, lang }}>
  window.__BLOG_SEARCH__ = {
    posts: JSON.parse(searchPosts),
    colors: JSON.parse(categoryColors),
    label: label,
    lang: lang,
  };
</script>

<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <div class="search-header">
      <div class="search-input-wrap">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder={label.placeholder}
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <button class="search-close" id="search-close" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="search-body">
      <ul id="search-results" class="search-results"></ul>
      <p id="search-empty" class="search-empty">{label.noResults}</p>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var state = window.__BLOG_SEARCH__;
  if (!state) return;

  var posts = state.posts;
  var colors = state.colors;
  var label = state.label;
  var lang = state.lang;

  var modal = document.getElementById('search-modal');
  var backdrop = document.getElementById('search-backdrop');
  var closeBtn = document.getElementById('search-close');
  var input = document.getElementById('search-input');
  var results = document.getElementById('search-results');
  var emptyMsg = document.getElementById('search-empty');

  function isOpen() { return modal && modal.classList.contains('is-open'); }

  function openModal() {
    if (!modal) return;
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    if (input) { input.value = ''; input.focus(); }
    if (results) results.innerHTML = '';
    if (emptyMsg) emptyMsg.style.display = 'none';
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.getElementById('search-trigger').addEventListener('click', openModal);
  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && isOpen()) closeModal();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      isOpen() ? closeModal() : openModal();
    }
  });

  function render(items) {
    if (!results || !emptyMsg) return;
    if (items.length === 0) {
      results.innerHTML = '';
      emptyMsg.style.display = '';
      return;
    }
    emptyMsg.style.display = 'none';
    var html = '';
    for (var i = 0; i < items.length; i++) {
      var p = items[i];
      var color = p.color || '#06b6d4';
      html += '<li class="search-result-item" style="--result-color:' + color + ';">\
        <a href="/' + lang + '/blog/' + p.slug + '" class="result-link">\
          <span class="result-meta">\
            <span class="result-cat">' + p.catLabel + '</span>\
            <span class="result-sep">·</span>\
            <span class="result-date">' + p.date + '</span>\
          </span>\
          <span class="result-title">' + p.title + '</span>\
        </a>\
      </li>';
    }
    results.innerHTML = html;
  }

  if (input) {
    input.addEventListener('input', function () {
      var q = input.value.trim().toLowerCase();
      if (!q) { render([]); return; }
      var filtered = [];
      for (var i = 0; i < posts.length; i++) {
        var p = posts[i];
        if (
          p.title.toLowerCase().indexOf(q) !== -1 ||
          p.description.toLowerCase().indexOf(q) !== -1 ||
          (p.body && p.body.toLowerCase().indexOf(q) !== -1)
        ) {
          filtered.push(p);
        }
      }
      render(filtered);
    });
  }
})();
</script>

<style>
  .search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: flex-start;
    justify-content: center;
    padding-top: clamp(48px, 10vh, 120px);
    padding-inline: 16px;
  }

  .search-modal.is-open {
    display: flex;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-panel {
    position: relative;
    width: 100%;
    max-width: 620px;
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.4);
    backdrop-filter: blur(20px);
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .search-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0 12px;
    transition: border-color 0.15s;
  }

  .search-input-wrap:focus-within {
    border-color: var(--result-color, var(--color-accent));
  }

  .search-icon {
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text);
    padding: 10px 0;
  }

  .search-input::placeholder {
    color: var(--color-muted);
  }

  .search-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.15s;
  }

  .search-close:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .search-body {
    max-height: 420px;
    overflow-y: auto;
    padding: 8px;
  }

  .search-results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .search-result-item {
    border-radius: 10px;
    overflow: hidden;
    transition: background 0.1s;
  }

  .search-result-item:hover {
    background: color-mix(in srgb, var(--result-color, var(--color-accent)) 10%, transparent);
  }

  .result-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-border);
  }

  .search-result-item:last-child .result-link {
    border-bottom: none;
  }

  .result-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
  }

  .result-cat {
    color: var(--result-color, var(--color-accent));
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .result-sep {
    color: var(--color-muted);
  }

  .result-date {
    color: var(--result-color, var(--color-accent));
    opacity: 0.75;
  }

  .result-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.35;
  }

  .search-result-item:hover .result-title {
    color: var(--result-color, var(--color-accent));
  }

  .search-empty {
    padding: 28px 16px;
    text-align: center;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin: 0;
  }
</style>
