  {
    name: 'LINE',
    href: 'https://line.me/ti/p/~danielpieopieo',
    icon: `<img src="/images/line-icon.png" alt="" width="18" height="18" />`,
  },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <p class="footer-brand">danielcanfly.com</p>
      <p class="footer-copy muted">&copy; {year} Daniel. All rights reserved.</p>
    </div>

    <div class="footer-social">
      {socialLinks.map(link => (
        <a
          href={link.href}
          class={`social-link social-link--${link.name.toLowerCase()}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.name}
          set:html={link.icon}
        />
      ))}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-10);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .footer-copy {
    font-size: 0.75rem;
  }

  .footer-social {
    display: flex;
    gap: var(--space-2);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    transition: all var(--transition-fast);
  }

  .social-link--linkedin {
    color: #0A66C2;
  }

  .social-link--whatsapp {
    color: #25D366;
  }

  .social-link:hover {
    transform: translateY(-2px);
  }

  .social-link--linkedin:hover {
    border-color: #0A66C2;
    background: rgba(10, 102, 194, 0.08);
    color: #0A66C2;
  }

  .social-link--whatsapp:hover {
    border-color: #25D366;
    background: rgba(37, 211, 102, 0.08);
    color: #25D366;
  }

  .social-link--line:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
