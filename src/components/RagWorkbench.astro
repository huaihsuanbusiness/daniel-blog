    metricsPolicy: 'Policy',
    metricsResolvedMode: 'Resolved mode',
    metricsLatency: 'Latency',
    metricsSources: 'Sources',
    connected: 'Connected',
    disconnected: 'Issue detected',
  },
  zh: {
    eyebrow: 'Interactive RAG Workbench',
    titleLeadA: '這不只是一篇文章，',
    titleLeadB: '這是一個',
    titleAccent: 'live RAG',
    titleTail: '實驗台。',
    description:
      '你可以問任何關於我的問題，也可以問這個部落格裡提到的任何內容，然後直接看 runtime 怎麼檢索、判斷與回答。',
    statusLoading: '正在確認 runtime 連線…',
    statusReady: 'Live runtime 已連線',
    statusError: 'Live runtime 目前異常',
    statusHint: '目前連到的 endpoint',
    statusLegend: '狀態燈號',
    statusHealthy: '正常',
    statusWarning: '警告',
    statusErrorState: '異常',
    questionLabel: '直接問這個 RAG 一個真實問題',
    questionPlaceholder: '試著問：什麼情況下比較適合 creative mode，而不是 safe mode？',
    exampleLabel: '你可以先試這些問題',
    modeLabel: 'Query mode',
    modeHintAuto: 'Auto 會讓 runtime policy router 自動決定最適合的執行路徑。',
    modeHintManual: '固定 mode 比較適合教學或除錯，因為你能觀察比較可預期的路徑。',
    manualLabel: '進階 Runtime controls',
    manualDescription: '',
