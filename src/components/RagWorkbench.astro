    background:
      radial-gradient(circle at 50% 50%, rgba(255, 248, 230, 0.9) 0%, rgba(224, 171, 98, 0.9) 18%, rgba(176, 111, 40, 0.42) 34%, rgba(176, 111, 40, 0.06) 72%, transparent 74%),
      radial-gradient(circle at 50% 50%, rgba(194, 125, 52, 0.12), transparent 74%);
    box-shadow:
      0 0 0 18px rgba(194, 125, 52, 0.04),
      0 16px 34px rgba(181, 118, 49, 0.16);
  }

  .rag-eyebrow,
  .rag-kicker {
