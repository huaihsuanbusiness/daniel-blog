---
interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const copy = {
  en: {
    eyebrow: 'Interactive RAG Workbench',
    title: 'This isn’t just an article. It’s a live RAG cockpit.',
    description:
      'Ask a real question, let the runtime choose the cheapest safe path, or manually override the retrieval stack when you want to inspect how the system behaves.',
    statusLoading: 'Loading runtime profile…',
    statusReady: 'Live runtime connected',
    statusFallback: 'Auto mode is visible, but the dedicated runtime-policy endpoint is still falling back.',
    questionLabel: 'Ask the RAG a real question',
    questionPlaceholder: 'Try asking how the system decides between fast, safe, creative, deep_eval, and agentic.',
    exampleLabel: 'Good demo prompts',
    modeLabel: 'Query mode',
    modeHintAuto: 'Best for most readers. The system chooses the strategy first, then runs the answer path.',
    modeHintManual: 'Pick a fixed mode when you want a predictable profile for teaching or debugging.',
    manualLabel: 'Advanced runtime controls',
    manualDescription:
      'Turn this on only when you want to override the system. If it stays off, the runtime keeps its own defaults.',
    manualToggle: 'Enable manual overrides',
    manualHelper:
      'Manual overrides are sent explicitly to the API, so they can replace what auto mode or a fixed mode would normally choose.',
    modeAutoTitle: 'Auto',
    workflow: 'Workflow',
    workflowHelp: 'Use the inspectable workflow rail instead of the direct engine path.',
    toolRouting: 'Tool routing',
    toolRoutingHelp: 'Route toward tools or alternate execution paths before answering.',
    retryLoop: 'Retry loop',
    retryLoopHelp: 'Allow reflect-and-retry if the first answer looks weak or mismatched.',
    retrievalMode: 'Retrieval mode',
    retrievalModeHelp: 'Choose between hybrid retrieval and dense-only retrieval.',
    parentExpansion: 'Parent expansion',
    parentExpansionHelp: 'Expand retrieved child chunks back into richer parent context.',
    contextCompression: 'Context compression',
    contextCompressionHelp: 'Compress long context before synthesis to save attention budget.',
    longContextReorder: 'Long-context reorder',
    longContextReorderHelp: 'Re-rank long context so the strongest evidence appears earlier.',
    minScore: 'Minimum score',
    minScoreHelp: 'Drop evidence below this retrieval confidence threshold.',
    maxRetries: 'Max retries',
    maxRetriesHelp: 'Cap how many recovery attempts the runtime may spend on this question.',
    hybrid: 'Hybrid',
    dense: 'Dense only',
    askButton: 'Run this request',
    askingButton: 'Running…',
    resetButton: 'Reset',
    answerLabel: 'Final answer',
    routeLabel: 'Request journey',
    routeEmpty: 'After the first run, this ribbon will show the exact path the request took.',
    policyLabel: 'Automatic policy decision',
    policyEmpty: 'Run a question to inspect which policy the runtime selected and why.',
    plannerLabel: 'Planner view',
    runtimeLabel: 'Runtime guardrails',
    timelineLabel: 'Stage trace',
    timelineEmpty: 'Each recorded stage will appear here after the request finishes.',
    sourcesLabel: 'Retrieved sources',
    sourceEmpty: 'No sources returned yet.',
    rawLabel: 'Raw response',
    failedPrefix: 'Request failed',
    examples: [
      'What query modes does this system support, and when would each one be chosen?',
      'Explain the path from planning to synthesis for this request.',
      'When should I use creative mode instead of safe mode?',
    ],
    emptyAnswer: 'Your answer will appear here after the first run.',
    runningAnswer: 'Calling the live RAG…',
    needsQuestion: 'Please enter a question first.',
    policyLive: 'runtime policy live',
    policyFallback: 'proxy fallback',
    metricsHealth: 'Health',
    metricsModes: 'Modes',
    metricsPolicy: 'Policy',
    metricsTenant: 'Tenant',
    metricsLatency: 'Latency',
    metricsSources: 'Sources',
    metricsStages: 'Trace stages',
    metricsResolvedMode: 'Resolved mode',
  },
  zh: {
    eyebrow: 'Interactive RAG Workbench',
    title: '這不只是一篇文章，這是一個 live RAG 控制台。',
    description:
      '你可以直接問一個真實問題，讓系統先判斷最便宜又安全的路徑，或在需要教學、除錯時手動覆寫 retrieval 與 runtime 控制。',
    statusLoading: '正在載入 runtime profile…',
    statusReady: 'Live runtime 已連線',
    statusFallback: '目前已顯示 auto mode，但正式 runtime-policy endpoint 還在 fallback 狀態。',
    questionLabel: '直接問這個 RAG 一個真實問題',
    questionPlaceholder: '試著問：系統會怎麼在 fast、safe、creative、deep_eval、agentic 之間做選擇？',
    exampleLabel: '你可以先試這些問題',
    modeLabel: 'Query mode',
    modeHintAuto: '最適合一般讀者。系統會先決定策略，再走後續回答路徑。',
    modeHintManual: '如果你想教學或除錯，就選固定 mode 來觀察一條比較可預期的路徑。',
    manualLabel: '進階 Runtime controls',
    manualDescription:
      '只有在你想覆寫系統判斷時才需要打開。維持關閉時，runtime 會沿用自己的預設策略。',
    manualToggle: '啟用手動覆寫',
    manualHelper:
      '一旦你開啟手動覆寫，這些欄位會被明確送到 API，所以它們可能會取代 auto mode 或固定 mode 原本會自動選的設定。',
    modeAutoTitle: 'Auto',
    workflow: 'Workflow',
    workflowHelp: '改走可觀察的 workflow rail，而不是直接 engine path。',
    toolRouting: 'Tool routing',
    toolRoutingHelp: '先判斷要不要走工具或其他執行路徑，再開始回答。',
    retryLoop: 'Retry loop',
    retryLoopHelp: '如果第一版答案看起來不夠好，允許系統反思後再試一次。',
    retrievalMode: 'Retrieval mode',
    retrievalModeHelp: '選擇 hybrid 檢索，或只用 dense vector 檢索。',
    parentExpansion: 'Parent expansion',
    parentExpansionHelp: '把命中的 child chunk 展開回更完整的 parent context。',
    contextCompression: 'Context compression',
    contextCompressionHelp: '在 synthesis 前先壓縮長上下文，節省注意力預算。',
    longContextReorder: 'Long-context reorder',
    longContextReorderHelp: '重新排序長上下文，讓最關鍵證據更早被模型看到。',
    minScore: 'Minimum score',
    minScoreHelp: '低於這個檢索分數的證據，系統就不應太信任。',
    maxRetries: 'Max retries',
    maxRetriesHelp: '限制這題最多可以花多少次重試機會。',
    hybrid: 'Hybrid',
    dense: 'Dense only',
    askButton: '送出這次查詢',
    askingButton: '執行中…',
    resetButton: '重設',
    answerLabel: '最終回答',
    routeLabel: '這次請求的旅程',
    routeEmpty: '送出第一個問題後，這裡會把這次請求實際經過的路徑攤開給你看。',
    policyLabel: '自動策略判斷',
    policyEmpty: '送出一個問題後，這裡會顯示 runtime 最後選了什麼策略，以及為什麼。',
    plannerLabel: 'Planner 視角',
    runtimeLabel: 'Runtime guardrails',
    timelineLabel: '逐階段 trace',
    timelineEmpty: '每個被記錄的 stage，都會在查詢完成後出現在這裡。',
    sourcesLabel: '這次取回的 sources',
    sourceEmpty: '目前還沒有來源。',
    rawLabel: 'Raw response',
    failedPrefix: '請求失敗',
    examples: [
      '這套系統有哪些 query modes？系統會在什麼情況下自動選它們？',
      '幫我解釋這次 request 從 planning 到 synthesis 之間發生了什麼。',
      '什麼情況下比較適合 creative mode，而不是 safe mode？',
    ],
    emptyAnswer: '送出第一個問題之後，回答會出現在這裡。',
    runningAnswer: '正在請求 live RAG…',
    needsQuestion: '請先輸入問題。',
    policyLive: 'runtime policy 已上線',
    policyFallback: '目前仍是 proxy fallback',
    metricsHealth: 'Health',
    metricsModes: 'Modes',
    metricsPolicy: 'Policy',
    metricsTenant: 'Tenant',
    metricsLatency: 'Latency',
    metricsSources: 'Sources',
    metricsStages: 'Trace stages',
    metricsResolvedMode: 'Resolved mode',
  },
}[lang];
---

<section class="rag-lab" data-rag-lab data-lang={lang}>
  <div class="rag-lab-shell">
    <div class="rag-orb rag-orb-a"></div>
    <div class="rag-orb rag-orb-b"></div>

    <header class="rag-hero">
      <div class="rag-hero-copy">
        <p class="rag-eyebrow">{copy.eyebrow}</p>
        <h2 class="rag-title">{copy.title}</h2>
        <p class="rag-description">{copy.description}</p>
      </div>

      <div class="rag-status-card">
        <div class="rag-status-row" data-rag-status>
          <span class="rag-status-dot"></span>
          <span>{copy.statusLoading}</span>
        </div>
        <p class="rag-status-note" data-rag-status-note></p>
      </div>
    </header>

    <div class="rag-grid">
      <aside class="rag-sidebar">
        <section class="rag-panel rag-panel-soft">
          <label class="rag-label" for="rag-question">{copy.questionLabel}</label>
          <textarea id="rag-question" class="rag-question" rows="6" placeholder={copy.questionPlaceholder}></textarea>

          <div class="rag-example-block">
            <p class="rag-kicker">{copy.exampleLabel}</p>
            <div class="rag-chip-row">
              {copy.examples.map((prompt) => (
                <button type="button" class="rag-chip" data-rag-example={prompt}>{prompt}</button>
              ))}
            </div>
          </div>
        </section>

        <section class="rag-panel">
          <div class="rag-section-headline">
            <div>
              <p class="rag-kicker">{copy.modeLabel}</p>
              <h3 class="rag-subtitle">{copy.modeLabel}</h3>
            </div>
            <span class="rag-pill" data-rag-mode-state>{copy.modeAutoTitle}</span>
          </div>
          <p class="rag-helper" data-rag-mode-helper>{copy.modeHintAuto}</p>
          <div class="rag-mode-grid" data-rag-modes></div>
          <div class="rag-mode-note" data-rag-mode-note></div>
        </section>

        <section class="rag-panel">
          <div class="rag-section-headline">
            <div>
              <p class="rag-kicker">{copy.manualLabel}</p>
              <h3 class="rag-subtitle">{copy.manualLabel}</h3>
            </div>
            <label class="rag-switch rag-switch-master">
              <input type="checkbox" data-rag-manual-enabled />
              <span class="rag-switch-track"></span>
              <span class="rag-switch-text">{copy.manualToggle}</span>
            </label>
          </div>
          <p class="rag-helper">{copy.manualDescription}</p>
          <p class="rag-callout" data-rag-manual-helper>{copy.manualHelper}</p>

          <div class="rag-override-list" data-rag-manual-fields>
            <article class="rag-override-card">
              <div>
                <h4>{copy.workflow}</h4>
                <p>{copy.workflowHelp}</p>
              </div>
              <label class="rag-switch">
                <input type="checkbox" data-rag-field="use_workflow" />
                <span class="rag-switch-track"></span>
              </label>
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.toolRouting}</h4>
                <p>{copy.toolRoutingHelp}</p>
              </div>
              <label class="rag-switch">
                <input type="checkbox" data-rag-field="use_tool_routing" />
                <span class="rag-switch-track"></span>
              </label>
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.retryLoop}</h4>
                <p>{copy.retryLoopHelp}</p>
              </div>
              <label class="rag-switch">
                <input type="checkbox" data-rag-field="use_retry_loop" />
                <span class="rag-switch-track"></span>
              </label>
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.retrievalMode}</h4>
                <p>{copy.retrievalModeHelp}</p>
              </div>
              <select class="rag-select" data-rag-field="retrieval_mode">
                <option value="hybrid">{copy.hybrid}</option>
                <option value="dense">{copy.dense}</option>
              </select>
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.parentExpansion}</h4>
                <p>{copy.parentExpansionHelp}</p>
              </div>
              <label class="rag-switch">
                <input type="checkbox" data-rag-field="use_parent_expansion" />
                <span class="rag-switch-track"></span>
              </label>
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.contextCompression}</h4>
                <p>{copy.contextCompressionHelp}</p>
              </div>
              <label class="rag-switch">
                <input type="checkbox" data-rag-field="use_context_compression" />
                <span class="rag-switch-track"></span>
              </label>
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.longContextReorder}</h4>
                <p>{copy.longContextReorderHelp}</p>
              </div>
              <label class="rag-switch">
                <input type="checkbox" data-rag-field="use_long_context_reorder" />
                <span class="rag-switch-track"></span>
              </label>
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.minScore}</h4>
                <p>{copy.minScoreHelp}</p>
              </div>
              <input class="rag-number" type="number" min="0" max="1" step="0.01" data-rag-field="min_score" />
            </article>

            <article class="rag-override-card">
              <div>
                <h4>{copy.maxRetries}</h4>
                <p>{copy.maxRetriesHelp}</p>
              </div>
              <input class="rag-number" type="number" min="0" max="5" step="1" data-rag-field="max_retries" />
            </article>
          </div>

          <div class="rag-actions">
            <button type="button" class="rag-primary" data-rag-submit>{copy.askButton}</button>
            <button type="button" class="rag-secondary" data-rag-reset>{copy.resetButton}</button>
          </div>
        </section>
      </aside>

      <div class="rag-main">
        <div class="rag-metric-strip" data-rag-metrics></div>

        <section class="rag-panel rag-panel-featured">
          <div class="rag-section-headline">
            <div>
              <p class="rag-kicker">{copy.answerLabel}</p>
              <h3 class="rag-subtitle">{copy.answerLabel}</h3>
            </div>
          </div>
          <div class="rag-answer" data-rag-answer>{copy.emptyAnswer}</div>
        </section>

        <section class="rag-panel">
          <div class="rag-section-headline">
            <div>
              <p class="rag-kicker">{copy.routeLabel}</p>
              <h3 class="rag-subtitle">{copy.routeLabel}</h3>
            </div>
          </div>
          <div class="rag-route" data-rag-route>{copy.routeEmpty}</div>
        </section>

        <div class="rag-dual-grid">
          <section class="rag-panel">
            <div class="rag-section-headline">
              <div>
                <p class="rag-kicker">{copy.policyLabel}</p>
                <h3 class="rag-subtitle">{copy.policyLabel}</h3>
              </div>
            </div>
            <div class="rag-card-list" data-rag-policy>{copy.policyEmpty}</div>
          </section>

          <section class="rag-panel">
            <div class="rag-section-headline">
              <div>
                <p class="rag-kicker">{copy.runtimeLabel}</p>
                <h3 class="rag-subtitle">{copy.runtimeLabel}</h3>
              </div>
            </div>
            <div class="rag-card-list" data-rag-runtime></div>
          </section>
        </div>

        <div class="rag-dual-grid">
          <section class="rag-panel">
            <div class="rag-section-headline">
              <div>
                <p class="rag-kicker">{copy.plannerLabel}</p>
                <h3 class="rag-subtitle">{copy.plannerLabel}</h3>
              </div>
            </div>
            <div class="rag-card-list" data-rag-plan></div>
          </section>

          <section class="rag-panel">
            <div class="rag-section-headline">
              <div>
                <p class="rag-kicker">{copy.timelineLabel}</p>
                <h3 class="rag-subtitle">{copy.timelineLabel}</h3>
              </div>
            </div>
            <div class="rag-timeline" data-rag-timeline>{copy.timelineEmpty}</div>
          </section>
        </div>

        <section class="rag-panel">
          <div class="rag-section-headline">
            <div>
              <p class="rag-kicker">{copy.sourcesLabel}</p>
              <h3 class="rag-subtitle">{copy.sourcesLabel}</h3>
            </div>
          </div>
          <div class="rag-sources" data-rag-sources>{copy.sourceEmpty}</div>
        </section>

        <details class="rag-raw">
          <summary>{copy.rawLabel}</summary>
          <pre data-rag-raw></pre>
        </details>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ lang, copy }} type="module">
  const root = document.querySelector('[data-rag-lab]');

  if (root) {
    const AUTO_MODE = 'auto';
    const FALLBACK_MODES = ['auto', 'fast', 'safe', 'creative', 'deep_eval', 'agentic'];

    const state = {
      bootstrap: null,
      selectedMode: AUTO_MODE,
      manualOverridesEnabled: false,
    };

    const elements = {
      status: root.querySelector('[data-rag-status]'),
      statusNote: root.querySelector('[data-rag-status-note]'),
      question: root.querySelector('#rag-question'),
      modes: root.querySelector('[data-rag-modes]'),
      modeNote: root.querySelector('[data-rag-mode-note]'),
      modeHelper: root.querySelector('[data-rag-mode-helper]'),
      modeState: root.querySelector('[data-rag-mode-state]'),
      manualEnabled: root.querySelector('[data-rag-manual-enabled]'),
      manualFields: Array.from(root.querySelectorAll('[data-rag-field]')),
      manualHelper: root.querySelector('[data-rag-manual-helper]'),
      metrics: root.querySelector('[data-rag-metrics]'),
      answer: root.querySelector('[data-rag-answer]'),
      route: root.querySelector('[data-rag-route]'),
      policy: root.querySelector('[data-rag-policy]'),
      runtime: root.querySelector('[data-rag-runtime]'),
      plan: root.querySelector('[data-rag-plan]'),
      timeline: root.querySelector('[data-rag-timeline]'),
      sources: root.querySelector('[data-rag-sources]'),
      raw: root.querySelector('[data-rag-raw]'),
      submit: root.querySelector('[data-rag-submit]'),
      reset: root.querySelector('[data-rag-reset]'),
    };

    const defaultQuestion = copy.examples[0];
    elements.question.value = defaultQuestion;

    const escapeHtml = (value) =>
      String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatMaybe = (value) => {
      if (value === null || value === undefined || value === '') return '—';
      if (typeof value === 'boolean') return value ? 'true' : 'false';
      if (typeof value === 'number' && Number.isFinite(value)) return String(value);
      return String(value);
    };

    const formatLatency = (value) => {
      if (typeof value !== 'number' || Number.isNaN(value)) return '—';
      return `${value >= 100 ? value.toFixed(0) : value.toFixed(1)} ms`;
    };

    const getProfileMeta = (mode) => {
      const profiles = state.bootstrap?.queryProfiles || {};
      if (mode === AUTO_MODE) return profiles.auto_mode || null;
      return profiles.profiles?.[mode] || null;
    };

    const getModeDescription = (mode) => getProfileMeta(mode)?.description || '';

    const updateManualState = () => {
      elements.manualEnabled.checked = state.manualOverridesEnabled;
      elements.manualFields.forEach((field) => {
        field.disabled = !state.manualOverridesEnabled;
      });
      elements.manualHelper.textContent = state.manualOverridesEnabled
        ? copy.manualHelper
        : copy.manualDescription;
    };

    const stageSummary = (stage) => {
      if (!stage) return '';
      const output = stage.output || {};
      const metadata = stage.metadata || {};
      switch (stage.name) {
        case 'planner':
          return metadata.route_reason || output.rewritten_question || '';
        case 'retrieval':
          return `${output.output_count ?? 0} source(s) via ${metadata.retrieval_mode || 'rag'}`;
        case 'parent_expansion':
          return `${output.source_count ?? 0} expanded source(s)`;
        case 'context_compression':
          return metadata.enabled ? `Compressed ${metadata.compressed_sources ?? 0} source(s)` : 'Compression off';
        case 'synthesis':
          return metadata.diagnostics?.deterministic_reason || metadata.model || `Answer chars: ${metadata.answer_chars ?? '—'}`;
        case 'citation_check':
          return `score ${formatMaybe(output.score)} / passed ${formatMaybe(output.passed)}`;
        case 'reflect_retry':
          return `retry decision: ${metadata.retry_decision || output.retry_decision || 'n/a'}`;
        case 'engine.ask':
          return `${output.source_count ?? 0} source(s), ${output.answer_chars ?? 0} chars`;
        default:
          return JSON.stringify(output || metadata).slice(0, 140);
      }
    };

    const routeSummary = (response) => {
      const policy = response.runtime_policy_router || {};
      const resolved = policy.resolved || {};
      const chips = [];
      chips.push(response.query_profile?.mode || resolved.query_mode || state.selectedMode);
      chips.push(response.filters?.retrieval_mode || resolved.retrieval_mode || 'hybrid');
      chips.push((response.workflow?.enabled || resolved.use_workflow) ? 'workflow:on' : 'workflow:off');
      chips.push((response.tool_routing?.enabled || resolved.use_tool_routing) ? `route:${response.tool_routing?.route || resolved.tool_route || 'tool'}` : 'route:rag');
      chips.push((response.retry_loop?.enabled || resolved.use_retry_loop) ? `retry:${response.retry_loop?.retry_attempt_count ?? 0}` : 'retry:off');
      return chips.map((chip) => `<span class="rag-path-chip">${escapeHtml(chip)}</span>`).join('');
    };

    const renderModes = () => {
      const queryProfiles = state.bootstrap?.queryProfiles;
      const supportedModes = queryProfiles?.supported_modes || FALLBACK_MODES;

      elements.modes.innerHTML = supportedModes
        .map((mode) => {
          const meta = getProfileMeta(mode) || {};
          const active = mode === state.selectedMode;
          const cost = meta.cost_tier || (mode === AUTO_MODE ? 'adaptive' : 'n/a');
          const title = mode === AUTO_MODE ? copy.modeAutoTitle : mode;
          return `
            <button type="button" class="rag-mode-card ${active ? 'is-active' : ''}" data-rag-mode="${escapeHtml(mode)}">
              <span class="rag-mode-top">
                <strong>${escapeHtml(title)}</strong>
                <span>${escapeHtml(cost)}</span>
              </span>
              <p>${escapeHtml(getModeDescription(mode) || '')}</p>
            </button>
          `;
        })
        .join('');

      elements.modeNote.textContent = getModeDescription(state.selectedMode) || '';
      elements.modeHelper.textContent = state.selectedMode === AUTO_MODE ? copy.modeHintAuto : copy.modeHintManual;
      elements.modeState.textContent = state.selectedMode === AUTO_MODE ? copy.modeAutoTitle : state.selectedMode;

      elements.modes.querySelectorAll('[data-rag-mode]').forEach((button) => {
        button.addEventListener('click', () => {
          state.selectedMode = button.getAttribute('data-rag-mode') || AUTO_MODE;
          renderModes();
        });
      });
    };

    const renderMetrics = (payload = null) => {
      const healthy = state.bootstrap?.health?.status === 'ok';
      const runtimePolicyLive = Boolean(state.bootstrap?.capabilities?.runtimePolicyEndpoint);
      const observedLatency = payload?.runtime_budget?.postrun?.observed?.latency_ms;
      const sourcesCount = (payload?.sources || []).length;
      const stagesCount = (payload?.observability?.stage_names || []).length;
      const resolvedMode = payload?.query_profile?.mode || state.selectedMode;

      elements.metrics.innerHTML = `
        <article class="rag-metric-card">
          <span>${copy.metricsHealth}</span>
          <strong>${healthy ? 'ok' : 'check'}</strong>
        </article>
        <article class="rag-metric-card">
          <span>${copy.metricsPolicy}</span>
          <strong>${runtimePolicyLive ? copy.policyLive : copy.policyFallback}</strong>
        </article>
        <article class="rag-metric-card">
          <span>${payload ? copy.metricsResolvedMode : copy.metricsModes}</span>
          <strong>${escapeHtml(payload ? resolvedMode : String((state.bootstrap?.queryProfiles?.supported_modes || FALLBACK_MODES).length))}</strong>
        </article>
        <article class="rag-metric-card">
          <span>${payload ? copy.metricsLatency : copy.metricsTenant}</span>
          <strong>${escapeHtml(payload ? formatLatency(observedLatency) : state.bootstrap?.proxy?.tenantId || '—')}</strong>
        </article>
        ${payload ? `
          <article class="rag-metric-card">
            <span>${copy.metricsSources}</span>
            <strong>${escapeHtml(String(sourcesCount))}</strong>
          </article>
          <article class="rag-metric-card">
            <span>${copy.metricsStages}</span>
            <strong>${escapeHtml(String(stagesCount))}</strong>
          </article>
        ` : ''}
      `;
    };

    const renderBootstrapState = () => {
      const healthy = state.bootstrap?.health?.status === 'ok';
      const runtimePolicyLive = Boolean(state.bootstrap?.capabilities?.runtimePolicyEndpoint);

      elements.status.innerHTML = `
        <span class="rag-status-dot ${healthy ? 'is-healthy' : 'is-bad'}"></span>
        <span>${healthy ? copy.statusReady : 'API needs attention'}</span>
      `;
      elements.statusNote.textContent = runtimePolicyLive ? state.bootstrap?.proxy?.apiBaseUrl || '' : copy.statusFallback;
      renderModes();
      renderMetrics();
    };

    const renderPolicy = (response) => {
      const policy = response.runtime_policy_router || {};
      const resolved = policy.resolved || {};
      const explanation = escapeHtml(policy.user_explanation || policy.reasoning || copy.policyEmpty);
      const badges = [
        resolved.query_mode || response.query_profile?.mode || 'safe',
        resolved.use_workflow ? 'workflow:on' : 'workflow:off',
        resolved.use_tool_routing ? `route:${resolved.tool_route || 'tool'}` : 'route:rag',
        resolved.use_retry_loop ? 'retry:on' : 'retry:off',
      ];

      elements.policy.innerHTML = `
        <article class="rag-policy-card">
          <p class="rag-policy-lead">${explanation}</p>
          <div class="rag-route">${badges.map((badge) => `<span class="rag-path-chip">${escapeHtml(badge)}</span>`).join('')}</div>
          <div class="rag-policy-meta">
            <div><span>Implementation</span><strong>${escapeHtml(policy.implementation || policy.fallback || '—')}</strong></div>
            <div><span>Confidence</span><strong>${escapeHtml(formatMaybe(policy.confidence))}</strong></div>
            <div><span>Tool route</span><strong>${escapeHtml(resolved.tool_route || response.tool_routing?.route || 'rag_search')}</strong></div>
          </div>
        </article>
      `;
    };

    const renderPlan = (response) => {
      const plan = response.plan || {};
      elements.plan.innerHTML = `
        <article class="rag-mini-card"><span>Original</span><strong>${escapeHtml(plan.original_question || '—')}</strong></article>
        <article class="rag-mini-card"><span>Rewritten</span><strong>${escapeHtml(plan.rewritten_question || '—')}</strong></article>
        <article class="rag-mini-card"><span>Route reason</span><strong>${escapeHtml(plan.route_reason || '—')}</strong></article>
        <article class="rag-mini-card"><span>Rewrite reason</span><strong>${escapeHtml(plan.rewrite_reason || '—')}</strong></article>
      `;
    };

    const renderRuntime = (response) => {
      const budget = response.runtime_budget || {};
      const retry = response.retry_loop || {};
      const flags = response.query_profile?.resolved_flags || {};
      elements.runtime.innerHTML = `
        <article class="rag-mini-card"><span>Workflow</span><strong>${escapeHtml(response.workflow?.enabled ? 'enabled' : 'disabled')}</strong></article>
        <article class="rag-mini-card"><span>Tool route</span><strong>${escapeHtml(response.tool_routing?.route || 'rag_search')}</strong></article>
        <article class="rag-mini-card"><span>Retry attempts</span><strong>${escapeHtml(retry.retry_attempt_count ?? 0)}</strong></article>
        <article class="rag-mini-card"><span>Latency budget</span><strong>${escapeHtml(String(budget.limits?.max_latency_ms ?? '—'))} ms</strong></article>
        <article class="rag-mini-card"><span>Retrieval mode</span><strong>${escapeHtml(flags.retrieval_mode || response.filters?.retrieval_mode || 'hybrid')}</strong></article>
        <article class="rag-mini-card"><span>Min score</span><strong>${escapeHtml(formatMaybe(response.filters?.min_score ?? flags.min_score ?? '—'))}</strong></article>
      `;
    };

    const renderTimeline = (response) => {
      const stages = response.observability?.stages || [];
      if (!stages.length) {
        elements.timeline.textContent = copy.timelineEmpty;
        return;
      }

      elements.timeline.innerHTML = stages
        .map((stage) => `
          <article class="rag-stage-card">
            <div class="rag-stage-head">
              <strong>${escapeHtml(stage.name || 'stage')}</strong>
              <span>${escapeHtml(formatLatency(stage.latency_ms))}</span>
            </div>
            <p>${escapeHtml(stageSummary(stage))}</p>
          </article>
        `)
        .join('');
    };

    const renderSources = (response) => {
      const sources = response.sources || [];
      if (!sources.length) {
        elements.sources.textContent = copy.sourceEmpty;
        return;
      }

      elements.sources.innerHTML = sources
        .slice(0, 6)
        .map((source, index) => `
          <article class="rag-source-card">
            <div class="rag-source-head">
              <strong>${escapeHtml(source.file_name || source.metadata?.file_name || `Source ${index + 1}`)}</strong>
              <span>${escapeHtml(source.marker || source.citation_marker || `#${index + 1}`)}</span>
            </div>
            <p class="rag-source-meta">score ${escapeHtml(formatMaybe(source.score))} · ${escapeHtml(source.metadata?.document_type || source.metadata?.file_type || 'source')}</p>
            <p class="rag-source-preview">${escapeHtml(source.preview || source.text || '').slice(0, 280)}</p>
          </article>
        `)
        .join('');
    };

    const renderResponse = (response) => {
      elements.answer.textContent = response.answer || '';
      elements.route.innerHTML = routeSummary(response);
      elements.raw.textContent = JSON.stringify(response, null, 2);
      renderPolicy(response);
      renderPlan(response);
      renderRuntime(response);
      renderTimeline(response);
      renderSources(response);
      renderMetrics(response);
    };

    const renderError = async (response) => {
      const payload = await response.json().catch(() => ({}));
      elements.answer.textContent = `${copy.failedPrefix}: ${payload?.detail?.message || payload?.detail || payload?.error || response.statusText}`;
      elements.route.textContent = copy.routeEmpty;
      elements.policy.textContent = copy.policyEmpty;
      elements.plan.innerHTML = '';
      elements.runtime.innerHTML = '';
      elements.timeline.textContent = copy.timelineEmpty;
      elements.sources.textContent = copy.sourceEmpty;
      elements.raw.textContent = JSON.stringify(payload, null, 2);
      renderMetrics();
    };

    const coerceNumber = (value, { min = -Infinity, max = Infinity, integer = false } = {}) => {
      if (value === '' || value === null || value === undefined) return null;
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return null;
      const candidate = integer ? Math.trunc(numeric) : numeric;
      if (candidate < min || candidate > max) return null;
      return candidate;
    };

    const getPayload = () => {
      const payload = {
        question: elements.question.value.trim(),
        query_mode: state.selectedMode,
        use_runtime_policy_router: state.selectedMode === AUTO_MODE,
      };

      if (state.manualOverridesEnabled) {
        for (const field of elements.manualFields) {
          const key = field.getAttribute('data-rag-field');
          if (!key) continue;

          if (field.type === 'checkbox') {
            payload[key] = Boolean(field.checked);
          } else if (key === 'min_score') {
            const value = coerceNumber(field.value, { min: 0, max: 1 });
            if (value !== null) payload[key] = value;
          } else if (key === 'max_retries') {
            const value = coerceNumber(field.value, { min: 0, max: 5, integer: true });
            if (value !== null) payload[key] = value;
          } else if (field.value) {
            payload[key] = field.value;
          }
        }
      }

      return payload;
    };

    const setLoading = (loading) => {
      elements.submit.disabled = loading;
      elements.reset.disabled = loading;
      elements.manualEnabled.disabled = loading;
      elements.manualFields.forEach((field) => {
        field.disabled = loading || !state.manualOverridesEnabled;
      });
      elements.question.disabled = loading;
      elements.submit.textContent = loading ? copy.askingButton : copy.askButton;
    };

    const resetDefaults = () => {
      const defaults = state.bootstrap?.defaults || {};
      state.selectedMode = defaults.query_mode || AUTO_MODE;
      state.manualOverridesEnabled = false;
      elements.question.value = defaultQuestion;

      for (const field of elements.manualFields) {
        const key = field.getAttribute('data-rag-field');
        if (!key) continue;
        const value = defaults[key];
        if (field.type === 'checkbox') {
          field.checked = Boolean(value);
        } else if (value === null || value === undefined) {
          field.value = '';
        } else {
          field.value = String(value);
        }
      }

      updateManualState();
      renderModes();
      renderMetrics();
    };

    root.querySelectorAll('[data-rag-example]').forEach((button) => {
      button.addEventListener('click', () => {
        elements.question.value = button.getAttribute('data-rag-example') || '';
      });
    });

    elements.manualEnabled.addEventListener('change', () => {
      state.manualOverridesEnabled = elements.manualEnabled.checked;
      updateManualState();
    });

    elements.reset.addEventListener('click', resetDefaults);

    elements.submit.addEventListener('click', async () => {
      const payload = getPayload();
      if (!payload.question) {
        elements.answer.textContent = copy.needsQuestion;
        return;
      }

      setLoading(true);
      elements.answer.textContent = copy.runningAnswer;
      elements.route.textContent = '';
      elements.policy.textContent = copy.policyEmpty;
      elements.plan.innerHTML = '';
      elements.runtime.innerHTML = '';
      elements.timeline.textContent = copy.timelineEmpty;
      elements.sources.textContent = copy.sourceEmpty;

      try {
        const response = await fetch('/api/rag/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          await renderError(response);
        } else {
          renderResponse(await response.json());
        }
      } catch (error) {
        elements.answer.textContent = `${copy.failedPrefix}: ${String(error)}`;
      } finally {
        setLoading(false);
      }
    });

    try {
      const bootstrapResponse = await fetch('/api/rag/bootstrap');
      const bootstrapData = await bootstrapResponse.json();
      if (!bootstrapResponse.ok || !bootstrapData.ok) {
        throw new Error(bootstrapData.error || 'Failed to load bootstrap data');
      }
      state.bootstrap = bootstrapData;
      resetDefaults();
      renderBootstrapState();
    } catch (error) {
      elements.status.innerHTML = `
        <span class="rag-status-dot is-bad"></span>
        <span>${escapeHtml(String(error))}</span>
      `;
      elements.statusNote.textContent = '';
    }
  }
</script>

