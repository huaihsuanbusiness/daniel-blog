    workflowHelp: '改走可觀察的 workflow rail，而不是直接的 engine path。',
    toolRouting: 'Tool routing',
    toolRoutingHelp: '先判斷要不要走工具或其他執行路徑，再開始回答。',
    retryLoop: 'Retry loop',
    retryLoopHelp: '如果第一版答案看起來不夠好，允許系統反思後再試一次。',
    retrievalMode: 'Retrieval mode',
    retrievalModeHelp: '選擇 hybrid 檢索，或只用 dense vector 檢索。',
    parentExpansion: 'Parent expansion',
    parentExpansionHelp: '把命中的 child chunk 展開回更完整的 parent context。',
    contextCompression: 'Context compression',
    contextCompressionHelp: '在 synthesis 前先壓縮長上下文，節省注意力預算。',
    longContextReorder: 'Long-context reorder',
    longContextReorderHelp: '重新排序長上下文，讓最重要的證據更早被模型看到。',
    minScore: 'Minimum score',
    minScoreHelp: '低於這個檢索分數的證據，就不應太信任。',
    maxRetries: 'Max retries',
    maxRetriesHelp: '限制這題最多可以花多少次重試機會。',
    hybrid: 'Hybrid',
    dense: 'Dense only',
    askButton: '送出這次查詢',
    askingButton: '執行中…',
    resetButton: '重設',
    answerLabel: '最終回答',
    routeLabel: '這次請求的旅程',
    routeEmpty: '送出第一個問題後，這裡會顯示這趟請求實際走過的路徑。',
    policyLabel: '自動策略判斷',
    policyEmpty: '送出問題後，這裡會顯示 runtime 最後選了什麼策略，以及為什麼。',
    plannerLabel: 'Planner 視角',
    plannerEmpty: '—',
    runtimeLabel: 'Runtime guardrails',
    runtimeEmpty: '這裡會固定顯示 guardrails、retry budget 與 retrieval controls。',
    timelineLabel: '逐階段 trace',
    timelineEmpty: '每個被記錄的 stage，都會在查詢完成後出現在這裡。',
    traceExpand: '檢視完整 Trace',
    traceCollapse: '收合 Trace',
    sourcesLabel: '這次取回的 sources',
    sourceEmpty: '目前還沒有來源。',
    sourcesExpand: '檢視更多來源',
    sourcesCollapse: '顯示較少來源',
    rawLabel: 'Raw response',
    failedPrefix: '請求失敗',
    examples: [
      '什麼情況下比較適合 creative mode，而不是 safe mode？',
      '幫我解釋這次 request 從 planning 到 synthesis 之間發生了什麼。',
      '這次的 policy routing 與 retrieval 分別做了哪些事？',
    ],
    emptyAnswer: '送出第一個問題之後，回答會出現在這裡。',
    runningAnswer: '正在請求 live RAG…',
    needsQuestion: '請先輸入問題。',
    policyLive: 'runtime policy 已上線',
    policyFallback: '目前仍是 proxy fallback',
    metricsHealth: 'Health',
    metricsPolicy: 'Policy',
    metricsResolvedMode: 'Resolved mode',
    metricsLatency: 'Latency',
    metricsSources: 'Sources',
    connected: '已連線',
    disconnected: '需檢查',
  },
}[lang];
---

<section class="rag-lab" data-rag-lab data-lang={lang}>
  <div class="rag-shell">
    <div class="rag-atmosphere rag-atmosphere-a"></div>
    <div class="rag-atmosphere rag-atmosphere-b"></div>

    <header class="rag-hero">
      <div class="rag-hero-copy">
        <div class="rag-hero-mark" aria-hidden="true"></div>
        <p class="rag-eyebrow">{copy.eyebrow}</p>
        <h2 class:list={['rag-title', lang === 'zh' && 'is-zh']}>
          {lang === 'zh' ? (
            <>
              <span>{copy.titleLeadA}</span>
              <span>{copy.titleLeadB} <em>{copy.titleAccent}</em> {copy.titleTail}</span>
            </>
          ) : (
            <>
              <span>{copy.titleLeadA}</span>
              <span>{copy.titleLeadB}</span>
              <span>{copy.titleLeadC} <em>{copy.titleAccent}</em> {copy.titleTail}</span>
            </>
          )}
        </h2>
        <p class="rag-description">{copy.description}</p>
      </div>

      <aside class="rag-runtime-plaque">
        <div class="rag-runtime-frame" aria-hidden="true"></div>
        <div class="rag-runtime-head">
          <span class="rag-signal-dot" data-rag-signal></span>
          <div>
            <p class="rag-runtime-label" data-rag-status>{copy.statusLoading}</p>
          </div>
        </div>
        <p class="rag-runtime-endpoint" data-rag-status-note></p>
        <div class="rag-runtime-badge" aria-hidden="true">
          <span class="rag-runtime-badge-ring"></span>
          <span class="rag-runtime-badge-core"></span>
        </div>
      </aside>
      <div class="rag-runtime-legend" aria-hidden="true">
        <span class="rag-runtime-legend-label">{copy.statusLegend}:</span>
        <span class="rag-runtime-legend-item"><i class="rag-runtime-led rag-runtime-led-green"></i>{copy.statusHealthy}</span>
        <span class="rag-runtime-legend-item"><i class="rag-runtime-led rag-runtime-led-amber"></i>{copy.statusWarning}</span>
        <span class="rag-runtime-legend-item"><i class="rag-runtime-led rag-runtime-led-red"></i>{copy.statusErrorState}</span>
      </div>
    </header>

    <section class="rag-telemetry-ribbon" data-rag-metrics>
      <article class="rag-metric-card rag-metric-card-health">
        <span class="rag-metric-icon rag-metric-icon-health" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20s-6.5-4.35-8.7-8.18C1.6 8.78 3.1 5 6.35 5c2.02 0 3.08 1.14 3.69 2.21C10.66 6.14 11.71 5 13.73 5 17 5 18.48 8.79 16.8 11.82 14.58 15.65 12 20 12 20Z" />
          </svg>
        </span>
        <div class="rag-metric-copy">
        <span>{copy.metricsHealth}</span>
        <strong data-rag-metric-health>OK</strong>
        </div>
      </article>
      <article class="rag-metric-card rag-metric-card-policy">
        <span class="rag-metric-icon rag-metric-icon-policy" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l6 2.7v5.9c0 4.14-2.63 7.78-6 9.4-3.37-1.62-6-5.26-6-9.4V5.7L12 3Z" />
            <path d="m9.6 11.8 1.6 1.7 3.4-3.8" />
          </svg>
        </span>
        <div class="rag-metric-copy">
        <span>{copy.metricsPolicy}</span>
        <strong data-rag-metric-policy>{copy.policyFallback}</strong>
        </div>
      </article>
      <article class="rag-metric-card rag-metric-card-mode">
        <span class="rag-metric-icon rag-metric-icon-mode" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 6h14" />
            <path d="M5 12h14" />
            <path d="M5 18h14" />
            <circle cx="9" cy="6" r="1.9" fill="currentColor" stroke="none" />
            <circle cx="15" cy="12" r="1.9" fill="currentColor" stroke="none" />
            <circle cx="11" cy="18" r="1.9" fill="currentColor" stroke="none" />
          </svg>
        </span>
        <div class="rag-metric-copy">
        <span>{copy.metricsResolvedMode}</span>
        <strong data-rag-metric-mode>Auto</strong>
        </div>
      </article>
      <article class="rag-metric-card rag-metric-card-latency">
        <span class="rag-metric-icon rag-metric-icon-latency" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="7.4" />
            <path d="M12 8.3v4.2l3 1.8" />
          </svg>
        </span>
        <div class="rag-metric-copy">
        <span>{copy.metricsLatency}</span>
        <strong data-rag-metric-latency>—</strong>
        </div>
      </article>
      <article class="rag-metric-card rag-metric-card-sources">
        <span class="rag-metric-icon rag-metric-icon-sources" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 4.5h6l4 4v11H8z" />
            <path d="M14 4.5v4h4" />
            <path d="M10.5 13h5" />
            <path d="M10.5 16h5" />
          </svg>
        </span>
        <div class="rag-metric-copy">
        <span>{copy.metricsSources}</span>
        <strong data-rag-metric-sources>0</strong>
        </div>
      </article>
    </section>

    <section class="rag-composer-card">
      <div class="rag-composer-head">
        <div class="rag-composer-title">
          <span class="rag-composer-orb" aria-hidden="true">✦</span>
          <div>
            <h3 class="rag-section-title">{copy.questionLabel}</h3>
          </div>
        </div>
        <div class="rag-composer-actions">
          <button type="button" class="rag-primary" data-rag-submit>{copy.askButton}</button>
          <button type="button" class="rag-secondary" data-rag-reset>{copy.resetButton}</button>
        </div>
      </div>

      <label class="rag-field-shell" for="rag-question">
        <textarea id="rag-question" class="rag-question" rows="4" placeholder={copy.questionPlaceholder}></textarea>
      </label>

      <div class="rag-example-block">
        <p class="rag-kicker">{copy.exampleLabel}</p>
        <div class="rag-chip-row">
          {copy.examples.map((prompt) => (
            <button type="button" class="rag-chip" data-rag-example={prompt}>{prompt}</button>
          ))}
        </div>
      </div>
    </section>

    <section class="rag-controls-row">
      <section class="rag-mode-card">
        <div class="rag-mode-head">
          <div>
            <h3 class="rag-section-title">{copy.modeLabel}</h3>
          </div>
        </div>
        <div class="rag-mode-pills" data-rag-modes>
          <button type="button" class="rag-mode-pill is-active" data-rag-mode="auto">Auto</button>
          <button type="button" class="rag-mode-pill" data-rag-mode="fast">Fast</button>
          <button type="button" class="rag-mode-pill" data-rag-mode="safe">Safe</button>
          <button type="button" class="rag-mode-pill" data-rag-mode="deep_eval">Deep Eval</button>
          <button type="button" class="rag-mode-pill" data-rag-mode="creative">Creative</button>
          <button type="button" class="rag-mode-pill" data-rag-mode="agentic">Agentic</button>
        </div>
        <p class="rag-mode-helper" data-rag-mode-helper>{copy.modeHintAuto}</p>
        <p class="rag-mode-note" data-rag-mode-note hidden></p>
      </section>

      <section class="rag-advanced-card">
        <div class="rag-advanced-card-head">
          <h3 class="rag-section-title">{copy.manualLabel}</h3>
          <span class="rag-advanced-pill" data-rag-manual-state>{copy.manualSummaryClosed}</span>
        </div>
        <div class="rag-advanced-card-actions">
          <button type="button" class="rag-secondary rag-advanced-trigger" data-rag-advanced-open>{copy.manualOpenButton}</button>
          <button type="button" class="rag-secondary rag-advanced-reset" data-rag-manual-reset>{copy.manualResetButton}</button>
        </div>
      </section>
    </section>

    <dialog class="rag-advanced-modal" data-rag-advanced-dialog>
      <form method="dialog" class="rag-advanced-modal-shell">
        <div class="rag-advanced-modal-head">
          <div>
            <h3 class="rag-section-title">{copy.manualLabel}</h3>
          </div>
          <div class="rag-advanced-modal-actions">
            <button type="button" class="rag-secondary rag-advanced-reset" data-rag-manual-reset>{copy.manualResetButton}</button>
            <button type="submit" class="rag-secondary rag-advanced-close" data-rag-advanced-close>{copy.manualCloseButton}</button>
          </div>
        </div>

        <div class="rag-advanced-toggle-row">
          <label class="rag-switch rag-switch-master">
            <input type="checkbox" data-rag-manual-enabled />
            <span class="rag-switch-track"></span>
            <span class="rag-switch-label">{copy.manualToggle}</span>
          </label>
        </div>

        <div class="rag-manual-grid" data-rag-manual-fields-wrap>
          <article class="rag-manual-row">
            <div>
              <h4>{copy.workflow}</h4>
              <p>{copy.workflowHelp}</p>
            </div>
            <label class="rag-switch">
              <input type="checkbox" data-rag-field="use_workflow" />
              <span class="rag-switch-track"></span>
            </label>
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.toolRouting}</h4>
              <p>{copy.toolRoutingHelp}</p>
            </div>
            <label class="rag-switch">
              <input type="checkbox" data-rag-field="use_tool_routing" />
              <span class="rag-switch-track"></span>
            </label>
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.retryLoop}</h4>
              <p>{copy.retryLoopHelp}</p>
            </div>
            <label class="rag-switch">
              <input type="checkbox" data-rag-field="use_retry_loop" />
              <span class="rag-switch-track"></span>
            </label>
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.retrievalMode}</h4>
              <p>{copy.retrievalModeHelp}</p>
            </div>
            <select class="rag-select" data-rag-field="retrieval_mode">
              <option value="hybrid">{copy.hybrid}</option>
              <option value="dense">{copy.dense}</option>
            </select>
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.parentExpansion}</h4>
              <p>{copy.parentExpansionHelp}</p>
            </div>
            <label class="rag-switch">
              <input type="checkbox" data-rag-field="use_parent_expansion" />
              <span class="rag-switch-track"></span>
            </label>
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.contextCompression}</h4>
              <p>{copy.contextCompressionHelp}</p>
            </div>
            <label class="rag-switch">
              <input type="checkbox" data-rag-field="use_context_compression" />
              <span class="rag-switch-track"></span>
            </label>
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.longContextReorder}</h4>
              <p>{copy.longContextReorderHelp}</p>
            </div>
            <label class="rag-switch">
              <input type="checkbox" data-rag-field="use_long_context_reorder" />
              <span class="rag-switch-track"></span>
            </label>
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.minScore}</h4>
              <p>{copy.minScoreHelp}</p>
            </div>
            <input class="rag-number" type="number" min="0" max="1" step="0.01" data-rag-field="min_score" />
          </article>

          <article class="rag-manual-row">
            <div>
              <h4>{copy.maxRetries}</h4>
              <p>{copy.maxRetriesHelp}</p>
            </div>
            <input class="rag-number" type="number" min="0" max="5" step="1" data-rag-field="max_retries" />
          </article>
        </div>
      </form>
    </dialog>

    <section class="rag-results-grid">
      <section class="rag-panel rag-panel-answer">
        <div class="rag-panel-head">
          <div>
            <h3 class="rag-section-title">{copy.answerLabel}</h3>
          </div>
        </div>
        <div class="rag-answer" data-rag-answer>{copy.emptyAnswer}</div>
      </section>

      <section class="rag-panel rag-panel-journey">
        <div class="rag-panel-head">
          <div>
            <h3 class="rag-section-title">{copy.routeLabel}</h3>
          </div>
        </div>
        <div class="rag-route" data-rag-route>{copy.routeEmpty}</div>
      </section>

      <section class="rag-panel rag-panel-planner">
        <div class="rag-panel-head">
          <div>
            <h3 class="rag-section-title">{copy.plannerLabel}</h3>
          </div>
        </div>
        <div class="rag-mini-grid" data-rag-plan>{copy.plannerEmpty}</div>
      </section>

      <section class="rag-panel rag-panel-trace">
        <div class="rag-panel-head">
          <div>
            <h3 class="rag-section-title">{copy.timelineLabel}</h3>
          </div>
          <button type="button" class="rag-link-button" data-rag-trace-toggle hidden>{copy.traceExpand}</button>
        </div>
        <div class="rag-trace" data-rag-timeline>{copy.timelineEmpty}</div>
      </section>

    </section>

    <details class="rag-raw rag-sources-foldout">
      <summary>{copy.sourcesLabel}</summary>
      <div class="rag-sources rag-sources-foldout-body" data-rag-sources-foldout>{copy.sourceEmpty}</div>
      <div class="rag-foldout-actions">
        <button type="button" class="rag-link-button" data-rag-sources-toggle hidden>{copy.sourcesExpand}</button>
      </div>
    </details>

    <details class="rag-raw">
      <summary>{copy.rawLabel}</summary>
      <pre data-rag-raw></pre>
    </details>
  </div>
</section>

<script is:inline define:vars={{ copy }} type="module">
  const root = document.querySelector('[data-rag-lab]');

  if (root) {
    const AUTO_MODE = 'auto';
    const FALLBACK_MODES = ['auto', 'fast', 'safe', 'deep_eval', 'creative', 'agentic'];
    const state = {
      bootstrap: null,
      selectedMode: AUTO_MODE,
      manualOverridesEnabled: false,
      traceExpanded: false,
      sourcesExpanded: false,
    };

    const elements = {
      signal: root.querySelector('[data-rag-signal]'),
      status: root.querySelector('[data-rag-status]'),
      statusNote: root.querySelector('[data-rag-status-note]'),
      question: root.querySelector('#rag-question'),
      modes: root.querySelector('[data-rag-modes]'),
      modeHelper: root.querySelector('[data-rag-mode-helper]'),
      modeNote: root.querySelector('[data-rag-mode-note]'),
      advancedDialog: root.querySelector('[data-rag-advanced-dialog]'),
      advancedOpen: root.querySelector('[data-rag-advanced-open]'),
      advancedClose: root.querySelector('[data-rag-advanced-close]'),
      manualResetButtons: Array.from(root.querySelectorAll('[data-rag-manual-reset]')),
      manualEnabled: root.querySelector('[data-rag-manual-enabled]'),
      manualFields: Array.from(root.querySelectorAll('[data-rag-field]')),
      manualState: root.querySelector('[data-rag-manual-state]'),
      metricHealth: root.querySelector('[data-rag-metric-health]'),
      metricPolicy: root.querySelector('[data-rag-metric-policy]'),
      metricMode: root.querySelector('[data-rag-metric-mode]'),
      metricLatency: root.querySelector('[data-rag-metric-latency]'),
      metricSources: root.querySelector('[data-rag-metric-sources]'),
      answer: root.querySelector('[data-rag-answer]'),
      route: root.querySelector('[data-rag-route]'),
      plan: root.querySelector('[data-rag-plan]'),
      timeline: root.querySelector('[data-rag-timeline]'),
      traceToggle: root.querySelector('[data-rag-trace-toggle]'),
      sourcesFoldout: root.querySelector('[data-rag-sources-foldout]'),
      sourcesToggle: root.querySelector('[data-rag-sources-toggle]'),
      raw: root.querySelector('[data-rag-raw]'),
      submit: root.querySelector('[data-rag-submit]'),
      reset: root.querySelector('[data-rag-reset]'),
    };

    const defaultQuestion = copy.examples[0];
    elements.question.value = defaultQuestion;

    const escapeHtml = (value) =>
      String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatMaybe = (value) => {
      if (value === null || value === undefined || value === '') return '—';
      if (typeof value === 'boolean') return value ? 'true' : 'false';
      if (typeof value === 'number' && Number.isFinite(value)) return String(value);
      return String(value);
    };

    const formatLatency = (value) => {
      if (typeof value !== 'number' || Number.isNaN(value)) return '—';
      return `${value >= 100 ? value.toFixed(0) : value.toFixed(1)} ms`;
    };

    const getProfileMeta = (mode) => {
      const profiles = state.bootstrap?.queryProfiles || {};
      if (mode === AUTO_MODE) return profiles.auto_mode || null;
      return profiles.profiles?.[mode] || null;
    };

    const MODE_DESCRIPTION_ZH = {
      auto: 'Auto 會讓 runtime policy router 自動決定最適合的執行路徑。',
      fast: '低延遲的事實型 RAG 路徑。走較精簡的回答流程，不開昂貴 evaluator。',
      safe: '偏穩健的事實型 RAG 路徑。會優先保留較可控、較安全的回答方式。',
      deep_eval: '偏除錯與評估的模式。會打開較昂貴的 evaluator，方便檢查回答品質。',
      creative: '偏探索與延展的模式。適合需要更開放發想、重寫或多角度回答的問題。',
      agentic: '偏多步推理與規劃的模式。適合需要更多拆解、路由與工作流控制的問題。',
    };

    const getModeDescription = (mode) => {
      if (lang === 'zh' && MODE_DESCRIPTION_ZH[mode]) return MODE_DESCRIPTION_ZH[mode];
      return getProfileMeta(mode)?.description || '';
    };

    const truncateText = (value, maxLength) => {
      const text = String(value ?? '').replace(/\s+/g, ' ').trim();
      if (!text) return '';
      return text.length > maxLength ? `${text.slice(0, maxLength - 1)}…` : text;
    };

    const getFieldDefaultValue = (field) => {
      const key = field.getAttribute('data-rag-field');
      if (!key) return null;
      return state.bootstrap?.defaults?.[key];
    };

    const fieldMatchesDefault = (field) => {
      const defaultValue = getFieldDefaultValue(field);
      if (field.type === 'checkbox') {
        return Boolean(field.checked) === Boolean(defaultValue);
      }
      const currentValue = field.value === '' ? null : field.value;
      const expectedValue = defaultValue === undefined || defaultValue === null ? null : String(defaultValue);
      return currentValue === expectedValue;
    };

    const hasManualDiffs = () => elements.manualFields.some((field) => !fieldMatchesDefault(field));

    const stageSummary = (stage) => {
      if (!stage) return '';
      const output = stage.output || {};
      const metadata = stage.metadata || {};
      switch (stage.name) {
        case 'planner':
          return metadata.route_reason || output.rewritten_question || '';
        case 'retrieval':
          return `${output.output_count ?? output.retrieved_count ?? 0} source(s) via ${metadata.retrieval_mode || 'rag'}`;
        case 'parent_expansion':
          return `${output.source_count ?? 0} expanded source(s)`;
        case 'context_compression':
          return metadata.enabled ? `Compressed ${metadata.compressed_sources ?? 0} source(s)` : 'Compression off';
        case 'synthesis':
          return metadata.diagnostics?.deterministic_reason || metadata.model || `Answer chars: ${metadata.answer_chars ?? '—'}`;
        case 'citation_check':
          return `score ${formatMaybe(output.score)} / passed ${formatMaybe(output.passed)}`;
        case 'reflect_retry':
          return `retry decision: ${metadata.retry_decision || output.retry_decision || 'n/a'}`;
        case 'engine.ask':
          return `${output.source_count ?? 0} source(s), ${output.answer_chars ?? 0} chars`;
        default:
          return JSON.stringify(output || metadata).slice(0, 140);
      }
    };

    const routeSummary = (response) => {
      const policy = response.runtime_policy_router || {};
      const resolved = policy.resolved || {};
      const chips = [];
      chips.push(response.query_profile?.mode || resolved.query_mode || state.selectedMode);
      chips.push(response.filters?.retrieval_mode || resolved.retrieval_mode || 'hybrid');
      chips.push((response.workflow?.enabled || resolved.use_workflow) ? 'workflow:on' : 'workflow:off');
      chips.push((response.tool_routing?.enabled || resolved.use_tool_routing) ? `route:${response.tool_routing?.route || resolved.tool_route || 'tool'}` : 'route:rag');
      chips.push((response.retry_loop?.enabled || resolved.use_retry_loop) ? `retry:${response.retry_loop?.retry_attempt_count ?? 0}` : 'retry:off');
      const stages = response.observability?.timings?.stages || [];
      const preview = stages
        .filter((stage) => stage?.name && !String(stage.name).startsWith('engine.'))
        .map(
          (stage, index) => `
            <li class="rag-journey-step">
              <span class="rag-journey-index">${index + 1}</span>
              <span class="rag-journey-name">${escapeHtml(stage.name)}</span>
              <span class="rag-journey-time">${escapeHtml(formatLatency(stage.latency_ms))}</span>
            </li>
          `
        )
        .join('');

      return `
        <div class="rag-route-chips">${chips.map((chip) => `<span class="rag-path-chip">${escapeHtml(chip)}</span>`).join('')}</div>
        <ol class="rag-journey-list">${preview || `<li class="rag-journey-empty">${escapeHtml(copy.routeEmpty)}</li>`}</ol>
      `;
    };

    const setStatus = (healthy, runtimePolicyLive) => {
      elements.signal.classList.toggle('is-healthy', healthy);
      elements.signal.classList.toggle('is-bad', !healthy);
      elements.status.textContent = healthy ? copy.statusReady : copy.statusError;
      elements.statusNote.textContent = state.bootstrap?.proxy?.apiBaseUrl || '';
      elements.statusNote.setAttribute('data-policy-live', runtimePolicyLive ? 'true' : 'false');
    };

    const renderModes = () => {
      const queryProfiles = state.bootstrap?.queryProfiles;
      const supportedModes = queryProfiles?.supported_modes || FALLBACK_MODES;
      const profileDescription = getModeDescription(state.selectedMode);
      elements.modes.querySelectorAll('[data-rag-mode]').forEach((button) => {
        const mode = button.getAttribute('data-rag-mode') || '';
        const isSupported = supportedModes.includes(mode);
        button.hidden = !isSupported;
        button.classList.toggle('is-active', mode === state.selectedMode);
      });

      elements.modeHelper.textContent =
        state.selectedMode === AUTO_MODE
          ? copy.modeHintAuto
          : profileDescription || copy.modeHintManual;
      elements.modeNote.textContent = '';
      elements.modeNote.hidden = true;
    };

    const renderMetrics = (payload = null) => {
      const healthy = state.bootstrap?.health?.status === 'ok';
      const runtimePolicyLive = Boolean(state.bootstrap?.capabilities?.runtimePolicyEndpoint);
      const resolvedMode = payload?.query_profile?.mode || state.selectedMode || AUTO_MODE;
      const observedLatency = payload?.runtime_budget?.postrun?.observed?.latency_ms ?? null;
      const sourcesCount = (payload?.sources || []).length;
      elements.metricHealth.textContent = healthy ? 'OK' : copy.disconnected;
      elements.metricPolicy.textContent = runtimePolicyLive ? copy.policyLive : copy.policyFallback;
      elements.metricMode.textContent = resolvedMode === AUTO_MODE ? 'Auto' : resolvedMode;
      elements.metricLatency.textContent = formatLatency(observedLatency);
      elements.metricSources.textContent = String(sourcesCount);
    };

    const updateManualState = () => {
      elements.manualEnabled.checked = state.manualOverridesEnabled;
      elements.manualFields.forEach((field) => {
        field.disabled = !state.manualOverridesEnabled;
      });
      elements.manualState.textContent = state.manualOverridesEnabled
        ? copy.manualStatusActive
        : hasManualDiffs()
          ? copy.manualStatusCustom
          : copy.manualSummaryClosed;
    };

    const renderPlan = (response) => {
      const plan = response.plan || {};
      const originalQuestion = plan.original_question || response.question || '—';
      const rewrittenQuestion = plan.rewritten_question || originalQuestion;
      const routeReason = plan.route_reason || response.runtime_policy_router?.reasoning || '—';
      const rewriteReason = plan.rewrite_reason || response.runtime_policy_router?.user_explanation || '—';
      elements.plan.innerHTML = `
        <article class="rag-mini-card"><span>Original</span><strong>${escapeHtml(originalQuestion)}</strong></article>
        <article class="rag-mini-card"><span>Rewritten</span><strong>${escapeHtml(rewrittenQuestion)}</strong></article>
        <article class="rag-mini-card"><span>Route reason</span><strong>${escapeHtml(routeReason)}</strong></article>
        <article class="rag-mini-card"><span>Rewrite reason</span><strong>${escapeHtml(rewriteReason)}</strong></article>
      `;
    };

    const renderPlanEmpty = () => {
      elements.plan.innerHTML = `
        <article class="rag-mini-card"><span>Original</span><strong>—</strong></article>
        <article class="rag-mini-card"><span>Rewritten</span><strong>—</strong></article>
        <article class="rag-mini-card"><span>Route reason</span><strong>${escapeHtml(copy.plannerEmpty)}</strong></article>
        <article class="rag-mini-card"><span>Rewrite reason</span><strong>—</strong></article>
      `;
    };

    const renderTimeline = (response) => {
      const stages = response.observability?.timings?.stages || [];
      if (!stages.length) {
        elements.timeline.textContent = copy.timelineEmpty;
        elements.traceToggle.hidden = true;
        return;
      }
      const previewStages = stages;
      elements.traceToggle.hidden = true;

      elements.timeline.innerHTML = previewStages
        .map(
          (stage) => `
            <article class="rag-stage-card">
              <div class="rag-stage-marker"></div>
              <div class="rag-stage-body">
                <div class="rag-stage-head">
                  <strong>${escapeHtml(stage.name || 'stage')}</strong>
                  <span>${escapeHtml(formatLatency(stage.latency_ms))}</span>
                </div>
                <p>${escapeHtml(truncateText(stageSummary(stage), 140))}</p>
              </div>
            </article>
          `
        )
        .join('');
    };

    const renderSources = (response) => {
      const sources = response.sources || [];
      if (!sources.length) {
        elements.sourcesFoldout.textContent = copy.sourceEmpty;
        elements.sourcesToggle.hidden = true;
        return;
      }

      const previewCount = state.sourcesExpanded ? sources.length : Math.min(sources.length, 3);
      elements.sourcesToggle.hidden = sources.length <= 3;
      elements.sourcesToggle.textContent = state.sourcesExpanded ? copy.sourcesCollapse : copy.sourcesExpand;

      const renderedSourcesFull = sources
        .slice(0, previewCount)
        .map(
          (source, index) => `
            <article class="rag-source-card">
              <div class="rag-source-head">
                <strong>${escapeHtml(source.file_name || source.metadata?.file_name || `Source ${index + 1}`)}</strong>
                <span>${escapeHtml(source.marker || source.citation_marker || `#${index + 1}`)}</span>
              </div>
              <p class="rag-source-meta">score ${escapeHtml(formatMaybe(source.score))} · ${escapeHtml(source.metadata?.document_type || source.metadata?.file_type || 'source')}</p>
              <p class="rag-source-preview">${escapeHtml(truncateText(source.preview || source.text || '', 220))}</p>
            </article>
          `
        )
        .join('');
      elements.sourcesFoldout.innerHTML = renderedSourcesFull;
    };

    const renderResponse = (response) => {
      elements.answer.textContent = response.answer || '';
      elements.route.innerHTML = routeSummary(response);
      elements.raw.textContent = JSON.stringify(response, null, 2);
      renderPlan(response);
      renderTimeline(response);
      renderSources(response);
      renderMetrics(response);
    };

    const renderError = async (response) => {
      const payload = await response.json().catch(() => ({}));
      elements.answer.textContent = `${copy.failedPrefix}: ${payload?.detail?.message || payload?.detail || payload?.error || response.statusText}`;
      elements.route.innerHTML = `<div class="rag-journey-empty">${escapeHtml(copy.routeEmpty)}</div>`;
      renderPlanEmpty();
      elements.timeline.textContent = copy.timelineEmpty;
      elements.traceToggle.hidden = true;
      elements.sourcesFoldout.textContent = copy.sourceEmpty;
      elements.sourcesToggle.hidden = true;
      elements.raw.textContent = JSON.stringify(payload, null, 2);
      renderMetrics();
    };

    const coerceNumber = (value, { min = -Infinity, max = Infinity, integer = false } = {}) => {
      if (value === '' || value === null || value === undefined) return null;
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return null;
      const candidate = integer ? Math.trunc(numeric) : numeric;
      if (candidate < min || candidate > max) return null;
      return candidate;
    };

    const getPayload = () => {
      const payload = {
        question: elements.question.value.trim(),
        query_mode: state.selectedMode,
        use_runtime_policy_router: state.selectedMode === AUTO_MODE,
      };

      if (state.manualOverridesEnabled) {
        for (const field of elements.manualFields) {
          const key = field.getAttribute('data-rag-field');
          if (!key) continue;

          if (field.type === 'checkbox') {
            payload[key] = Boolean(field.checked);
          } else if (key === 'min_score') {
            const value = coerceNumber(field.value, { min: 0, max: 1 });
            if (value !== null) payload[key] = value;
          } else if (key === 'max_retries') {
            const value = coerceNumber(field.value, { min: 0, max: 5, integer: true });
            if (value !== null) payload[key] = value;
          } else if (field.value) {
            payload[key] = field.value;
          }
        }
      }

      return payload;
    };

    const getRenderedResponse = () => {
      if (!elements.raw.textContent) return null;
      try {
        return JSON.parse(elements.raw.textContent);
      } catch {
        return null;
      }
    };

    const setLoading = (loading) => {
      elements.submit.disabled = loading;
      elements.reset.disabled = loading;
      elements.manualEnabled.disabled = loading;
      elements.manualFields.forEach((field) => {
        field.disabled = loading || !state.manualOverridesEnabled;
      });
      elements.question.disabled = loading;
      elements.submit.textContent = loading ? copy.askingButton : copy.askButton;
    };

    const resetManualControls = () => {
      const defaults = state.bootstrap?.defaults || {};
      state.manualOverridesEnabled = false;
      for (const field of elements.manualFields) {
        const key = field.getAttribute('data-rag-field');
        if (!key) continue;
        const value = defaults[key];
        if (field.type === 'checkbox') {
          field.checked = Boolean(value);
        } else if (value === null || value === undefined) {
          field.value = '';
        } else {
          field.value = String(value);
        }
      }

      updateManualState();
    };

    const resetDefaults = () => {
      const defaults = state.bootstrap?.defaults || {};
      state.selectedMode = defaults.query_mode || AUTO_MODE;
      state.traceExpanded = false;
      state.sourcesExpanded = false;
      elements.question.value = defaultQuestion;
      resetManualControls();
      renderModes();
      renderMetrics();
      elements.answer.textContent = copy.emptyAnswer;
      elements.route.innerHTML = `<div class="rag-journey-empty">${escapeHtml(copy.routeEmpty)}</div>`;
      renderPlanEmpty();
      elements.timeline.textContent = copy.timelineEmpty;
      elements.traceToggle.hidden = true;
      elements.sourcesFoldout.textContent = copy.sourceEmpty;
      elements.sourcesToggle.hidden = true;
      elements.raw.textContent = '';
    };

    root.querySelectorAll('[data-rag-example]').forEach((button) => {
      button.addEventListener('click', () => {
        elements.question.value = button.getAttribute('data-rag-example') || '';
        elements.question.focus();
      });
    });

    elements.modes.querySelectorAll('[data-rag-mode]').forEach((button) => {
      button.addEventListener('click', () => {
        const nextMode = button.getAttribute('data-rag-mode') || AUTO_MODE;
        state.selectedMode = nextMode;
        renderModes();
        renderMetrics();
      });
    });

    elements.advancedOpen?.addEventListener('click', () => {
      elements.advancedDialog?.showModal();
    });

    elements.advancedDialog?.addEventListener('click', (event) => {
      const rect = elements.advancedDialog.getBoundingClientRect();
      const isInside =
        event.clientX >= rect.left &&
        event.clientX <= rect.right &&
        event.clientY >= rect.top &&
        event.clientY <= rect.bottom;
      if (!isInside) {
        elements.advancedDialog.close();
      }
    });

    elements.manualEnabled.addEventListener('change', () => {
      state.manualOverridesEnabled = elements.manualEnabled.checked;
      updateManualState();
    });

    elements.manualFields.forEach((field) => {
      field.addEventListener('change', updateManualState);
      field.addEventListener('input', updateManualState);
    });

    elements.manualResetButtons.forEach((button) => {
      button.addEventListener('click', () => {
        resetManualControls();
      });
    });

    elements.traceToggle?.addEventListener('click', () => {});

    elements.sourcesToggle.addEventListener('click', () => {
      state.sourcesExpanded = !state.sourcesExpanded;
      const payload = getRenderedResponse();
      if (payload) renderSources(payload);
    });

    elements.reset.addEventListener('click', resetDefaults);

    elements.submit.addEventListener('click', async () => {
      const payload = getPayload();
      if (!payload.question) {
        elements.answer.textContent = copy.needsQuestion;
        return;
      }

      setLoading(true);
      state.traceExpanded = false;
      state.sourcesExpanded = false;
      elements.answer.textContent = copy.runningAnswer;
      elements.route.innerHTML = `<div class="rag-journey-empty">${escapeHtml(copy.routeEmpty)}</div>`;
      renderPlanEmpty();
      elements.timeline.textContent = copy.timelineEmpty;
      elements.traceToggle.hidden = true;
      elements.sourcesFoldout.textContent = copy.sourceEmpty;
      elements.sourcesToggle.hidden = true;
      elements.raw.textContent = '';

      try {
        const response = await fetch('/api/rag/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          await renderError(response);
        } else {
          renderResponse(await response.json());
        }
      } catch (error) {
        elements.answer.textContent = `${copy.failedPrefix}: ${String(error)}`;
      } finally {
        setLoading(false);
      }
    });

    try {
      const bootstrapResponse = await fetch('/api/rag/bootstrap');
      const bootstrapData = await bootstrapResponse.json();
      if (!bootstrapResponse.ok || !bootstrapData.ok) {
        throw new Error(bootstrapData.error || 'Failed to load bootstrap data');
      }
      state.bootstrap = bootstrapData;
      resetDefaults();
      setStatus(state.bootstrap?.health?.status === 'ok', Boolean(state.bootstrap?.capabilities?.runtimePolicyEndpoint));
      renderModes();
      renderMetrics();
    } catch (error) {
      elements.signal.classList.add('is-bad');
      elements.status.textContent = copy.statusError;
      elements.statusNote.textContent = String(error);
      renderPlanEmpty();
    }
  }
</script>

