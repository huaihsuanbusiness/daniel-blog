---
import type { CategoryId } from '../utils/categories';

export interface Props {
  id: CategoryId;
  class?: string;
  size?: number;
}

const { id, class: className = '', size = 18 } = Astro.props;
const stroke = 1.9;
---

{ id === 'ai' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 4a5 5 0 0 0-5 5c0 1.9.9 3.3 2.1 4.3.8.7 1.4 1.6 1.6 2.7h2.6c.2-1.1.8-2 1.6-2.7C16.1 12.3 17 10.9 17 9a5 5 0 0 0-5-5Z"/>
    <path d="M9.5 18h5"/>
    <path d="M10 20.5h4"/>
    <path d="M10 8.5c.7-.7 1.4-1 2-1s1.3.3 2 1"/>
  </svg>
)}

{ id === 'openclaw' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M7 7c-1.4-1.2-2.9-1.1-4 0 .3 1.8 1.2 3 3.1 3.6"/>
    <path d="M17 7c1.4-1.2 2.9-1.1 4 0-.3 1.8-1.2 3-3.1 3.6"/>
    <path d="M9 8.5c-1.2 1.1-2 2.7-2 4.5 0 2.7 2.2 5 5 5s5-2.3 5-5c0-1.8-.8-3.4-2-4.5"/>
    <path d="M10 18.5 9 21"/>
    <path d="M14 18.5 15 21"/>
    <path d="M10.2 9.5 8.5 7.5"/>
    <path d="M13.8 9.5 15.5 7.5"/>
    <path d="M12 10.5v4.5"/>
    <path d="M10.5 12.5H13.5"/>
  </svg>
)}

{ id === 'pm' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="4" width="18" height="16" rx="2"/>
    <path d="M8 4v16"/>
    <path d="M8 9h13"/>
    <path d="M12 13h5"/>
    <path d="M12 17h3"/>
  </svg>
)}

{ id === 'startup' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M14.5 4.5c2.7.7 4.3 2.3 5 5L14 15l-5-5 5.5-5.5Z"/>
    <path d="M9 10 5.5 13.5c-.7.7-.7 1.8 0 2.5l2.5 2.5c.7.7 1.8.7 2.5 0L14 15"/>
    <path d="M10 14 6 18"/>
    <path d="M13 7l4 4"/>
    <path d="M4 20c1.5-1.8 3.1-2.4 5-2"/>
  </svg>
)}

{ id === 'business' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="7" width="18" height="13" rx="2"/>
    <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
    <path d="M3 12h18"/>
  </svg>
)}

{ id === 'web3' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="4" y="4" width="7" height="7" rx="1.5"/>
    <rect x="13" y="4" width="7" height="7" rx="1.5"/>
    <rect x="8.5" y="13" width="7" height="7" rx="1.5"/>
    <path d="M11 7.5h2"/>
    <path d="M9.5 11v2"/>
    <path d="M14.5 11v2"/>
  </svg>
)}

{ id === 'travel' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M2 14l8 1 9-9a1.5 1.5 0 1 1 2 2l-9 9 1 8-2.5-1.8L9 18l-5-.8L2 14Z"/>
    <path d="M14 10 6 8"/>
  </svg>
)}

{ id === 'murmurs' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 20h9"/>
